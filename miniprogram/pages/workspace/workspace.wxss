page {
  min-height: 100%;
  background: #ffffff;
  color: #151515;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

.studio-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #ffffff;
  --workspace-canvas-height: 780rpx;
  --workspace-top-chrome: 122rpx;
  --workspace-stage-top: 92rpx;
  --workspace-stage-size: 560rpx;
  --workspace-drawer-height: 592rpx;
  --workspace-tool-bottom: 608rpx;
  --workspace-tool-height: 82rpx;
  --workspace-tool-gap: 42rpx;
  --workspace-stage-tool-gap: 36rpx;
  --workspace-safe-bottom: 0rpx;
}

.studio-top {
  position: relative;
  z-index: 80;
  height: 122rpx;
  padding: 56rpx 28rpx 0;
  box-sizing: border-box;
}

.title-row {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 70rpx;
}

.back-btn {
  position: absolute;
  top: -8rpx;
  left: -14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: transparent;
  box-shadow: none;
  z-index: 120;
}

.back-btn::before {
  content: "";
  position: relative;
  z-index: 1;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #161616;
  border-bottom: 4rpx solid #161616;
  transform: rotate(45deg) translateX(3rpx);
}

.back-btn::after {
  content: "";
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 32rpx rgba(39, 34, 24, 0.12);
  transition: transform 120ms ease, background 120ms ease;
}

.back-btn-press::after {
  background: rgba(245, 243, 238, 0.96);
  transform: scale(0.94);
}

.canvas-area {
  position: relative;
  z-index: 10;
  height: var(--workspace-canvas-height);
  overflow: visible;
  background: #ffffff;
}

.studio-count-pill,
.tray-theme-switch {
  position: absolute;
  z-index: 45;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.48);
  background: rgba(255, 255, 255, 0.58);
  box-shadow: 0 18rpx 46rpx rgba(46, 40, 30, 0.10);
  backdrop-filter: blur(26rpx) saturate(1.2);
}

.studio-count-pill {
  top: 38rpx;
  left: 24rpx;
  display: flex;
  align-items: center;
  width: 258rpx;
  min-height: 94rpx;
  padding: 10rpx 12rpx;
  border-radius: 17rpx;
}

.studio-count-pill.over {
  border-color: rgba(194, 72, 62, 0.30);
  background: rgba(255, 246, 244, 0.92);
}

.count-gem {
  flex: 0 0 auto;
  width: 38rpx;
  height: 38rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 30% 24%, rgba(255, 255, 255, 0.95) 0 22%, rgba(230, 226, 209, 0.96) 24% 58%, rgba(184, 178, 155, 0.35) 100%);
  box-shadow: inset -4rpx -6rpx 12rpx rgba(65, 55, 38, 0.12);
}

.count-copy {
  min-width: 0;
}

.count-row {
  display: flex;
  align-items: baseline;
  white-space: nowrap;
}

.count-prefix {
  margin-right: 7rpx;
  font-size: 18rpx;
  font-weight: 500;
  color: rgba(26, 26, 26, 0.56);
}

.count-main {
  font-size: 29rpx;
  font-weight: 700;
  color: #111;
}

.count-unit {
  margin-left: 5rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: #202020;
}

.count-wrist {
  margin-top: 3rpx;
}

.count-wrist,
.count-current-length {
  position: relative;
  padding-left: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 17rpx;
  font-weight: 500;
  color: rgba(45, 45, 45, 0.55);
}

.count-current-length {
  margin-top: 1rpx;
  color: rgba(45, 45, 45, 0.42);
}

.count-wrist::before,
.count-current-length::before {
  content: "";
  position: absolute;
  left: 0;
  top: 3rpx;
  width: 16rpx;
  height: 16rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(65, 70, 66, 0.24);
  border-radius: 3rpx;
}

.count-current-length::before {
  border-radius: 50%;
}

.count-wrist::after,
.count-current-length::after {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 8rpx;
  width: 7rpx;
  height: 2rpx;
  background: rgba(65, 70, 66, 0.24);
}

.tray-theme-switch {
  top: 72rpx;
  right: 22rpx;
  width: 126rpx;
  min-height: 48rpx;
  padding: 8rpx 9rpx;
  border-radius: 16rpx;
}

.tray-theme-dots {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tray-theme-option {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid transparent;
}

.tray-theme-option.active {
  border-color: #c79b54;
}

.tray-theme-dot {
  width: 25rpx;
  height: 25rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(0, 0, 0, 0.07);
  box-shadow: inset 0 1rpx 4rpx rgba(0, 0, 0, 0.10);
}

.tray-theme-dot.warm {
  background: #efe7d8;
}

.tray-theme-dot.white {
  background: #fff;
}

.tray-theme-dot.black {
  background: #252525;
}

.bracelet-stage {
  position: absolute;
  left: 50%;
  top: var(--workspace-stage-top);
  width: var(--workspace-stage-size);
  height: var(--workspace-stage-size);
  transform: translateX(-50%);
  z-index: 20;
}

.bracelet-circle {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: visible;
  background: transparent;
  box-shadow: none;
}

.bracelet-tray-image {
  position: absolute;
  left: -6%;
  right: auto;
  top: -6%;
  bottom: auto;
  z-index: 1;
  width: 112%;
  height: 112%;
  border-radius: 0;
  opacity: 0.98;
  filter: none;
  background: transparent;
}

.tray-image-failed .bracelet-tray-image {
  display: none;
}

.tray-theme-white .bracelet-tray-image {
  opacity: 0.98;
  filter: none;
}

.tray-theme-white {
  background: transparent;
  box-shadow: none;
}

.tray-theme-black .bracelet-tray-image {
  opacity: 0.98;
  filter: none;
}

.tray-theme-black {
  background: transparent;
  box-shadow: none;
}

.bracelet-string,
.bracelet-canvas,
.bracelet-touch-layer,
.workspace-flight-canvas {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 8;
  width: 100%;
  height: 100%;
}

.bracelet-touch-layer {
  z-index: 14;
}

.workspace-flight-canvas {
  position: fixed;
  z-index: 12;
  pointer-events: none;
  opacity: 0;
}

.workspace-flight-canvas.active {
  z-index: 110;
  opacity: 1;
}

.completion-watermark {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translate(-50%, -50%);
  color: rgba(42, 38, 30, 0.18);
  pointer-events: none;
}

.studio-compass {
  font-size: 34rpx;
}

.completion-sub::after {
  content: "轻触珠子调整位置";
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: rgba(42, 38, 30, 0.20);
  white-space: nowrap;
}

.circle-bead {
  position: absolute;
  z-index: 12;
  overflow: visible;
  border-radius: 50%;
  transform-origin: center center;
}

.circle-bead-image,
.bead-glow {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.circle-bead.selected .circle-bead-image,
.circle-bead.selected .bead-glow {
  box-shadow: 0 0 0 4rpx rgba(196, 151, 78, 0.88), 0 12rpx 28rpx rgba(52, 40, 24, 0.18);
}

.circle-bead.dragging {
  z-index: 35;
}

.bead-glow {
  background: radial-gradient(circle at 32% 26%, rgba(255, 255, 255, 0.92) 0 12%, #d8d3c2 16% 58%, rgba(0, 0, 0, 0.24) 100%);
}

.tool-strip {
  position: fixed;
  left: 58rpx;
  right: 58rpx;
  bottom: var(--workspace-tool-bottom);
  z-index: 70;
  display: flex;
  align-items: stretch;
  height: var(--workspace-tool-height);
  min-height: var(--workspace-tool-height);
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.54);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.64);
  box-shadow: 0 18rpx 42rpx rgba(43, 37, 28, 0.11);
  backdrop-filter: blur(28rpx) saturate(1.18);
}

.tool-item {
  position: relative;
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #1e1e1e;
}

.tool-item::after {
  content: "";
  position: absolute;
  right: 0;
  top: 18rpx;
  width: 1rpx;
  height: 42rpx;
  background: rgba(28, 28, 28, 0.07);
}

.tool-item:last-child::after {
  display: none;
}

.tool-item.disabled {
  opacity: 0.32;
}

.tool-item.working {
  color: #9a7538;
}

.tool-item.active {
  color: #1f6a56;
}

.tool-item.danger {
  color: #b44940;
}

.tool-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30rpx;
  height: 30rpx;
  margin-bottom: 5rpx;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
}

.tool-undo::before {
  content: "↶";
}

.tool-wrist::before {
  content: "◎";
}

.tool-string::before {
  content: "◌";
}

.tool-release::before {
  content: "⌁";
}

.tool-energy::before {
  content: "☯";
}

.tool-save::before {
  content: "□";
}

.tool-clear::before {
  content: "×";
}

.tool-label {
  max-width: 64rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 18rpx;
  font-weight: 560;
  line-height: 1.1;
}

.flight-bead {
  position: fixed;
  z-index: 120;
  pointer-events: none;
}

.flight-bead-image,
.flight-bead-fallback {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.energy-floating-card,
.order-panel {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  z-index: 65;
  box-sizing: border-box;
  border: 1rpx solid rgba(30, 29, 24, 0.08);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 20rpx 48rpx rgba(43, 37, 28, 0.12);
  backdrop-filter: blur(18rpx);
}

.energy-floating-card {
  bottom: 118rpx;
  padding: 22rpx;
}

.energy-floating-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.energy-floating-title,
.energy-modal-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #151515;
}

.energy-floating-sub {
  display: block;
  margin-top: 5rpx;
  font-size: 21rpx;
  color: rgba(28, 28, 28, 0.48);
}

.energy-floating-action {
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  background: #edf3ef;
  font-size: 21rpx;
  font-weight: 700;
  color: #246150;
}

.energy-mini-row {
  display: flex;
  align-items: center;
  height: 36rpx;
}

.energy-mini-name {
  width: 42rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(26, 26, 26, 0.72);
}

.energy-mini-track {
  flex: 1;
  height: 10rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(20, 20, 20, 0.08);
}

.energy-mini-fill {
  height: 100%;
  border-radius: inherit;
}

.energy-mini-value {
  width: 56rpx;
  text-align: right;
  font-size: 20rpx;
  color: rgba(26, 26, 26, 0.50);
}

.order-panel {
  bottom: 124rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 22rpx;
}

.order-title {
  font-size: 25rpx;
  font-weight: 800;
}

.order-actions {
  display: flex;
  align-items: center;
}

.order-actions button {
  margin-left: 14rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f1eb;
  font-size: 22rpx;
  color: #222;
}

.order-actions button.danger {
  color: #b44940;
}

.material-drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  height: var(--workspace-drawer-height);
  box-sizing: border-box;
  padding-bottom: 0;
  overflow: hidden;
  border-radius: 34rpx 34rpx 0 0;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 -18rpx 58rpx rgba(40, 34, 26, 0.10);
  backdrop-filter: blur(20rpx);
}

.top-tabs {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(21, 21, 21, 0.06);
}

.top-tab {
  position: relative;
  margin-right: 62rpx;
  padding-top: 8rpx;
  font-size: 32rpx;
  font-weight: 650;
  color: rgba(17, 17, 17, 0.38);
}

.top-tab.active {
  color: #121212;
  font-weight: 760;
}

.top-tab.active::after {
  content: "";
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  bottom: -18rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #a49368;
}

.drawer-body {
  display: flex;
  height: calc(100% - 88rpx);
}

.category-rail {
  flex: 0 0 144rpx;
  height: 100%;
  box-sizing: border-box;
  padding: 14rpx 12rpx 220rpx 20rpx;
  background: linear-gradient(180deg, #fbfaf6 0%, #f2f0ea 100%);
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  margin-bottom: 12rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
  border-radius: 15rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 560;
  line-height: 1.22;
  color: rgba(29, 29, 29, 0.48);
}

.category-item.active {
  color: #8b6425;
  font-weight: 650;
  background: #f2e5ca;
}

.material-content {
  flex: 1;
  min-width: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 20rpx 24rpx 0;
  box-sizing: border-box;
}

.filter-summary {
  flex: 0 0 auto;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  font-weight: 560;
  color: rgba(25, 25, 25, 0.62);
}

.series-scroll {
  flex: 0 0 50rpx;
  width: 100%;
  height: 50rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  white-space: nowrap;
}

.series-tabs {
  display: block;
  align-items: center;
  width: 100%;
  white-space: nowrap;
}

.series-tab {
  display: inline-flex;
  vertical-align: top;
  align-items: center;
  justify-content: center;
  min-width: 84rpx;
  max-width: 148rpx;
  height: 48rpx;
  margin-right: 12rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(24, 24, 24, 0.07);
  border-radius: 999rpx;
  background: #fbfaf6;
  font-size: 21rpx;
  font-weight: 560;
  color: rgba(30, 30, 30, 0.50);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.series-tab.active {
  border-color: rgba(121, 133, 114, 0.40);
  background: #f0f4ed;
  color: #20241f;
}

.workspace-guide-card {
  flex: 0 0 auto;
  margin: 8rpx 0 16rpx;
  padding: 20rpx 20rpx 18rpx;
  border: 1rpx solid rgba(32, 32, 31, 0.08);
  border-radius: 20rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(249, 247, 241, 0.92));
  box-shadow: 0 12rpx 30rpx rgba(45, 39, 28, 0.08);
}

.workspace-guide-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.workspace-guide-kicker {
  color: #9d7a3f;
  font-size: 16rpx;
  font-weight: 820;
  letter-spacing: 2rpx;
}

.workspace-guide-title {
  margin-top: 6rpx;
  color: #181818;
  font-size: 26rpx;
  font-weight: 760;
}

.workspace-guide-close {
  flex: 0 0 auto;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  color: rgba(32, 32, 31, 0.40);
  background: rgba(32, 32, 31, 0.04);
  text-align: center;
  font-size: 27rpx;
  line-height: 38rpx;
}

.workspace-guide-list {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.workspace-guide-item {
  min-width: 0;
  padding: 14rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
}

.workspace-guide-index {
  color: rgba(32, 32, 31, 0.34);
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 1.4rpx;
}

.workspace-guide-item-title {
  margin-top: 8rpx;
  color: #20201f;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.2;
}

.workspace-guide-desc {
  margin-top: 6rpx;
  color: rgba(32, 32, 31, 0.52);
  font-size: 18rpx;
  line-height: 1.42;
}

.workspace-guide-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}

.workspace-guide-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 188rpx;
  height: 56rpx;
  min-height: 56rpx;
  border-radius: 999rpx;
  color: #fff;
  background: #20201f;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1;
}

.workspace-guide-secondary {
  color: rgba(32, 32, 31, 0.46);
  font-size: 21rpx;
}

.tip-bar {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  height: 56rpx;
  margin-bottom: 16rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #fff5dd;
  font-size: 21rpx;
  color: #8b6425;
}

.tip-icon {
  margin-right: 8rpx;
}

.tip-close {
  margin-left: auto;
  padding-left: 18rpx;
  font-size: 30rpx;
  color: rgba(80, 68, 28, 0.45);
}

.material-load-state {
  flex: 0 0 auto;
  margin: 10rpx 0 16rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f5f3ed;
  font-size: 22rpx;
  color: rgba(28, 28, 28, 0.54);
}

.material-load-warning {
  background: #fff1ed;
  color: #b44940;
}

.material-scroll {
  flex: 1 1 auto;
  min-height: 0;
  height: 0;
  padding-bottom: calc(164rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.material-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  column-gap: 18rpx;
  row-gap: 18rpx;
}

.material-card {
  position: relative;
  min-height: 138rpx;
  padding: 18rpx 12rpx 14rpx 102rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(20, 20, 20, 0.06);
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(41, 35, 24, 0.07);
}

.material-card.launching {
  opacity: 0.72;
  transform: scale(0.98);
}

.material-sphere {
  position: absolute;
  left: 18rpx;
  top: 24rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 18rpx rgba(35, 30, 22, 0.10);
}

.material-image {
  background: transparent;
}

.material-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
  font-weight: 660;
  color: #1f1f1d;
}

.material-effect {
  margin-top: 7rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 19rpx;
  color: rgba(26, 26, 26, 0.44);
}

.material-meta {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  min-width: 0;
  margin-top: 12rpx;
}

.material-price {
  flex: 0 1 auto;
  min-width: 0;
  margin-right: 6rpx;
  overflow: visible;
  text-overflow: clip;
  white-space: nowrap;
  font-size: 26rpx;
  font-weight: 700;
  color: #282824;
}

.size-pill {
  flex: 0 0 auto;
  min-width: 48rpx;
  max-width: none;
  height: 34rpx;
  padding: 0 7rpx;
  border-radius: 8rpx;
  background: #f0eee8;
  overflow: visible;
  text-align: center;
  text-overflow: clip;
  white-space: nowrap;
  font-size: 17rpx;
  font-weight: 560;
  line-height: 34rpx;
  color: rgba(28, 28, 28, 0.46);
}

.material-skeleton-card {
  padding-left: 102rpx;
}

.material-skeleton-sphere,
.material-skeleton-line,
.material-skeleton-meta view {
  background: linear-gradient(90deg, #f0eee8, #faf9f5, #f0eee8);
}

.material-skeleton-line {
  height: 20rpx;
  margin: 14rpx 0;
  border-radius: 999rpx;
}

.material-skeleton-line.strong {
  width: 76%;
}

.material-skeleton-meta {
  display: flex;
}

.material-skeleton-meta view {
  width: 56rpx;
  height: 22rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
}

.material-empty-state {
  padding: 90rpx 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(24, 24, 24, 0.44);
}

.load-more-hint {
  padding: 26rpx 0 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: rgba(24, 24, 24, 0.36);
}

.checkout-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 4;
  padding: 10rpx 24rpx calc(10rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-top: 1rpx solid rgba(30, 30, 30, 0.05);
  border-radius: 26rpx 26rpx 0 0;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 34rpx rgba(38, 32, 24, 0.08);
  backdrop-filter: blur(20rpx);
}

.checkout-summary {
  display: grid;
  grid-template-columns: 146rpx 1fr;
  column-gap: 12rpx;
  align-items: end;
}

.checkout-summary > text {
  display: block;
  grid-column: 1;
  font-size: 18rpx;
  font-weight: 520;
  color: rgba(25, 25, 25, 0.46);
}

.checkout-price {
  grid-column: 1;
  margin-top: 2rpx;
  font-size: 32rpx;
  font-weight: 760;
  color: #121212;
}

.checkout-metrics {
  grid-column: 2;
  grid-row: 1 / span 2;
  display: grid;
  grid-template-columns: minmax(112rpx, 148rpx);
  justify-content: start;
  column-gap: 10rpx;
  overflow: visible;
  border-radius: 0;
  background: transparent;
}

.checkout-metric {
  min-width: 0;
  padding: 8rpx 10rpx;
  box-sizing: border-box;
  border-left: 0;
  border-radius: 14rpx;
  background: #f6f3ed;
}

.checkout-metric:first-child {
  border-left: 0;
}

.checkout-metric text {
  display: block;
  margin-bottom: 3rpx;
  font-size: 16rpx;
  font-weight: 520;
  color: rgba(27, 27, 27, 0.38);
}

.checkout-metric view {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 19rpx;
  font-weight: 650;
  color: #333;
}

.checkout-actions {
  display: grid;
  grid-template-columns: 1fr 1.55fr;
  column-gap: 14rpx;
  margin-top: 10rpx;
}

.cart-btn,
.finish-btn,
.wrist-ruler-confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 62rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 680;
}

.cart-btn {
  border: 1rpx solid rgba(24, 24, 24, 0.12);
  background: rgba(255, 255, 255, 0.94);
  color: #151515;
}

.finish-btn,
.wrist-ruler-confirm {
  background: linear-gradient(135deg, #2f302e 0%, #171917 100%);
  color: #fff;
  box-shadow: 0 14rpx 30rpx rgba(20, 22, 20, 0.16);
}

.wrist-picker-mask,
.energy-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 150;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.38);
}

.wrist-picker,
.energy-modal {
  width: 100%;
  box-sizing: border-box;
  border-radius: 34rpx 34rpx 0 0;
  background: #fff;
  box-shadow: 0 -20rpx 60rpx rgba(0, 0, 0, 0.18);
}

.wrist-picker {
  padding: 30rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
}

.wrist-picker-head,
.energy-modal-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.wrist-picker-title {
  font-size: 34rpx;
  font-weight: 900;
}

.wrist-picker-subtitle {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: rgba(26, 26, 26, 0.50);
}

.wrist-picker-close,
.energy-modal-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #f3f1ec;
  font-size: 36rpx;
  color: rgba(28, 28, 28, 0.58);
}

.wrist-ruler-value {
  margin-top: 32rpx;
  text-align: center;
}

.wrist-ruler-number {
  font-size: 72rpx;
  font-weight: 900;
  color: #141414;
}

.wrist-ruler-unit {
  margin-left: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.wrist-ruler-caption,
.wrist-ruler-range {
  text-align: center;
  font-size: 22rpx;
  color: rgba(24, 24, 24, 0.42);
}

.wrist-ruler-caption {
  margin-top: 6rpx;
}

.wear-style-section {
  margin-top: 24rpx;
}

.wear-style-section-title {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  font-weight: 850;
  color: #171917;
}

.wear-style-options {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.wear-style-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
  padding: 18rpx 18rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(24, 24, 24, 0.08);
  border-radius: 24rpx;
  background: #f8f6f1;
}

.wear-style-option.active {
  border-color: rgba(100, 124, 112, 0.38);
  background: rgba(100, 124, 112, 0.10);
}

.wear-style-option-main {
  min-width: 0;
}

.wear-style-option-title {
  font-size: 26rpx;
  font-weight: 900;
  color: #171917;
}

.wear-style-option-desc {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 19rpx;
  color: rgba(24, 24, 24, 0.46);
}

.wear-style-check {
  flex: 0 0 auto;
  width: 28rpx;
  height: 28rpx;
  margin-left: 12rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(24, 24, 24, 0.16);
  border-radius: 50%;
}

.wear-style-option.active .wear-style-check {
  border: 8rpx solid #647c70;
  background: #fff;
}

.wrist-ruler-wrap {
  position: relative;
  height: 138rpx;
  margin: 32rpx 0 12rpx;
  overflow: hidden;
}

.wrist-ruler-pointer {
  position: absolute;
  left: 50%;
  top: 0;
  z-index: 3;
  width: 3rpx;
  height: 104rpx;
  border-radius: 999rpx;
  background: #c79b54;
  transform: translateX(-50%);
}

.wrist-ruler-scroll {
  height: 100%;
}

.wrist-ruler-track {
  display: flex;
  align-items: flex-start;
  height: 100%;
  box-sizing: border-box;
  padding-top: 26rpx;
}

.wrist-ruler-tick {
  position: relative;
  flex: 0 0 auto;
  height: 88rpx;
}

.tick-line {
  width: 2rpx;
  height: 28rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: rgba(20, 20, 20, 0.18);
}

.wrist-ruler-tick.middle .tick-line {
  height: 42rpx;
}

.wrist-ruler-tick.major .tick-line {
  width: 3rpx;
  height: 56rpx;
  background: rgba(20, 20, 20, 0.44);
}

.tick-label {
  position: absolute;
  left: 50%;
  top: 66rpx;
  transform: translateX(-50%);
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(20, 20, 20, 0.48);
}

.wrist-ruler-fade {
  position: absolute;
  top: 0;
  bottom: 0;
  z-index: 2;
  width: 90rpx;
  pointer-events: none;
}

.wrist-ruler-fade.left {
  left: 0;
  background: linear-gradient(90deg, #fff 0%, rgba(255, 255, 255, 0) 100%);
}

.wrist-ruler-fade.right {
  right: 0;
  background: linear-gradient(270deg, #fff 0%, rgba(255, 255, 255, 0) 100%);
}

.wrist-ruler-confirm {
  margin-top: 26rpx;
}

.energy-modal {
  min-height: 620rpx;
  padding: 30rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
}

.energy-modal-body {
  margin-top: 24rpx;
}

.energy-modal-svg {
  width: 100%;
}

.device-narrow .studio-count-pill,
.device-compact .studio-count-pill,
.device-short .studio-count-pill {
  top: 38rpx;
  left: 20rpx;
  width: 244rpx;
  min-height: 90rpx;
  padding: 9rpx 11rpx;
}

.device-narrow .tray-theme-switch,
.device-compact .tray-theme-switch,
.device-short .tray-theme-switch {
  top: 74rpx;
  right: 18rpx;
  width: 118rpx;
  padding: 8rpx;
}

.device-narrow .count-main,
.device-compact .count-main,
.device-short .count-main {
  font-size: 28rpx;
}

.device-narrow .count-wrist,
.device-compact .count-wrist,
.device-short .count-wrist,
.device-narrow .count-current-length,
.device-compact .count-current-length,
.device-short .count-current-length {
