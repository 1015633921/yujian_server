}

.wrist-guide-sheet {
  max-height: 88vh;
  padding: 30rpx 32rpx calc(26rpx + env(safe-area-inset-bottom));
}

.wrist-guide-tabs {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 22rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #f5f1e9;
}

.wrist-guide-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 58rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 760;
  color: rgba(35, 29, 22, 0.52);
}

.wrist-guide-tab.active {
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(64, 48, 28, 0.10);
  color: #2a2018;
}

.wrist-guide-body {
  height: 980rpx;
  max-height: 62vh;
  margin-top: 18rpx;
  border-radius: 24rpx;
  background: #fffaf2;
}

.wrist-guide-image {
  display: block;
  width: 100%;
  border-radius: 24rpx;
}

.workspace-help-list {
  padding: 18rpx;
  box-sizing: border-box;
}

.workspace-help-item {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(44, 35, 24, 0.08);
}

.workspace-help-item:last-child {
  border-bottom: 0;
}

.workspace-help-tag {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  min-height: 76rpx;
  margin-right: 16rpx;
  padding: 8rpx 6rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #efe2cb;
  flex-direction: column;
  gap: 4rpx;
}

.workspace-help-icon {
  width: 34rpx;
  height: 34rpx;
  margin: 0;
  color: #805c2e;
  font-size: 30rpx;
}

.workspace-help-icon.plate-random-icon::before {
  margin-right: 0;
}

.workspace-help-icon.workspace-icon-theme::before {
  content: "\25CC";
}

.workspace-help-icon.workspace-icon-cart::before {
  content: "\8D2D";
}

.workspace-help-tag-text {
  font-size: 20rpx;
  font-weight: 820;
  line-height: 1;
  color: #805c2e;
}

.workspace-help-copy {
  min-width: 0;
}

.workspace-help-title {
  font-size: 25rpx;
  font-weight: 850;
  line-height: 1.24;
  color: #1b1916;
}

.workspace-help-desc {
  margin-top: 7rpx;
  font-size: 21rpx;
  line-height: 1.45;
  color: rgba(28, 24, 20, 0.52);
}

.share-sheet {
  padding: 30rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
}

.share-sheet-card {
  display: flex;
  align-items: center;
  min-height: 154rpx;
  margin-top: 28rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(25, 25, 25, 0.08);
  border-radius: 24rpx;
  background: #fbfaf7;
}

.share-sheet-preview {
  flex: 0 0 118rpx;
  width: 118rpx;
  height: 118rpx;
  border-radius: 18rpx;
  background: #f2efe8;
}

.share-sheet-placeholder {
  position: relative;
}

.share-sheet-placeholder::after {
  content: "";
  position: absolute;
  left: 35rpx;
  top: 35rpx;
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid rgba(25, 25, 25, 0.18);
  border-radius: 50%;
}

.share-sheet-card-copy {
  min-width: 0;
  margin-left: 20rpx;
}

.share-sheet-card-title {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 27rpx;
  font-weight: 780;
  line-height: 1.32;
  color: #171717;
}

.share-sheet-card-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 560;
  color: rgba(25, 25, 25, 0.48);
}

.share-sheet-primary,
.share-sheet-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 720;
}

.share-sheet-primary {
  background: #171917;
  color: #fff;
  box-shadow: 0 14rpx 30rpx rgba(20, 22, 20, 0.16);
}

.share-sheet-secondary {
  border: 1rpx solid rgba(24, 24, 24, 0.12);
  background: #fff;
  color: #161616;
}

.device-narrow .studio-metrics,
.device-compact .studio-metrics,
.device-short .studio-metrics {
  left: 88rpx;
  right: 128rpx;
  min-height: 72rpx;
}

.device-narrow .tray-theme-switch,
.device-compact .tray-theme-switch,
.device-short .tray-theme-switch {
  width: var(--workspace-theme-width);
}

.device-narrow .tray-theme-label,
.device-compact .tray-theme-label,
.device-short .tray-theme-label {
  margin-bottom: 0;
  font-size: 18rpx;
}

.device-narrow .studio-metric-label,
.device-compact .studio-metric-label,
.device-short .studio-metric-label {
  font-size: 16rpx;
}

.device-narrow .studio-metric-value,
.device-compact .studio-metric-value,
.device-short .studio-metric-value {
  font-size: 27rpx;
}

.device-narrow .studio-metric-sub,
.device-compact .studio-metric-sub,
.device-short .studio-metric-sub {
  font-size: 18rpx;
}

.device-narrow .tool-icon,
.device-compact .tool-icon,
.device-short .tool-icon {
  width: 38rpx;
  height: 32rpx;
}

.device-narrow .tool-label,
.device-compact .tool-label,
.device-short .tool-label {
  font-size: 20rpx;
}

.device-narrow .material-card,
.device-compact .material-card,
.device-short .material-card {
  min-height: 136rpx;
  padding-left: 100rpx;
}

.device-narrow .material-sphere,
.device-compact .material-sphere,
.device-short .material-sphere {
  width: 68rpx;
  height: 68rpx;
}

.device-wide .bracelet-stage,
.device-tall .bracelet-stage {
  filter: none;
}
