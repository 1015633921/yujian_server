page {
  background: #f8f8f8;
}

.studio-page {
  min-height: 100vh;
  overflow: hidden;
  color: #111;
  background: linear-gradient(180deg, #fbfaf8 0%, #f7f4ef 52%, #fbfaf8 100%);
}

.studio-top {
  position: relative;
  z-index: 8;
  padding: calc(24rpx + env(safe-area-inset-top)) 34rpx 14rpx;
  border-bottom: 1rpx solid rgba(122, 78, 58, 0.08);
  background: rgba(255, 255, 255, 0.86);
  backdrop-filter: blur(18rpx);
}

.title-row {
  position: relative;
  display: grid;
  grid-template-columns: 86rpx 1fr 86rpx;
  align-items: center;
  min-height: 72rpx;
}

.back-btn {
  font-size: 70rpx;
  font-weight: 300;
  line-height: 70rpx;
}

.title {
  text-align: center;
  font-size: 40rpx;
  font-weight: 900;
}

.save-nav {
  display: none;
}

.canvas-area {
  position: relative;
  height: 792rpx;
  overflow: hidden;
}

.count-badge {
  position: absolute;
  top: -10rpx;
  left: 50%;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 62rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #7f8977;
  background: rgba(255, 253, 248, 0.94);
  box-shadow: 0 12rpx 26rpx rgba(73, 51, 33, 0.12);
  transform: translateX(-50%);
}

.count-badge text {
  color: #9a9189;
  font-size: 20rpx;
}

.count-badge .count-target {
  padding-left: 12rpx;
  border-left: 1rpx solid rgba(126, 139, 117, .2);
  color: #7f8977;
}

.count-badge view {
  font-size: 25rpx;
  font-weight: 900;
}

.count-badge.over {
  color: #b35f34;
  background: #eef0e9;
}

.wrist-selector {
  position: absolute;
  top: 62rpx;
  left: 24rpx;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 52rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(126, 139, 117, 0.16);
  border-radius: 999rpx;
  color: #626c5d;
  background: rgba(247, 245, 237, 0.96);
  box-shadow: 0 10rpx 24rpx rgba(73, 51, 33, 0.08);
  transform: none;
}

.wrist-selector-label {
  color: #9a9189;
  font-size: 19rpx;
  font-weight: 700;
}

.wrist-selector-value {
  color: #34302d;
  font-size: 24rpx;
  font-weight: 900;
}

.wrist-selector-hint {
  color: #7f8977;
  font-size: 18rpx;
}

.tool-strip {
  position: absolute;
  top: 132rpx;
  right: 10rpx;
  left: auto;
  z-index: 6;
  display: grid;
  grid-template-columns: 1fr;
  width: 72rpx;
  min-height: 0;
  gap: 10rpx;
  padding: 12rpx 5rpx;
  border: 1rpx solid rgba(122, 78, 58, 0.08);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  box-shadow: 0 18rpx 36rpx rgba(73, 51, 33, 0.10);
  backdrop-filter: blur(18rpx);
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-height: 54rpx;
}

.tool-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  color: #34302d;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: inset 0 0 0 1rpx rgba(122, 78, 58, 0.08);
  backdrop-filter: blur(10rpx);
  font-size: 24rpx;
  font-weight: 800;
}

.undo-icon {
  color: #34302d;
  background: rgba(255, 255, 255, 0.86);
}

.tool-label {
  display: none;
}

.toolbox-icon {
  color: #626c5d;
  background: #eef0e9;
}

.history-strip {
  position: absolute;
  top: 58rpx;
  left: 20rpx;
  z-index: 7;
  display: flex;
  align-items: center;
  gap: 9rpx;
}

.history-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border: 1rpx solid rgba(122, 78, 58, .1);
  border-radius: 999rpx;
  color: #555c53;
  background: rgba(255, 255, 255, .88);
  box-shadow: 0 10rpx 24rpx rgba(73, 51, 33, .09);
  font-size: 29rpx;
  font-weight: 800;
}

.history-icon.disabled {
  opacity: .34;
}

.wrist-chip {
  min-height: 48rpx;
  padding: 0 17rpx;
  border: 1rpx solid rgba(126, 139, 117, .16);
  border-radius: 999rpx;
  color: #626c5d;
  background: rgba(247, 245, 237, .92);
  box-shadow: 0 10rpx 24rpx rgba(73, 51, 33, .07);
  font-size: 19rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.bracelet-stage {
  position: absolute;
  top: 18rpx;
  left: 50%;
  width: 560rpx;
  height: 560rpx;
  transform: translateX(-50%);
}

.bracelet-circle {
  position: relative;
  width: 560rpx;
  height: 560rpx;
  border: 7rpx solid rgba(172, 139, 102, 0.5);
  border-radius: 999rpx;
  box-shadow:
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.72),
    inset 0 0 42rpx rgba(92, 65, 42, 0.16),
    inset 0 -18rpx 30rpx rgba(104, 73, 47, 0.12),
    0 8rpx 0 rgba(117, 83, 55, 0.13),
    0 24rpx 52rpx rgba(73, 51, 33, 0.2);
  background:
    radial-gradient(ellipse at 24% 18%, rgba(255, 255, 255, 0.82) 0 7%, transparent 28%),
    linear-gradient(118deg, transparent 0 24%, rgba(147, 115, 83, 0.045) 25% 26%, transparent 27% 48%, rgba(255, 255, 255, 0.25) 49% 50%, transparent 51%),
    linear-gradient(28deg, transparent 0 38%, rgba(121, 91, 64, 0.035) 39% 40%, transparent 41% 66%, rgba(255, 255, 255, 0.2) 67% 68%, transparent 69%),
    radial-gradient(circle at 50% 46%, #fffdf8 0 47%, #f7f0e6 70%, #e5d6c4 91%, #c7ad91 100%);
}

.bracelet-circle::before {
  position: absolute;
  inset: 17rpx;
  z-index: 0;
  border: 3rpx solid rgba(130, 97, 67, 0.2);
  border-radius: 999rpx;
  box-shadow:
    inset 0 4rpx 8rpx rgba(84, 58, 38, 0.13),
    0 2rpx 3rpx rgba(255, 255, 255, 0.9);
  content: "";
}

.bracelet-circle::after {
  position: absolute;
  inset: 51rpx;
  z-index: 0;
  border: 2rpx solid rgba(151, 116, 82, 0.12);
  border-radius: 999rpx;
  box-shadow:
    inset 0 0 24rpx rgba(113, 83, 55, 0.07),
    0 0 0 9rpx rgba(255, 255, 255, 0.16);
  content: "";
}

.bracelet-string {
  position: absolute;
  z-index: 1;
  border: 5rpx solid transparent;
  border-radius: 999rpx;
  box-shadow: none;
  box-sizing: border-box;
  opacity: 0.38;
  pointer-events: none;
}

.bracelet-string.has-beads {
  opacity: 1;
}

.bracelet-string.empty {
  border-style: dashed;
  box-shadow: none;
}

.bracelet-canvas {
  position: absolute;
  inset: 0;
  z-index: 3;
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
}

.bracelet-touch-layer {
  position: absolute;
  inset: -44rpx;
  z-index: 8;
  display: block;
  border-radius: 999rpx;
}

.workspace-flight-canvas {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 29;
  display: block;
  visibility: hidden;
  opacity: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
}

.workspace-flight-canvas.active {
  visibility: visible;
  opacity: 1;
}

.bracelet-string-highlight {
  display: none;
}

.completion-watermark {
  position: absolute;
  top: 50%;
  left: 50%;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 360rpx;
  min-height: 210rpx;
  text-align: center;
  color: #7f8977;
  transform: translate(-50%, -50%);
}

.brand-emblem {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-seal {
  position: absolute;
  top: 7rpx;
  right: -37rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border: 3rpx solid rgba(139, 62, 47, 0.72);
  color: rgba(139, 62, 47, 0.82);
  font-family: serif;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 38rpx;
  transform: rotate(5deg);
}

.brand-name {
  color: rgba(91, 62, 44, 0.82);
  font-family: "STKaiti", "KaiTi", serif;
  font-size: 66rpx;
  font-weight: 700;
  line-height: 76rpx;
  letter-spacing: 14rpx;
  text-indent: 14rpx;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.78);
}

.brand-en {
  margin-top: 3rpx;
  color: rgba(122, 91, 68, 0.48);
  font-family: serif;
  font-size: 17rpx;
  letter-spacing: 8rpx;
  text-indent: 8rpx;
}

.brand-divider {
  display: grid;
  grid-template-columns: 76rpx 18rpx 76rpx;
  align-items: center;
  gap: 9rpx;
  margin: 17rpx 0 10rpx;
  color: rgba(139, 101, 70, 0.42);
  font-size: 12rpx;
}

.brand-divider text {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(139, 101, 70, 0.45));
}

.brand-divider text:last-child {
  transform: rotate(180deg);
}

.completion-sub {
  color: rgba(112, 91, 75, 0.58);
  font-size: 20rpx;
  line-height: 30rpx;
}

.circle-bead {
  position: absolute;
  z-index: 2;
  overflow: hidden;
  border-radius: 999rpx;
  box-shadow: inset -8rpx -12rpx 18rpx rgba(0, 0, 0, 0.18), 0 8rpx 18rpx rgba(0, 0, 0, 0.12);
  will-change: transform;
}

.bracelet-circle .circle-bead {
  transition: transform 80ms linear;
}

.bracelet-circle.shuffling .circle-bead,
.circle-bead.dragging {
  transition: none;
}

.circle-bead.has-image {
  background: transparent !important;
  box-shadow: none;
}

.circle-bead.active {
  outline: 5rpx solid rgba(0, 0, 0, 0.78);
  outline-offset: 5rpx;
  z-index: 3;
}

.circle-bead.dragging {
  z-index: 12;
  opacity: 0.96;
  filter: drop-shadow(0 16rpx 20rpx rgba(57, 38, 27, 0.26));
}

.circle-bead.delete-ready {
  outline: 0;
  opacity: 0.68;
}

.bead-glow {
  width: 34%;
  height: 34%;
  margin: 16% 0 0 18%;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.55);
}

.circle-bead-image {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
  background: transparent;
  transform: scale(1.04);
}

.bead-through-thread {
  position: absolute;
  top: 3%;
  bottom: 3%;
  left: 50%;
  z-index: 3;
  width: 6rpx;
  pointer-events: none;
  transform: translateX(-50%);
}

.bead-through-thread::before,
.bead-through-thread::after {
  position: absolute;
  left: 50%;
  width: 4rpx;
  height: 23%;
  border-radius: 999rpx;
  background: rgba(235, 232, 222, 0.38);
  box-shadow: 0 0 2rpx rgba(255, 255, 255, 0.48);
  content: "";
  transform: translateX(-50%);
}

.bead-through-thread::before {
  top: 0;
}

.bead-through-thread::after {
  bottom: 0;
}

.bead-through-thread-core {
  position: absolute;
  top: 20%;
  bottom: 20%;
  left: 50%;
  width: 3rpx;
  border-radius: 999rpx;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.18),
    rgba(235, 232, 222, 0.34) 22%,
    rgba(210, 207, 198, 0.26) 50%,
    rgba(235, 232, 222, 0.34) 78%,
    rgba(255, 255, 255, 0.18)
  );
  opacity: 0.56;
  transform: translateX(-50%);
}

.flight-bead {
  position: fixed;
  z-index: 30;
  overflow: hidden;
  border-radius: 999rpx;
  box-shadow: 0 12rpx 24rpx rgba(42, 29, 19, 0.28);
  pointer-events: none;
  will-change: transform;
}

.flight-bead-image,
.flight-bead-fallback {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: inherit;
}

.flight-bead-image {
  transform: scale(1.02);
}

.energy-board {
  position: relative;
  display: grid;
  grid-template-columns: 1fr;
  grid-template-rows: 48rpx 1fr;
  align-items: center;
  min-width: 0;
  width: 238rpx;
  height: 224rpx;
  padding: 10rpx 12rpx 12rpx;
  border: 1rpx solid rgba(122, 78, 58, 0.08);
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 88% 50%, rgba(212, 172, 111, 0.14), transparent 46%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 250, 244, 0.78));
  box-shadow: 0 16rpx 34rpx rgba(73, 51, 33, 0.07);
  box-sizing: border-box;
  overflow: hidden;
}

.energy-board-copy {
  text-align: center;
}

.energy-board-title {
  color: #7f8977;
  font-size: 27rpx;
  font-weight: 900;
}

.energy-board-sub {
  margin-top: 4rpx;
  color: #9a9189;
  font-size: 18rpx;
}

.energy-chart-shell {
  position: relative;
  justify-self: center;
  width: 202rpx;
  height: 164rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background:
    radial-gradient(circle, rgba(255, 255, 255, 0.94), rgba(246, 239, 229, 0.56));
  box-shadow: inset 0 0 0 1rpx rgba(122, 78, 58, 0.05);
}

.pentagon-chart {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 200rpx;
  height: 200rpx;
  transform: translate(-50%, -50%) scale(0.72);
  transform-origin: center center;
}

.pentagon-line {
  position: absolute;
  z-index: 2;
  height: 5rpx;
  border-radius: 999rpx;
  background: rgba(122, 78, 58, 0.66);
  transform-origin: 0 50%;
}

.target-dot,
.current-dot {
  position: absolute;
  border-radius: 999rpx;
}

.target-dot {
  z-index: 3;
  opacity: 0.42;
  outline: 2rpx solid #fff;
}

.current-dot {
  z-index: 4;
  box-shadow: 0 0 0 3rpx #fff, 0 4rpx 10rpx rgba(0, 0, 0, 0.18);
}

.pentagon-label {
  position: absolute;
  color: rgba(122, 78, 58, 0.58);
  font-size: 20rpx;
  font-weight: 800;
}

.label-wood { top: 6rpx; left: 90rpx; }
.label-fire { top: 62rpx; right: 6rpx; }
.label-earth { right: 22rpx; bottom: 16rpx; }
.label-metal { bottom: 16rpx; left: 22rpx; }
.label-water { top: 62rpx; left: 6rpx; }

.energy-bars {
  display: none;
}

.inline-pentagon-chart {
  height: 98rpx;
  margin-bottom: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inline-pentagon-canvas {
  position: relative;
  width: 220rpx;
  height: 98rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.92), rgba(246,239,229,0.5));
  box-shadow: inset 0 0 0 1rpx rgba(122,78,58,0.05);
}

.inline-pentagon-chart-view {
  transform: translate(-50%, -50%) scale(0.38) !important;
  transform-origin: center center !important;
}

.energy-row-mini {
  display: grid;
  grid-template-columns: 28rpx 1fr 48rpx;
  align-items: center;
  gap: 8rpx;
  font-size: 18rpx;
}

.energy-row-mini text:first-child {
  color: #666;
  font-weight: 800;
}

.energy-row-mini text:last-child {
  color: #111;
  text-align: right;
}

.energy-track-mini {
  position: relative;
  height: 10rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eef0f1;
}

.target-bar,
.current-bar {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  border-radius: 999rpx;
}

.target-bar {
  background: #cfd4d7;
}

.current-bar {
  box-shadow: 0 0 0 1rpx rgba(255, 255, 255, 0.45) inset;
}

.order-panel {
  position: absolute;
  left: 18rpx;
  top: 224rpx;
  z-index: 4;
  width: 78rpx;
  padding: 12rpx 8rpx;
  border: 1rpx solid rgba(122, 78, 58, 0.08);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 34rpx rgba(73, 51, 33, 0.10);
  backdrop-filter: blur(16rpx);
}

.order-title {
  display: block;
  margin-bottom: 10rpx;
  color: #9a9189;
  text-align: center;
  font-size: 16rpx;
  line-height: 22rpx;
}

.order-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10rpx;
}

.order-actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid #ececec;
  border-radius: 999rpx;
  color: #111;
  background: #fff;
  font-size: 18rpx;
  font-weight: 700;
}

.order-actions .danger {
  color: #fff;
  border-color: #111;
  background: #111;
}

.energy-area {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(180deg, rgba(127, 137, 119, .46), rgba(127, 137, 119, .14));
  filter: drop-shadow(0 8rpx 14rpx rgba(101, 112, 96, .28));
  opacity: .82;
}

.order-actions button:active,
.finish-btn:active {
  opacity: .82;
  transform: scale(.98);
}

.device-real .circle-bead.dragging {
  filter: none;
}

.device-low-performance .circle-bead {
  box-shadow: inset -5rpx -7rpx 12rpx rgba(0, 0, 0, .14), 0 4rpx 10rpx rgba(0, 0, 0, .09);
}

.device-low-performance .bracelet-circle .circle-bead {
  transition-duration: 120ms;
}

.device-low-performance .material-card,
.device-low-performance .energy-board {
  box-shadow: none;
}

.design-status {
  display: none;
  position: absolute;
  top: 530rpx;
  right: 96rpx;
  left: 96rpx;
  z-index: 5;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0;
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(122, 78, 58, 0.08);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(36, 29, 24, 0.08);
  backdrop-filter: blur(18rpx);
}

.status-cell {
  display: grid;
  grid-template-columns: 38rpx 1fr;
  gap: 8rpx;
  align-items: center;
  min-width: 0;
  padding: 0 4rpx;
}

.status-cell:nth-child(n + 4) {
  display: none;
}

.status-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  color: #7f8977;
  background: #f7f1ea;
  font-size: 18rpx;
  font-weight: 800;
}

.design-status text {
  color: #9a9189;
  font-size: 18rpx;
}

.status-cell > view:last-child view {
  margin-top: 2rpx;
  color: #34302d;
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

.material-drawer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 7;
  height: calc(592rpx + env(safe-area-inset-bottom));
  overflow: hidden;
  border-radius: 32rpx 32rpx 0 0;
  background: #fff;
  box-shadow: 0 -18rpx 38rpx rgba(0, 0, 0, 0.06);
}

.top-tabs {
  display: grid;
  grid-template-columns: 132rpx 132rpx 132rpx 1fr 1fr;
  align-items: center;
  height: 82rpx;
  border-bottom: 1rpx solid #f1f1f1;
}

.top-tab {
  position: relative;
  height: 82rpx;
  color: #a0a6aa;
  text-align: center;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 82rpx;
}

.top-tab.active {
  color: #7f8977;
  font-weight: 900;
}

.top-tab.active::after {
  position: absolute;
  right: 46rpx;
  bottom: 8rpx;
  left: 46rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #7f8977;
  content: "";
}

.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  margin: 0 auto;
  border: 1rpx solid #e1e3dc;
  border-radius: 999rpx;
  color: #333;
  background: #f4f4ef;
  font-size: 30rpx;
}

.drawer-body {
  display: flex;
  height: 360rpx;
}

.category-rail {
  flex: 0 0 150rpx;
  height: 360rpx;
  background: #f7f7f7;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  margin: 8rpx 12rpx;
  border-radius: 999rpx;
