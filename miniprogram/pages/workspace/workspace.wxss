page {
  min-height: 100%;
  background: #ffffff;
  color: #151515;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

.studio-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #ffffff;
  --workspace-canvas-height: 780rpx;
  --workspace-top-chrome: 122rpx;
  --workspace-stage-top: 92rpx;
  --workspace-stage-size: 560rpx;
  --workspace-drawer-height: 592rpx;
  --workspace-color-top: 88rpx;
  --workspace-left-rail-top: 210rpx;
  --workspace-right-rail-top: 270rpx;
  --workspace-rail-side: 14rpx;
  --workspace-rail-width: 90rpx;
  --workspace-rail-gap: 18rpx;
  --workspace-left-rail-height: 390rpx;
  --workspace-right-rail-height: 392rpx;
  --workspace-tool-item-height: 100rpx;
  --workspace-theme-left: 28rpx;
  --workspace-theme-top: 742rpx;
  --workspace-theme-width: 164rpx;
  --workspace-theme-height: 62rpx;
  --workspace-plate-tool-width: 62rpx;
  --workspace-plate-tool-height: 62rpx;
  --workspace-wrist-guide-left: 36rpx;
  --workspace-wrist-guide-top: 190rpx;
  --workspace-wrist-guide-width: 62rpx;
  --workspace-wrist-guide-height: 62rpx;
  --workspace-share-tool-left: 150rpx;
  --workspace-share-tool-top: 190rpx;
  --workspace-share-tool-size: 62rpx;
  --workspace-undo-button-size: 62rpx;
  --workspace-wrist-button-width: 164rpx;
  --workspace-wrist-button-height: 62rpx;
  --workspace-left-tool-left: 28rpx;
  --workspace-wrist-tool-left: 28rpx;
  --workspace-left-one-top: 560rpx;
  --workspace-left-two-top: 660rpx;
  --workspace-right-tool-left: 634rpx;
  --workspace-right-one-top: 540rpx;
  --workspace-right-two-top: 640rpx;
  --workspace-right-three-top: 740rpx;
  --workspace-random-left: 281rpx;
  --workspace-random-top: 820rpx;
  --workspace-random-width: 188rpx;
  --workspace-random-height: 64rpx;
  --workspace-tool-bottom: 608rpx;
  --workspace-tool-height: 82rpx;
  --workspace-tool-gap: 42rpx;
  --workspace-stage-tool-gap: 36rpx;
  --workspace-safe-bottom: 0rpx;
}

.studio-top {
  position: relative;
  z-index: 80;
  height: 122rpx;
  padding: 56rpx 28rpx 0;
  box-sizing: border-box;
}

.title-row {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 70rpx;
}

.back-btn {
  position: absolute;
  top: 18rpx;
  left: -20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: transparent;
  box-shadow: none;
  z-index: 120;
}

.back-btn::before {
  content: "";
  position: relative;
  z-index: 1;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #161616;
  border-bottom: 4rpx solid #161616;
  transform: rotate(45deg) translateX(3rpx);
}

.back-btn::after {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 32rpx rgba(39, 34, 24, 0.12);
  transition: transform 120ms ease, background 120ms ease;
}

.back-btn-press::after {
  background: rgba(245, 243, 238, 0.96);
  transform: scale(0.94);
}

.more-btn {
  position: absolute;
  top: 18rpx;
  right: -8rpx;
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}

.more-btn::before {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  width: 60rpx;
  height: 60rpx;
  border: 1rpx solid rgba(24, 24, 24, 0.06);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 30rpx rgba(39, 34, 24, 0.10);
  transition: transform 120ms ease, background 120ms ease;
}

.more-btn-press::before {
  background: rgba(245, 243, 238, 0.96);
  transform: scale(0.94);
}

.more-dot {
  position: relative;
  z-index: 1;
  width: 6rpx;
  height: 6rpx;
  margin: 0 3rpx;
  border-radius: 50%;
  background: #181818;
}

.canvas-area {
  position: relative;
  z-index: 10;
  height: var(--workspace-canvas-height);
  overflow: visible;
  background: #ffffff;
}

.studio-metrics,
.tray-theme-switch {
  position: absolute;
  z-index: 45;
  box-sizing: border-box;
}

.studio-metrics {
  top: 0;
  left: 104rpx;
  right: 148rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 78rpx;
  padding: 3rpx 0 0;
  background: transparent;
  box-shadow: none;
}

.studio-metrics.over .studio-metric-value {
  color: #b44940;
}

.studio-metric {
  position: relative;
  flex: 1;
  min-width: 0;
  text-align: center;
}

.studio-metric + .studio-metric::before {
  content: "";
  position: absolute;
  left: 0;
  top: 17rpx;
  width: 1rpx;
  height: 42rpx;
  background: rgba(28, 28, 28, 0.09);
}

.studio-metric-label {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 20rpx;
  font-weight: 560;
  line-height: 1.2;
  color: rgba(24, 24, 24, 0.42);
}

.studio-metric-value {
  margin-top: 9rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 31rpx;
  font-weight: 850;
  line-height: 1.05;
  color: #121212;
}

.studio-metric-sub {
  margin-left: 4rpx;
  font-size: 21rpx;
  font-weight: 760;
}

.tray-theme-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  top: var(--workspace-theme-top);
  left: var(--workspace-theme-left);
  width: var(--workspace-theme-width);
  height: var(--workspace-theme-height);
  min-height: var(--workspace-theme-height);
  padding: 10rpx 12rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(24, 24, 24, 0.06);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 14rpx 32rpx rgba(42, 36, 26, 0.10);
  backdrop-filter: blur(18rpx);
}

.tray-theme-label {
  margin-bottom: 0;
  text-align: left;
  font-size: 19rpx;
  font-weight: 680;
  line-height: 1;
  color: rgba(24, 24, 24, 0.62);
}

.tray-theme-current {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-left: 8rpx;
  border: 2rpx solid #c79b54;
  border-radius: 50%;
}

.tray-theme-press {
  transform: scale(0.96);
}

.tray-theme-dots {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  min-height: 34rpx;
  padding: 0;
  box-sizing: border-box;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  backdrop-filter: none;
}

.tray-theme-option {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  border: 2rpx solid transparent;
}

.tray-theme-option.active {
  border-color: #c79b54;
}

.tray-theme-dot {
  width: 25rpx;
  height: 25rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(0, 0, 0, 0.07);
  box-shadow: inset 0 1rpx 4rpx rgba(0, 0, 0, 0.10);
}

.tray-theme-dot.warm {
  background: #efe7d8;
}

.tray-theme-dot.white {
  background: #fff;
}

.tray-theme-dot.black {
  background: #252525;
}

.bracelet-stage {
  position: absolute;
  left: 50%;
  top: var(--workspace-stage-top);
  width: var(--workspace-stage-size);
  height: var(--workspace-stage-size);
  transform: translateX(-50%);
  z-index: 20;
}

.bracelet-circle {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: visible;
  background: transparent;
  box-shadow: none;
}

.bracelet-tray-image {
  position: absolute;
  left: -13%;
  right: auto;
  top: -13%;
  bottom: auto;
  z-index: 1;
  width: 126%;
  height: 126%;
  border-radius: 0;
  opacity: 0.98;
  filter: none;
  background: transparent;
}

.tray-image-failed .bracelet-tray-image {
  display: none;
}

.tray-theme-white .bracelet-tray-image {
  opacity: 0.98;
  filter: none;
}

.tray-theme-white {
  background: transparent;
  box-shadow: none;
}

.tray-theme-black .bracelet-tray-image {
  opacity: 0.98;
  filter: none;
}

.tray-theme-black {
  background: transparent;
  box-shadow: none;
}

.wrist-guide-entry {
  position: absolute;
  left: var(--workspace-wrist-guide-left);
  top: var(--workspace-wrist-guide-top);
  z-index: 76;
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--workspace-wrist-guide-width);
  height: var(--workspace-wrist-guide-height);
  min-height: var(--workspace-wrist-guide-height);
  box-sizing: border-box;
  border: 1rpx solid rgba(166, 124, 65, 0.18);
  border-radius: 50%;
  background: rgba(255, 252, 246, 0.92);
  box-shadow: 0 12rpx 28rpx rgba(72, 54, 30, 0.10);
  backdrop-filter: blur(18rpx);
  color: #7c5a2b;
}

.wrist-guide-entry-press {
  transform: scale(0.95);
}

.wrist-guide-entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.plate-tool {
  position: absolute;
  z-index: 74;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: var(--workspace-plate-tool-width);
  height: var(--workspace-plate-tool-height);
  box-sizing: border-box;
  border: 1rpx solid rgba(24, 24, 24, 0.08);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.90);
  box-shadow: 0 14rpx 30rpx rgba(42, 36, 26, 0.10);
  backdrop-filter: blur(18rpx);
  color: #181818;
}

.plate-tool-left-one {
  left: var(--workspace-left-tool-left);
  top: var(--workspace-left-one-top);
  width: var(--workspace-undo-button-size);
  height: var(--workspace-undo-button-size);
  border-radius: 17rpx;
}

.plate-tool-left-two {
  left: var(--workspace-wrist-tool-left);
  top: var(--workspace-left-two-top);
  flex-direction: row;
  width: var(--workspace-wrist-button-width);
  height: var(--workspace-wrist-button-height);
  padding: 0 14rpx;
  border-radius: 18rpx;
}

.plate-tool-share {
  left: var(--workspace-share-tool-left);
  top: var(--workspace-share-tool-top);
  width: var(--workspace-share-tool-size);
  height: var(--workspace-share-tool-size);
  border-radius: 17rpx;
}

.plate-tool-right-one {
  left: var(--workspace-right-tool-left);
  top: var(--workspace-right-one-top);
}

.plate-tool-right-two {
  left: var(--workspace-right-tool-left);
  top: var(--workspace-right-two-top);
}

.plate-tool-right-three {
  left: var(--workspace-right-tool-left);
  top: var(--workspace-right-three-top);
}

.plate-tool.disabled {
  opacity: 0.34;
}

.plate-tool.active {
  border-color: rgba(31, 106, 86, 0.20);
  color: #1f6a56;
}

.plate-tool.danger {
  color: #b44940;
}

.plate-tool-press,
.plate-random-press {
  transform: scale(0.94);
}

.plate-tool-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 31rpx;
  margin-bottom: 5rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.plate-tool-left-one .plate-tool-icon {
  height: auto;
  margin-bottom: 0;
  font-size: 32rpx;
}

.plate-tool-share .plate-tool-icon {
  height: auto;
  margin-bottom: 0;
  font-size: 31rpx;
}

.plate-tool-left-two .plate-tool-icon {
  flex: 0 0 auto;
  width: 28rpx;
  height: auto;
  margin-right: 8rpx;
  margin-bottom: 0;
  font-size: 26rpx;
}

.plate-tool-right-one .plate-tool-icon,
.plate-tool-right-two .plate-tool-icon,
.plate-tool-right-three .plate-tool-icon {
  height: auto;
  margin-bottom: 0;
  font-size: 32rpx;
}

.plate-icon-undo::before {
  content: "\21B6";
}

.plate-icon-wrist::before {
  content: "\25EF";
}

.plate-icon-share::before {
  content: "\2197";
}

.plate-icon-save::before {
  content: "\2606";
}

.plate-icon-energy::before {
  content: "\272A";
}

.plate-icon-clear::before {
  content: "\1F5D1";
}

.plate-tool-label {
  max-width: calc(var(--workspace-plate-tool-width) - 12rpx);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 21rpx;
  font-weight: 680;
  line-height: 1.05;
}

.plate-tool-left-two .plate-tool-label {
  max-width: none;
  overflow: visible;
  text-overflow: clip;
  font-size: 20rpx;
  line-height: 1;
}

.plate-random-btn {
  position: absolute;
  left: var(--workspace-random-left);
  top: var(--workspace-random-top);
  z-index: 74;
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--workspace-random-width);
  height: var(--workspace-random-height);
  box-sizing: border-box;
  border: 1rpx solid rgba(24, 24, 24, 0.08);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 30rpx rgba(42, 36, 26, 0.11);
  backdrop-filter: blur(18rpx);
  color: #1b1a18;
}

.plate-random-btn.working {
  opacity: 0.68;
  color: #9a7538;
}

.plate-random-icon::before {
  content: "\2682";
  display: block;
  margin-right: 12rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.plate-random-text {
  font-size: 25rpx;
  font-weight: 760;
  line-height: 1;
}

.bracelet-string,
.bracelet-canvas,
.bracelet-touch-layer,
.workspace-flight-canvas {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 8;
  width: 100%;
  height: 100%;
}

.bracelet-touch-layer {
  z-index: 14;
}

.workspace-flight-canvas {
  position: fixed;
  z-index: 12;
  pointer-events: none;
  opacity: 0;
}

.workspace-flight-canvas.active {
  z-index: 110;
  opacity: 1;
}

.completion-watermark {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translate(-50%, -50%);
  color: rgba(42, 38, 30, 0.18);
  pointer-events: none;
}

.studio-compass {
  font-size: 30rpx;
}

.completion-sub::after {
  content: "轻触珠子调整位置";
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(42, 38, 30, 0.14);
  white-space: nowrap;
}

.circle-bead {
  position: absolute;
  z-index: 12;
  overflow: visible;
  border-radius: 50%;
  transform-origin: center center;
}

.circle-bead-image,
.bead-glow {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.circle-bead.selected .circle-bead-image,
.circle-bead.selected .bead-glow {
  box-shadow: 0 0 0 4rpx rgba(196, 151, 78, 0.88), 0 12rpx 28rpx rgba(52, 40, 24, 0.18);
}

.circle-bead.dragging {
  z-index: 35;
}

.bead-glow {
  background: radial-gradient(circle at 32% 26%, rgba(255, 255, 255, 0.92) 0 12%, #d8d3c2 16% 58%, rgba(0, 0, 0, 0.24) 100%);
}

.tool-rail {
  position: absolute;
  z-index: 70;
  display: flex;
  flex-direction: column;
  width: var(--workspace-rail-width);
  gap: var(--workspace-rail-gap);
  pointer-events: none;
}

.tool-rail-left {
  left: var(--workspace-rail-side);
  top: var(--workspace-left-rail-top);
  height: var(--workspace-left-rail-height);
  justify-content: space-between;
  gap: 0;
}

.tool-rail-right {
  right: var(--workspace-rail-side);
  top: var(--workspace-right-rail-top);
  height: var(--workspace-right-rail-height);
  justify-content: space-between;
  gap: 0;
}

.tool-item {
  position: relative;
  flex: 0 0 auto;
  min-width: 0;
  min-height: var(--workspace-tool-item-height);
  height: var(--workspace-tool-item-height);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid rgba(24, 24, 24, 0.07);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 10rpx 26rpx rgba(42, 36, 26, 0.09);
  backdrop-filter: blur(18rpx);
  color: #1e1e1e;
  pointer-events: auto;
}

.tool-item::after {
  display: none;
}

.tool-item.disabled {
  opacity: 0.32;
}

.tool-item.working {
  color: #9a7538;
}

.tool-item.active {
  color: #1f6a56;
}

.tool-item.danger {
  color: #b44940;
}

.tool-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 34rpx;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
}

.tool-undo::before {
  content: "\21B6";
}

.tool-wrist::before {
  content: "\25CE";
}

.tool-string::before {
  content: "\25CC";
}

.tool-release::before {
  content: "\2301";
}

.tool-energy::before {
  content: "\2630";
}

.tool-save::before {
  content: "\25A3";
}

.tool-share::before {
  content: "\2197";
}

.tool-clear::before {
  content: "\00D7";
}

.tool-label {
  max-width: var(--workspace-rail-width);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  font-size: 21rpx;
  font-weight: 780;
  line-height: 1.1;
}

.tool-item.active {
  border-color: rgba(31, 106, 86, 0.22);
  background: rgba(239, 246, 241, 0.92);
}

.tool-item.danger {
  border-color: rgba(180, 73, 64, 0.16);
}

.plate-action-bar {
  position: absolute;
  top: var(--workspace-plate-action-top);
  left: calc(var(--workspace-rail-side) + var(--workspace-rail-width) + 12rpx);
  right: calc(var(--workspace-rail-side) + var(--workspace-rail-width) + 12rpx);
  z-index: 72;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: var(--workspace-plate-action-height);
  pointer-events: none;
}

.plate-action-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--workspace-plate-action-width);
  height: var(--workspace-plate-action-height);
  box-sizing: border-box;
  border: 1rpx solid rgba(24, 24, 24, 0.07);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.90);
  box-shadow: 0 10rpx 24rpx rgba(42, 36, 26, 0.08);
  backdrop-filter: blur(18rpx);
  color: rgba(26, 26, 26, 0.78);
  pointer-events: auto;
}

.plate-action-item.primary {
  border-color: rgba(168, 126, 54, 0.18);
  background: rgba(255, 253, 247, 0.94);
  color: #8b6424;
}

.plate-action-item.working {
  color: #9a7538;
  opacity: 0.72;
}

.plate-action-divider {
  display: none;
}

.plate-action-text {
  max-width: 128rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 21rpx;
  font-weight: 760;
  line-height: 1.1;
}

.flight-bead {
  position: fixed;
  z-index: 120;
  pointer-events: none;
}

.flight-bead-image,
.flight-bead-fallback {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.energy-floating-card,
.order-panel {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  z-index: 65;
  box-sizing: border-box;
