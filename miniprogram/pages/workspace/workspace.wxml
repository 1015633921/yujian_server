<view class="studio-page {{deviceClass}}" style="{{workspaceLayoutStyle}}">
  <view class="studio-top">
    <view class="title-row">
      <view class="back-btn" catchtap="goBack" hover-class="back-btn-press" aria-role="button" aria-label="返回"></view>
      <view class="more-btn" catchtap="openToolbox" hover-class="more-btn-press" aria-role="button" aria-label="更多操作">
        <view class="more-dot"></view>
        <view class="more-dot"></view>
        <view class="more-dot"></view>
      </view>
    </view>
  </view>

  <view class="canvas-area">
    <view class="studio-metrics {{countOverClass}}" bindtap="openWristSetting">
      <view class="studio-metric">
        <view class="studio-metric-label">手串颗数</view>
        <view class="studio-metric-value">{{summary.count}}<text class="studio-metric-sub">/18 颗</text></view>
      </view>
      <view class="studio-metric">
        <view class="studio-metric-label">适合腕围</view>
        <view class="studio-metric-value">{{wristSize}}<text class="studio-metric-sub"> cm</text></view>
      </view>
      <view class="studio-metric">
        <view class="studio-metric-label">当前串长</view>
        <view class="studio-metric-value">{{summary.length}}<text class="studio-metric-sub"> cm</text></view>
      </view>
    </view>

    <view class="tray-theme-switch" bindtap="cycleTrayTheme" hover-class="tray-theme-press" aria-role="button" aria-label="切换托盘颜色">
      <view class="tray-theme-label">托盘颜色</view>
      <view class="tray-theme-current">
        <view class="tray-theme-dot {{trayTheme}}"></view>
      </view>
    </view>

    <view class="wrist-guide-entry" catchtap="openWristGuideModal" data-tab="workspace" hover-class="wrist-guide-entry-press" aria-role="button" aria-label="手围与工作台指南">
      <view class="wrist-guide-entry-icon">?</view>
    </view>

    <view class="bracelet-stage">
      <view class="bracelet-circle tray-theme-{{trayTheme}} {{trayImageFailed ? 'tray-image-failed' : ''}} {{isShuffling ? 'shuffling' : ''}}">
        <image
          class="bracelet-tray-image"
          src="{{trayImageUrl}}"
          mode="aspectFill"
          binderror="onTrayImageError"
        ></image>
        <view class="bracelet-string {{braceletStringClass}}" style="{{stringStyle}}"></view>
        <canvas
          wx:if="{{useCanvasRenderer && workspaceCanvasVisible}}"
          id="braceletCanvas"
          class="bracelet-canvas"
          type="2d"
          canvas-id="braceletCanvas"
          catchtouchstart="onBraceletCanvasTouchStart"
          catchtouchmove="onBraceletCanvasTouchMove"
          catchtouchend="onBraceletCanvasTouchEnd"
          catchtouchcancel="onBraceletCanvasTouchEnd"
        ></canvas>
        <view
          wx:if="{{useCanvasRenderer && workspaceCanvasVisible}}"
          class="bracelet-touch-layer"
          catchtouchstart="onBraceletCanvasTouchStart"
          catchtouchmove="onBraceletCanvasTouchMove"
          catchtouchend="onBraceletCanvasTouchEnd"
          catchtouchcancel="onBraceletCanvasTouchEnd"
        ></view>
        <view class="completion-watermark {{completionWatermarkClass}}">
          <view class="studio-compass">✦</view>
          <view class="completion-sub"></view>
        </view>
        <view
          wx:if="{{!useCanvasRenderer}}"
          wx:for="{{selectedItems}}"
          wx:key="index"
          class="circle-bead {{item.className}}"
          style="{{item.style}}"
          data-index="{{index}}"
          bindtap="selectBead"
          bindlongpress="removeItem"
          catchtouchstart="onBeadTouchStart"
          catchtouchmove="onBeadTouchMove"
          catchtouchend="onBeadTouchEnd"
          catchtouchcancel="onBeadTouchEnd"
        >
          <image wx:if="{{item.image_url}}" class="circle-bead-image" src="{{item.image_url}}" mode="aspectFit" data-id="{{item.id}}" binderror="onMaterialImageError"></image>
          <view wx:else class="bead-glow"></view>
        </view>
      </view>
    </view>

    <view class="plate-tool plate-tool-left-one {{canUndo ? '' : 'disabled'}}" catchtap="undo" hover-class="plate-tool-press" aria-role="button" aria-label="撤回">
      <view class="plate-tool-icon plate-icon-undo"></view>
    </view>
    <view class="plate-tool plate-tool-left-two" catchtap="openWristSetting" hover-class="plate-tool-press" aria-role="button" aria-label="调整腕围">
      <view class="plate-tool-icon plate-icon-wrist"></view>
      <view class="plate-tool-label">腕围{{wristSize}}cm</view>
    </view>
    <view class="plate-tool plate-tool-share {{sharingDesign ? 'disabled' : ''}}" catchtap="prepareShareDesign" hover-class="plate-tool-press" aria-role="button" aria-label="分享方案">
      <view class="plate-tool-icon plate-icon-share"></view>
    </view>

    <view class="plate-tool plate-tool-right-one" catchtap="saveDraft" hover-class="plate-tool-press" aria-role="button" aria-label="保存方案">
      <view class="plate-tool-icon plate-icon-save"></view>
    </view>
    <view class="plate-tool plate-tool-right-two {{showEnergyPanel ? 'active' : ''}}" catchtap="toggleEnergyPanel" hover-class="plate-tool-press" aria-role="button" aria-label="五行图">
      <view class="plate-tool-icon plate-icon-energy"></view>
    </view>
    <view class="plate-tool plate-tool-right-three danger" catchtap="confirmClearDesign" hover-class="plate-tool-press" aria-role="button" aria-label="清空">
      <view class="plate-tool-icon plate-icon-clear"></view>
    </view>

    <view class="plate-random-btn {{shuffleButtonClass}}" catchtap="toggleStringMode" hover-class="plate-random-press" aria-role="button" aria-label="随机成串">
      <view class="plate-random-icon"></view>
      <view class="plate-random-text">{{randomTitle}}</view>
    </view>

    <view wx:if="{{showEnergyPanel}}" class="energy-floating-card">
      <view class="energy-floating-head" bindtap="openEnergyModal">
        <view>
          <text class="energy-floating-title">五行占比</text>
          <text class="energy-floating-sub">当前方案</text>
        </view>
        <view class="energy-floating-action">详情</view>
      </view>
      <view class="energy-mini-bars">
        <view wx:for="{{summary.energy}}" wx:key="key" class="energy-mini-row">
          <text class="energy-mini-name">{{item.name}}</text>
          <view class="energy-mini-track">
            <view class="energy-mini-fill" style="width:{{item.value}}%;background:{{item.color}};"></view>
          </view>
          <text class="energy-mini-value">{{item.value}}%</text>
        </view>
      </view>
    </view>

    <view wx:if="{{selectedBeadInfo}}" class="order-panel bead-info-panel">
      <view class="bead-info-copy">
        <view class="order-title">第 {{selectedBeadInfo.position}} 颗</view>
        <view class="bead-info-name"><text class="bead-info-label">品名</text>{{selectedBeadInfo.name}}</view>
        <view class="bead-info-meta"><text class="bead-info-label">珠径</text>{{selectedBeadInfo.diameterText}}</view>
      </view>
      <view class="order-actions">
        <button class="danger" data-index="{{selectedBeadInfo.index}}" bindtap="removeItem">删除</button>
      </view>
    </view>
  </view>

  <canvas
    wx:if="{{useCanvasRenderer && workspaceCanvasVisible}}"
    id="workspaceFlightCanvas"
    class="workspace-flight-canvas {{canvasFlightActive ? 'active' : ''}}"
    type="2d"
    canvas-id="workspaceFlightCanvas"
  ></canvas>

  <view wx:if="{{flightBead && !useCanvasRenderer && workspaceCanvasVisible}}" class="flight-bead" style="{{flightBead.style}}" animation="{{flightBead.animation}}">
    <image wx:if="{{flightBead.image_url}}" class="flight-bead-image" src="{{flightBead.image_url}}" mode="aspectFit"></image>
    <view wx:else class="flight-bead-fallback" style="background: radial-gradient(circle at 32% 26%, {{flightBead.shine}} 0 10%, {{flightBead.color}} 12% 58%, rgba(0,0,0,.22) 100%);"></view>
  </view>

  <view class="material-drawer">
    <view class="top-tabs">
      <view wx:for="{{topTabs}}" wx:for-index="tabIndex" wx:key="key" class="top-tab {{item.className}} {{tabIndex === topTabs.length - 1 ? 'last' : ''}}" data-top="{{item.value}}" bindtap="selectTop">{{item.label}}</view>
      <view class="drawer-checkout">
        <view class="drawer-price-block">
          <text>当前方案</text>
          <view>¥{{summary.priceText}}</view>
        </view>
      </view>
    </view>

    <view class="drawer-body">
      <scroll-view class="category-rail" scroll-y scroll-into-view="{{activeCategoryAnchor}}" scroll-with-animation="{{true}}">
        <view wx:for="{{categories}}" wx:key="value" id="{{item.anchorId}}" class="category-item {{item.className}}" data-category="{{item.value}}" bindtap="selectCategory">{{item.label}}</view>
        <view wx:if="{{categoryRailSeries.length}}" class="category-series-panel">
          <view class="category-series-title">品种</view>
          <view
            wx:for="{{categoryRailSeries}}"
            wx:key="value"
            id="{{item.anchorId}}"
            class="category-series-item {{item.className}}"
            data-series="{{item.value}}"
            bindtap="selectSeries"
          >{{item.label}}</view>
        </view>
      </scroll-view>

      <view class="material-content">
        <view class="material-search-row">
          <view class="material-search-box">
            <view class="material-search-icon"></view>
            <input
              class="material-search-input"
              value="{{materialSearchKeyword}}"
              placeholder="搜索珠子名称 / 品种"
              placeholder-class="material-search-placeholder"
              confirm-type="search"
              bindinput="onMaterialSearchInput"
              bindconfirm="submitMaterialSearch"
            />
            <view wx:if="{{materialSearchKeyword}}" class="material-search-clear" catchtap="clearMaterialSearch">×</view>
          </view>
          <view class="material-search-cart" catchtap="addDesignToCart" aria-role="button" aria-label="加入购物车">加入购物车</view>
        </view>
        <view wx:if="{{showWorkspaceGuide}}" class="workspace-guide-card">
          <view class="workspace-guide-head">
            <view>
              <view class="workspace-guide-kicker">FIRST DIY</view>
              <view class="workspace-guide-title">三步开始排一串</view>
            </view>
            <view class="workspace-guide-close" catchtap="dismissWorkspaceGuide" data-forever="true">×</view>
          </view>
          <view class="workspace-guide-list">
            <view wx:for="{{workspaceGuideItems}}" wx:key="index" class="workspace-guide-item">
              <view class="workspace-guide-index">{{item.index}}</view>
              <view>
                <view class="workspace-guide-item-title">{{item.title}}</view>
                <view class="workspace-guide-desc">{{item.desc}}</view>
              </view>
            </view>
          </view>
          <view class="workspace-guide-actions">
            <button class="workspace-guide-primary" catchtap="dismissWorkspaceGuide" data-forever="true">开始试试</button>
            <view class="workspace-guide-secondary" catchtap="dismissWorkspaceGuide" data-forever="true">不再提示</view>
          </view>
        </view>
        <scroll-view wx:if="{{seriesOptions.length > 1}}" class="series-scroll" scroll-x enhanced="{{true}}" bounces="{{true}}" show-scrollbar="{{false}}" scroll-into-view="{{activeSeriesAnchor}}" scroll-with-animation="{{true}}">
          <view class="series-tabs">
            <view wx:for="{{seriesOptions}}" wx:key="value" id="{{item.anchorId}}" class="series-tab {{item.className}}" data-series="{{item.value}}" bindtap="selectSeries">{{item.label}}</view>
          </view>
        </scroll-view>
        <view wx:if="{{materialsLoading}}" class="material-load-state">正在同步最新珠材，图片加载时会先显示柔光占位</view>
        <view wx:if="{{materialsErrorText}}" class="material-load-state material-load-warning">{{materialsErrorText}}</view>

        <scroll-view class="material-scroll" scroll-y enhanced="{{true}}" bounces="{{true}}" show-scrollbar="{{false}}" bindscrolltolower="loadMoreMaterials">
          <view wx:if="{{visibleMaterials.length}}" class="material-grid">
            <view
              wx:for="{{visibleMaterials}}"
              wx:for-index="index"
              wx:key="id"
              class="material-card {{item.cardClass}}"
              data-id="{{item.id}}"
              data-index="{{index}}"
              bindtap="addMaterial"
            >
              <image wx:if="{{item.image_url}}" class="material-sphere material-image" src="{{item.image_url}}" mode="aspectFit" lazy-load="{{true}}" webp="{{true}}" fade-in="{{false}}" data-id="{{item.id}}" binderror="onMaterialImageError"></image>
              <view wx:else class="material-sphere" style="background: radial-gradient(circle at 32% 26%, {{item.shine}} 0 10%, {{item.color}} 12% 58%, rgba(0,0,0,.22) 100%);"></view>
              <view class="material-name">{{item.name}}</view>
              <view class="material-effect">{{item.effectText}}</view>
              <view class="material-meta">
                <view class="material-price">¥{{item.price}}</view>
                <view class="size-pill">{{item.size}}mm</view>
              </view>
            </view>
          </view>
          <view wx:elif="{{materialsLoading}}" class="material-grid material-skeleton-grid">
            <view wx:for="{{materialSkeletons}}" wx:key="*this" class="material-card material-skeleton-card">
              <view class="material-sphere material-skeleton-sphere"></view>
              <view class="material-skeleton-line strong"></view>
              <view class="material-skeleton-line"></view>
              <view class="material-skeleton-meta">
                <view></view>
                <view></view>
              </view>
            </view>
          </view>
          <view wx:else class="material-empty-state">
            <text wx:if="{{materialsErrorText}}">{{materialsErrorText}}</text>
            <text wx:elif="{{materialSearchKeyword}}">没有匹配的珠子</text>
            <text wx:else>暂无可用珠材</text>
          </view>
          <view wx:if="{{materialsLoadingMore}}" class="load-more-hint">正在加载更多材料...</view>
          <view wx:elif="{{hasMoreMaterials}}" class="load-more-hint">上滑加载更多材料</view>
        </scroll-view>
      </view>
    </view>

  </view>

  <view wx:if="{{showWristPicker}}" class="wrist-picker-mask" bindtap="closeWristSetting">
    <view class="wrist-picker" catchtap="stopPropagation">
      <view class="wrist-picker-head">
        <view>
          <view class="wrist-picker-title">选择手围</view>
          <view class="wrist-picker-subtitle">设置腕围，系统会同步更新当前方案适配参考。</view>
        </view>
        <view class="wrist-picker-close" bindtap="closeWristSetting">×</view>
      </view>
      <view class="wrist-ruler-value">
        <text class="wrist-ruler-number">{{wristRulerValue}}</text>
        <text class="wrist-ruler-unit">cm</text>
      </view>
      <view class="wrist-ruler-caption">左右滑动软尺，松手后自动吸附到 0.1cm</view>
      <view class="wrist-ruler-wrap">
        <view class="wrist-ruler-pointer"></view>
        <view class="wrist-ruler-fade left"></view>
        <view class="wrist-ruler-fade right"></view>
        <scroll-view
          class="wrist-ruler-scroll"
          scroll-x
          enhanced="{{true}}"
          bounces="{{true}}"
          show-scrollbar="{{false}}"
          scroll-left="{{wristRulerScrollLeft}}"
          bindtouchstart="onWristRulerTouchStart"
          bindtouchend="onWristRulerTouchEnd"
          bindtouchcancel="onWristRulerTouchEnd"
          bindscroll="onWristRulerScroll"
        >
          <view class="wrist-ruler-track" style="padding-left:{{wristRulerSidePadding}}px;padding-right:{{wristRulerSidePadding}}px;">
            <view
              wx:for="{{wristRulerTicks}}"
              wx:key="index"
              class="wrist-ruler-tick {{item.className}}"
              style="width:{{wristRulerTickWidth}}px;"
            >
              <view class="tick-line"></view>
              <view wx:if="{{item.label}}" class="tick-label">{{item.label}}</view>
            </view>
          </view>
        </scroll-view>
      </view>
      <view class="wrist-ruler-range">{{wristRulerRangeText}}</view>
      <button class="wrist-ruler-confirm" catchtap="confirmWristRuler">确认手围</button>
    </view>
  </view>

  <view wx:if="{{showWristGuideModal}}" class="wrist-guide-mask" bindtap="closeWristGuideModal">
    <view class="wrist-guide-sheet" catchtap="stopPropagation">
      <view class="wrist-guide-head">
        <view>
          <view class="wrist-guide-title">手围与工作台指南</view>
          <view class="wrist-guide-subtitle">先熟悉工作台按钮，再按需要查看手围测量。</view>
        </view>
        <view class="wrist-guide-close" bindtap="closeWristGuideModal">×</view>
      </view>
      <view class="wrist-guide-tabs">
        <view
          wx:for="{{wristGuideTabs}}"
          wx:key="key"
          class="wrist-guide-tab {{activeWristGuideTab === item.key ? 'active' : ''}}"
          data-tab="{{item.key}}"
          bindtap="switchWristGuideTab"
        >{{item.label}}</view>
      </view>
      <scroll-view class="wrist-guide-body" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}">
        <image
          wx:if="{{activeWristGuideTab === 'measure'}}"
          class="wrist-guide-image"
          src="{{wristMeasureGuideImageUrl}}"
          mode="widthFix"
          binderror="onWristGuideImageError"
        ></image>
        <view wx:else class="workspace-help-list">
          <view wx:for="{{workspaceUsageGuide}}" wx:key="tag" class="workspace-help-item">
            <view class="workspace-help-tag">
              <view class="workspace-help-icon plate-tool-icon {{item.iconClass}}"></view>
              <view class="workspace-help-tag-text">{{item.tag}}</view>
            </view>
            <view class="workspace-help-copy">
              <view class="workspace-help-title">{{item.title}}</view>
              <view class="workspace-help-desc">{{item.desc}}</view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showEnergyModal}}" class="energy-modal-mask" bindtap="closeEnergyModal">
    <view class="energy-modal" catchtap="stopPropagation">
      <view class="energy-modal-head">
        <view class="energy-modal-title">五行能量图</view>
        <view class="energy-modal-close" bindtap="closeEnergyModal">×</view>
      </view>
      <view class="energy-modal-body">
        <image class="energy-modal-svg" src="{{energyChartSvgUrl}}" mode="widthFix"></image>
      </view>
    </view>
  </view>

  <view wx:if="{{showShareSheet}}" class="share-sheet-mask" bindtap="closeShareSheet">
    <view class="share-sheet" catchtap="stopPropagation">
      <view class="share-sheet-head">
        <view>
          <view class="share-sheet-title">分享当前方案</view>
          <view class="share-sheet-subtitle">好友打开后直达 DIY 工作台查看这条方案。</view>
        </view>
        <view class="share-sheet-close" bindtap="closeShareSheet">×</view>
      </view>
      <view class="share-sheet-card">
        <image wx:if="{{sharePreviewImage}}" class="share-sheet-preview" src="{{sharePreviewImage}}" mode="aspectFill"></image>
        <view wx:else class="share-sheet-preview share-sheet-placeholder"></view>
        <view class="share-sheet-card-copy">
          <view class="share-sheet-card-title">{{shareDesignTitle}}</view>
          <view class="share-sheet-card-desc">{{summary.count}} 颗 · {{wristSize}}cm · ¥{{summary.priceText}}</view>
        </view>
      </view>
      <button class="share-sheet-primary" open-type="share">分享给好友</button>
      <button class="share-sheet-secondary" bindtap="closeShareSheet">继续编辑</button>
    </view>
  </view>
</view>
