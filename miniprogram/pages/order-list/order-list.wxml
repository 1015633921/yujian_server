<view class="page order-list-page">
  <view class="list-head">
    <view class="list-title">{{title}}</view>
    <view wx:if="{{showListCount}}" class="list-count">{{filteredOrders.length}} 个订单</view>
  </view>

  <view wx:if="{{loading}}" class="card state-card">正在加载订单...</view>

  <view wx:elif="{{filteredOrders.length}}" class="order-list">
    <view wx:for="{{filteredOrders}}" wx:key="id" class="card order-card" data-id="{{item.id}}" bindtap="goDetail">
      <view class="order-card-head">
        <view class="order-id-row">
          <text class="order-id-label">订单号：</text>
          <text class="order-id" selectable="{{true}}">{{item.id}}</text>
          <view class="order-copy-btn" data-id="{{item.id}}" catchtap="copyOrderId">复制</view>
        </view>
        <view class="order-status">{{item.status}}</view>
      </view>
      <view class="order-card-content">
        <view wx:if="{{item.previewImage || item.previewBeads.length}}" class="order-ring-preview">
          <image wx:if="{{item.previewImage}}" class="order-preview-image" src="{{item.previewImage}}" mode="aspectFill" data-id="{{item.id}}" binderror="onPreviewImageError"></image>
          <view class="order-ring-plate"></view>
          <view wx:if="{{!item.previewImage}}" class="order-ring-track"></view>
          <view wx:if="{{!item.previewImage}}" wx:for="{{item.previewBeads}}" wx:for-item="bead" wx:key="key" class="order-ring-bead" style="{{bead.style}}">
            <image wx:if="{{bead.image_url}}" src="{{bead.image_url}}" mode="aspectFill"></image>
          </view>
        </view>
        <view class="order-card-copy">
          <view class="order-time">{{item.createdAtText}}</view>
          <view class="order-body">
            <view class="order-desc">{{item.materialCount}} 件材料 · {{item.receiver.name || '未填写收货人'}}</view>
            <view class="order-price">¥{{item.totalAmount}}</view>
          </view>
          <view class="order-arrow">查看详情 ></view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="card empty-card">
    <view>暂无相关订单</view>
    <button class="mini-action" bindtap="goWorkspace">去 DIY</button>
  </view>
</view>
