<view class="page">
  <view class="profile-card card">
    <view wx:if="{{user && user.avatar_url}}" class="avatar avatar-image">
      <image src="{{user.avatar_url}}" mode="aspectFill"></image>
    </view>
    <view wx:else class="avatar default-avatar">
      <text class="avatar-star">✦</text>
      <text class="avatar-crystal">◇</text>
    </view>
    <view class="profile-info">
      <view class="profile-name">{{user.nickname || profile.name || '新朋友'}}</view>
      <view class="profile-title">{{isLoggedIn ? (profile.title || '温柔直觉型守护者') : '登录后同步你的专属能量档案'}}</view>
      <view wx:if="{{isLoggedIn && (!hasProfile || !hasPhone)}}" class="profile-nudge" bindtap="openProfileModal">您的能量档案还差一步解锁，立即完善资料 ></view>
    </view>
  </view>

  <view wx:if="{{!isLoggedIn}}" class="login-panel card">
    <view class="login-title">登录后开启个性化服务</view>
    <view class="login-desc">测算记录、每日能量、DIY 草稿和订单会归档到你的账号。</view>
    <button class="primary-button" loading="{{authLoading}}" bindtap="loginWithWechat">微信快捷登录</button>
  </view>

  <view class="asset-grid card">
    <view class="asset-item" bindtap="goAssessment">
      <text>能量档案</text>
      <view>查看 / 重测</view>
    </view>
    <view class="asset-item" bindtap="goWorkspace">
      <text>设计草稿</text>
      <view>{{draftCount}} 件材料</view>
    </view>
    <view class="asset-item" bindtap="goCoupons">
      <text>优惠券</text>
      <view>{{couponCount}} 张可用</view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">我的订单</view>
      <view class="section-link" bindtap="showAllOrders">全部订单 ></view>
    </view>
    <view class="card order-status-grid">
      <view wx:for="{{orderStats}}" wx:key="key" class="order-status-item" data-key="{{item.key}}" bindtap="handleOrderStatus">
        <view class="order-icon">{{item.icon}}</view>
        <view class="order-label">{{item.label}}</view>
        <view wx:if="{{item.count}}" class="order-badge">{{item.count}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">我的灵感</view>
      <view class="section-link" bindtap="goCommunity">去逛灵感</view>
    </view>
    <view class="inspiration-list">
      <view wx:for="{{inspirationStats}}" wx:key="key" class="inspiration-item card" data-type="{{item.key}}" bindtap="handleInspiration">
        <view class="inspiration-icon {{item.key}}">{{item.icon}}</view>
        <view class="inspiration-copy">
          <view class="inspiration-title">{{item.title}}</view>
          <view class="inspiration-desc">{{item.desc}}</view>
        </view>
        <view class="inspiration-count">{{item.count}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showProfileModal}}" class="modal-mask" catchtap="closeProfileModal">
    <view class="profile-modal" catchtap="noop">
      <view class="modal-header">
        <view>
          <view class="modal-title">完善个人资料</view>
          <view class="modal-desc">头像、昵称可以从微信选择，也可以手动补充。</view>
        </view>
        <button class="modal-close" bindtap="closeProfileModal">×</button>
      </view>

      <view class="form-row avatar-row">
        <view class="field-copy">
          <view class="field-label">头像</view>
          <view class="field-hint">调用微信头像选择</view>
        </view>
        <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{profileDraft.avatar_url}}" src="{{profileDraft.avatar_url}}" mode="aspectFill"></image>
          <text wx:else>{{avatarChar}}</text>
        </button>
      </view>

      <view class="form-field">
        <view class="field-header">
          <view class="field-label">昵称</view>
          <button class="field-action" bindtap="focusNicknameInput">选择微信昵称</button>
        </view>
        <input class="nickname-input" type="nickname" placeholder="填写昵称，或选择微信昵称" value="{{profileDraft.nickname}}" data-field="nickname" focus="{{nicknameFocus}}" bindinput="onProfileInput" bindblur="onNicknameBlur" />
        <view class="field-hint">点击输入框或右侧按钮后，在微信候选昵称中选择。</view>
      </view>

      <view class="form-field">
        <view class="field-label">手机号</view>
        <view wx:if="{{hasPhone}}" class="phone-value">{{user.phone_number}}</view>
        <button wx:else class="secondary-button phone-auth-button" loading="{{phoneLoading}}" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">授权当前微信手机号</button>
        <block wx:if="{{isLocalApi && !hasPhone}}">
          <view class="phone-manual-row">
            <input class="nickname-input phone-input" type="number" maxlength="11" placeholder="本地调试手机号" value="{{phoneDraft}}" bindinput="onPhoneInput" />
            <button class="secondary-button phone-save-button" loading="{{phoneLoading}}" bindtap="saveManualPhone">保存</button>
          </view>
          <view class="field-hint">本地调试可手动填写，正式版使用微信手机号授权。</view>
        </block>
      </view>

      <view class="modal-actions">
        <button class="secondary-button" bindtap="closeProfileModal">稍后再说</button>
        <button class="primary-button" loading="{{savingProfile}}" bindtap="saveBasicProfile">保存头像昵称</button>
      </view>
    </view>
  </view>
</view>
