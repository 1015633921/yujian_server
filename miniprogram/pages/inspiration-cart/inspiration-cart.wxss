page {
  background: var(--yu-color-bg-page);
}

.cart-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.cart-nav {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.nav-title {
  color: var(--yu-color-anchor-dark);
  font-size: 36rpx;
  font-weight: 900;
}

.nav-subtitle {
  margin-top: 8rpx;
  color: var(--yu-color-text-secondary);
  font-size: 22rpx;
}

.manage-button {
  height: 56rpx;
  min-height: 56rpx;
  margin: 0;
  padding: 0 24rpx;
  border: 0;
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-anchor-dark);
  background: rgba(255, 255, 255, .78);
  box-shadow: var(--yu-shadow-press);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.manage-button::after,
.item-action::after,
.empty-primary::after,
.empty-secondary::after {
  border: 0;
}

.list-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin: 8rpx 2rpx 18rpx;
}

.list-title {
  color: var(--yu-color-anchor-dark);
  font-size: 28rpx;
  font-weight: 900;
}

.list-subtitle {
  margin-top: 6rpx;
  color: var(--yu-color-text-secondary);
  font-size: 20rpx;
}

.list-badge {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-green);
  background: rgba(100, 124, 112, .12);
  font-size: 20rpx;
  font-weight: 900;
}

.cart-list {
  display: grid;
  gap: 18rpx;
}

.cart-item {
  position: relative;
  display: grid;
  grid-template-columns: 142rpx minmax(0, 1fr);
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
}

.item-preview {
  position: relative;
  overflow: hidden;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #f4f1ea, #e1ddd4);
}

.item-preview {
  width: 142rpx;
  height: 116rpx;
}

.tone-blue {
  background: linear-gradient(145deg, #dfeaec, #b7c9cb);
}

.tone-gold {
  background: linear-gradient(145deg, #efe4c7, #d4bd82);
}

.tone-pink {
  background: linear-gradient(145deg, #ead8da, #cfaaa8);
}

.tone-clear {
  background: linear-gradient(145deg, #f3f2ed, #d8ded8);
}

.tone-black {
  background: linear-gradient(145deg, #777d79, #383d39);
}

.item-image {
  width: 100%;
  height: 100%;
}

.mini-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 96rpx;
  height: 86rpx;
  transform: translate(-50%, -50%) rotate(-8deg);
}

.mini-bead {
  position: absolute;
  left: 36rpx;
  top: 31rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 10rpx rgba(20, 20, 20, .16), inset 0 0 0 1rpx rgba(255, 255, 255, .58);
  transform-origin: 12rpx 12rpx;
}

.item-main {
  min-width: 0;
}

.item-title {
  overflow: hidden;
  color: var(--yu-color-anchor-dark);
  font-size: 25rpx;
  font-weight: 900;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.item-spec,
.item-desc,
.item-recipe {
  overflow: hidden;
  color: var(--yu-color-text-secondary);
  font-size: 20rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.item-spec {
  margin-top: 8rpx;
}

.item-recipe {
  margin-top: 6rpx;
}

.item-desc {
  margin-top: 6rpx;
  color: var(--yu-color-text-regular);
  opacity: .72;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 14rpx;
}

.item-price {
  color: var(--yu-color-anchor-dark);
  font-size: 23rpx;
  font-weight: 900;
}

.cart-label {
  flex: none;
  margin-top: 4rpx;
  color: var(--yu-color-text-secondary);
  font-size: 18rpx;
  font-weight: 800;
}

.item-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: none;
  width: 204rpx;
  gap: 10rpx;
}

.item-action {
  box-sizing: border-box;
  display: flex;
  flex: 0 0 82rpx;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  min-width: 0;
  height: 58rpx;
  min-height: 58rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: var(--yu-radius-pill);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.action-secondary {
  color: var(--yu-color-anchor-dark);
  background: rgba(255, 255, 255, .86);
  box-shadow: inset 0 0 0 1rpx rgba(32, 32, 31, .08), 0 8rpx 18rpx rgba(45, 43, 37, .06);
}

.action-primary {
  flex-basis: 112rpx;
  width: 112rpx;
  color: #fff;
  background: linear-gradient(135deg, #2f322f 0%, #141614 100%);
  box-shadow: 0 12rpx 26rpx rgba(26, 28, 25, .16);
}

.item-delete {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  padding: 8rpx 14rpx;
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-red);
  background: rgba(200, 59, 61, .08);
  font-size: 19rpx;
  font-weight: 800;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 58rpx;
  padding: 64rpx 38rpx;
  text-align: center;
}

.empty-ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 230rpx;
  height: 230rpx;
  border: 1rpx solid rgba(100, 124, 112, .22);
  border-radius: 50%;
  background: radial-gradient(circle, #fbfaf7 0 48%, #eee9df 49% 52%, #fbfaf7 53%);
  box-shadow: inset 0 0 34rpx rgba(255, 255, 255, .9);
}

.empty-brand {
  color: var(--yu-color-anchor-dark);
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
}

.empty-brand-en {
  margin-top: 8rpx;
  color: var(--yu-color-text-muted);
  font-size: 16rpx;
  letter-spacing: 4rpx;
}

.empty-title {
  margin-top: 38rpx;
  color: var(--yu-color-anchor-dark);
  font-size: 34rpx;
  font-weight: 900;
}

.empty-desc {
  max-width: 520rpx;
  margin-top: 16rpx;
  color: var(--yu-color-text-secondary);
  font-size: 23rpx;
  line-height: 1.55;
}

.empty-primary,
.empty-secondary {
  width: 480rpx;
}

.empty-primary {
  margin-top: 36rpx;
}

.empty-secondary {
  margin-top: 16rpx;
}

@media (max-width: 360px) {
  .cart-item {
    grid-template-columns: 116rpx minmax(0, 1fr);
    gap: 14rpx;
    padding: 18rpx;
  }

  .item-preview {
    width: 116rpx;
    height: 102rpx;
  }

  .item-bottom {
    align-items: flex-start;
    flex-direction: column;
    gap: 10rpx;
  }

  .item-actions {
    width: 196rpx;
    gap: 8rpx;
  }

  .item-action {
    flex-basis: 80rpx;
    width: 80rpx;
    font-size: 21rpx;
  }

  .action-primary {
    flex-basis: 108rpx;
    width: 108rpx;
  }

  .list-head {
    align-items: flex-start;
    flex-direction: column;
  }
}

.manage-button:active,
.item-action:active {
  opacity: .86;
  transform: scale(.985);
}
