page {
  background: var(--yu-color-bg-page);
}

.cart-page {
  min-height: 100vh;
}

.cart-nav {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.nav-title {
  color: var(--yu-color-anchor-dark);
  font-size: 36rpx;
  font-weight: 900;
}

.nav-subtitle {
  margin-top: 8rpx;
  color: var(--yu-color-text-secondary);
  font-size: 22rpx;
}

.manage-button {
  height: 56rpx;
  min-height: 56rpx;
  margin: 0;
  padding: 0 24rpx;
  border: 0;
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-anchor-dark);
  background: rgba(255, 255, 255, .78);
  box-shadow: var(--yu-shadow-press);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 56rpx;
}

.manage-button::after,
.checkout-button::after,
.delete-selected::after,
.empty-primary::after,
.empty-secondary::after {
  border: 0;
}

.list-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin: 8rpx 2rpx 18rpx;
}

.list-title {
  color: var(--yu-color-anchor-dark);
  font-size: 28rpx;
  font-weight: 900;
}

.list-subtitle {
  margin-top: 6rpx;
  color: var(--yu-color-text-secondary);
  font-size: 20rpx;
}

.list-badge {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-green);
  background: rgba(100, 124, 112, .12);
  font-size: 20rpx;
  font-weight: 900;
}

.cart-list {
  display: grid;
  gap: 18rpx;
}

.cart-item {
  position: relative;
  display: grid;
  grid-template-columns: 38rpx 142rpx 1fr;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
}

.check-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #d4d7d0;
  border-radius: 50%;
  color: #fff;
  background: #fff;
  font-size: 20rpx;
  font-weight: 900;
}

.check-dot.checked {
  border-color: var(--yu-color-blue);
  background: var(--yu-color-blue);
}

.check-dot.small {
  width: 30rpx;
  height: 30rpx;
  font-size: 18rpx;
}

.item-preview {
  position: relative;
  overflow: hidden;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #f4f1ea, #e1ddd4);
}

.item-preview {
  width: 142rpx;
  height: 116rpx;
}

.tone-blue {
  background: linear-gradient(145deg, #dfeaec, #b7c9cb);
}

.tone-gold {
  background: linear-gradient(145deg, #efe4c7, #d4bd82);
}

.tone-pink {
  background: linear-gradient(145deg, #ead8da, #cfaaa8);
}

.tone-clear {
  background: linear-gradient(145deg, #f3f2ed, #d8ded8);
}

.tone-black {
  background: linear-gradient(145deg, #777d79, #383d39);
}

.item-image {
  width: 100%;
  height: 100%;
}

.mini-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 96rpx;
  height: 86rpx;
  transform: translate(-50%, -50%) rotate(-8deg);
}

.mini-bead {
  position: absolute;
  left: 36rpx;
  top: 31rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 10rpx rgba(20, 20, 20, .16), inset 0 0 0 1rpx rgba(255, 255, 255, .58);
  transform-origin: 12rpx 12rpx;
}

.item-main {
  min-width: 0;
}

.item-title {
  overflow: hidden;
  color: var(--yu-color-anchor-dark);
  font-size: 25rpx;
  font-weight: 900;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.item-spec,
.item-desc,
.item-recipe {
  overflow: hidden;
  color: var(--yu-color-text-secondary);
  font-size: 20rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.item-spec {
  margin-top: 8rpx;
}

.item-recipe {
  margin-top: 6rpx;
}

.item-desc {
  margin-top: 6rpx;
  color: var(--yu-color-text-regular);
  opacity: .72;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 14rpx;
}

.item-price {
  color: var(--yu-color-anchor-dark);
  font-size: 23rpx;
  font-weight: 900;
}

.cart-label {
  flex: none;
  margin-top: 4rpx;
  color: var(--yu-color-text-secondary);
  font-size: 18rpx;
  font-weight: 800;
}

.qty-control {
  display: grid;
  grid-template-columns: 44rpx 52rpx 44rpx;
  align-items: center;
  height: 42rpx;
  overflow: hidden;
  border: var(--yu-line-hair);
  border-radius: var(--yu-radius-pill);
  background: rgba(255, 255, 255, .78);
}

.qty-btn,
.qty-value {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 42rpx;
  color: var(--yu-color-anchor-dark);
  font-size: 20rpx;
  font-weight: 800;
}

.qty-value {
  border-right: var(--yu-line-hair);
  border-left: var(--yu-line-hair);
}

.item-delete {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  padding: 8rpx 14rpx;
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-red);
  background: rgba(200, 59, 61, .08);
  font-size: 19rpx;
  font-weight: 800;
}

.bottom-spacer {
  height: 170rpx;
}

.checkout-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx;
  border: var(--yu-line-hair);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .94);
  box-shadow: 0 16rpx 42rpx rgba(20, 20, 20, .1);
  backdrop-filter: blur(18rpx);
}

.select-all {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
  font-weight: 800;
}

.checkout-summary {
  min-width: 0;
  text-align: right;
  color: var(--yu-color-text-regular);
  font-size: 22rpx;
  font-weight: 800;
}

.checkout-price {
  color: var(--yu-color-anchor-dark);
  font-size: 28rpx;
  font-weight: 900;
}

.checkout-button,
.delete-selected {
  height: 76rpx;
  min-height: 76rpx;
  margin: 0;
  padding: 0 32rpx;
  border: 0;
  border-radius: 22rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.checkout-button {
  background: var(--yu-color-anchor-dark);
  box-shadow: 0 12rpx 24rpx rgba(20, 20, 20, .16);
}

.checkout-button.disabled {
  opacity: .42;
  box-shadow: none;
}

.delete-selected {
  background: var(--yu-color-red);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 58rpx;
  padding: 64rpx 38rpx;
  text-align: center;
}

.empty-ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 230rpx;
  height: 230rpx;
  border: 1rpx solid rgba(100, 124, 112, .22);
  border-radius: 50%;
  background: radial-gradient(circle, #fbfaf7 0 48%, #eee9df 49% 52%, #fbfaf7 53%);
  box-shadow: inset 0 0 34rpx rgba(255, 255, 255, .9);
}

.empty-brand {
  color: var(--yu-color-anchor-dark);
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
}

.empty-brand-en {
  margin-top: 8rpx;
  color: var(--yu-color-text-muted);
  font-size: 16rpx;
  letter-spacing: 4rpx;
}

.empty-title {
  margin-top: 38rpx;
  color: var(--yu-color-anchor-dark);
  font-size: 34rpx;
  font-weight: 900;
}

.empty-desc {
  max-width: 520rpx;
  margin-top: 16rpx;
  color: var(--yu-color-text-secondary);
  font-size: 23rpx;
  line-height: 1.55;
}

.empty-primary,
.empty-secondary {
  width: 480rpx;
}

.empty-primary {
  margin-top: 36rpx;
}

.empty-secondary {
  margin-top: 16rpx;
}

@media (max-width: 360px) {
  .cart-item {
    grid-template-columns: 34rpx 116rpx 1fr;
    gap: 14rpx;
    padding: 18rpx;
  }

  .item-preview {
    width: 116rpx;
    height: 102rpx;
  }

  .item-bottom {
    align-items: flex-start;
    flex-direction: column;
    gap: 10rpx;
  }

  .list-head {
    align-items: flex-start;
    flex-direction: column;
  }

  .checkout-bar {
    left: 16rpx;
    right: 16rpx;
    grid-template-columns: auto 1fr;
  }

  .checkout-button,
  .delete-selected {
    grid-column: 1 / -1;
    width: 100%;
  }
}

/* WeUI-like cart controls. */
.manage-button,
.checkout-button,
.delete-selected,
.qty-btn {
  box-sizing: border-box;
}

.manage-button::after,
.checkout-button::after,
.delete-selected::after,
.qty-btn::after {
  border: 0;
}

.checkout-bar {
  border-top: 1rpx solid rgba(32, 32, 31, .08);
  background: rgba(251, 250, 247, .96);
  box-shadow: 0 -14rpx 34rpx rgba(45, 43, 37, .07);
  backdrop-filter: blur(18rpx);
  grid-template-columns: auto minmax(0, 1fr) minmax(190rpx, auto);
}

.checkout-button,
.delete-selected {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  min-height: 82rpx;
  min-width: 190rpx;
  border-radius: 999rpx;
  line-height: 1;
  white-space: nowrap;
}

.checkout-button {
  background: linear-gradient(135deg, #2f322f 0%, #141614 100%);
  box-shadow: 0 14rpx 32rpx rgba(26, 28, 25, .16);
}

.delete-selected {
  background: linear-gradient(135deg, #c95c50, #9d3e35);
}

.checkout-button:active,
.delete-selected:active,
.manage-button:active,
.qty-btn:active {
  opacity: .86;
  transform: scale(.985);
}
