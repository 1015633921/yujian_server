page {
  background: var(--yu-color-bg-page);
}

.favorites-page {
  box-sizing: border-box;
  min-height: 100vh;
  overflow-x: hidden;
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin: 14rpx 0 22rpx;
}

.section-title {
  color: var(--yu-color-anchor-dark);
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.section-subtitle {
  margin-top: 10rpx;
  color: var(--yu-color-text-secondary);
  font-size: 22rpx;
  line-height: 1.45;
}

.result-count {
  flex: none;
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
  font-weight: 800;
}

.post-list {
  display: grid;
  gap: 24rpx;
}

.post-card {
  overflow: hidden;
  border-radius: 28rpx;
}

.post-media {
  position: relative;
  height: 344rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #eee9df 0%, #d9d0c2 100%);
}

.tone-blue {
  background: linear-gradient(145deg, #dce9eb, #a8bfc3);
}

.tone-gold {
  background: linear-gradient(145deg, #eee3ca, #c5a978);
}

.tone-pink {
  background: linear-gradient(145deg, #eedcdd, #caa5a4);
}

.tone-clear {
  background: linear-gradient(145deg, #f3f2ed, #d8ded8);
}

.tone-black {
  background: linear-gradient(145deg, #737a77, #343936);
}

.post-cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.bracelet-preview {
  position: absolute;
  left: 50%;
  top: 48%;
  width: 300rpx;
  height: 260rpx;
  transform: translate(-50%, -50%) rotate(-7deg);
}

.bracelet-preview::before {
  position: absolute;
  left: 18rpx;
  top: 0;
  width: 262rpx;
  height: 230rpx;
  border: 1rpx solid rgba(255, 255, 255, .5);
  border-radius: 50%;
  content: "";
}

.preview-bead {
  position: absolute;
  left: 129rpx;
  top: 109rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 18rpx rgba(30, 32, 30, .2), inset 0 0 0 1rpx rgba(255, 255, 255, .58);
  transform-origin: 21rpx 21rpx;
}

.media-shade {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(0, 0, 0, .03) 0%, rgba(0, 0, 0, .14) 52%, rgba(0, 0, 0, .48) 100%),
    radial-gradient(circle at 20% 12%, rgba(255, 255, 255, .46), rgba(255, 255, 255, 0) 34%);
}

.type-pill,
.remove-fab {
  position: absolute;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 52rpx;
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-anchor-dark);
  background: rgba(255, 255, 255, .82);
  backdrop-filter: blur(12rpx);
  font-size: 20rpx;
  font-weight: 850;
  line-height: 1;
}

.type-pill {
  left: 22rpx;
  top: 22rpx;
  min-width: 136rpx;
  padding: 0 18rpx;
}

.remove-fab {
  right: 22rpx;
  top: 22rpx;
  min-width: 122rpx;
  height: 52rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 0;
}

.remove-fab::after,
.use-button::after,
.empty-button::after {
  border: 0;
}

.post-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 26rpx;
  z-index: 2;
  color: #fff;
}

.post-title {
  overflow: hidden;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
  text-shadow: 0 6rpx 20rpx rgba(0, 0, 0, .22);
  white-space: nowrap;
  text-overflow: ellipsis;
}

.post-desc {
  display: -webkit-box;
  margin-top: 12rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, .86);
  font-size: 23rpx;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.post-body {
  padding: 24rpx 26rpx 26rpx;
  background: rgba(255, 255, 255, .94);
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
}

.meta-text {
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.author-dot {
  flex: none;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--yu-color-green);
}

.meta-divider {
  flex: none;
  width: 1rpx;
  height: 18rpx;
  background: var(--yu-color-line);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.post-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.detail-link {
  color: var(--yu-color-anchor-dark);
  font-size: 22rpx;
  font-weight: 850;
}

.use-button {
  flex: none;
  box-sizing: border-box;
  min-height: 64rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 28rpx;
  border: 0;
  border-radius: var(--yu-radius-pill);
  color: #fff;
  background: linear-gradient(135deg, #2f322f 0%, #141614 100%);
  box-shadow: 0 10rpx 22rpx rgba(26, 28, 25, .12);
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1;
}

.use-button:active,
.remove-fab:active,
.empty-button:active {
  opacity: .86;
  transform: scale(.985);
}

.empty-card {
  margin-top: 80rpx;
  padding: 50rpx 32rpx;
  text-align: center;
}

.empty-title {
  color: var(--yu-color-anchor-dark);
  font-size: 30rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 12rpx;
  color: var(--yu-color-text-secondary);
  font-size: 23rpx;
  line-height: 1.6;
}

.empty-button {
  width: 260rpx;
  margin: 30rpx auto 0;
}

@media (max-width: 360px) {
  .favorites-page {
    padding-left: 22rpx;
    padding-right: 22rpx;
  }

  .post-media {
    height: 316rpx;
  }

  .post-actions {
    align-items: stretch;
    flex-direction: column;
  }

  .use-button {
    width: 100%;
  }
}
