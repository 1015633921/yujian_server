<view class="favorites-page yu-page">
  <view class="section-head">
    <view>
      <view class="section-title">我的收藏</view>
      <view class="section-subtitle">收藏过的灵感搭配、推荐方案和每日能量</view>
    </view>
    <view class="result-count">{{posts.length}} 款</view>
  </view>

  <view wx:if="{{loading}}" class="yu-loading">
    <view class="yu-spinner"></view>
    <view>正在同步收藏内容</view>
  </view>

  <view wx:elif="{{!posts.length}}" class="empty-card yu-card">
    <view class="empty-title">还没有收藏灵感</view>
    <view class="empty-desc">在灵感详情、每日能量或材料页收藏后，会统一留在这里。</view>
    <button class="empty-button yu-button yu-button-primary" bindtap="goCommunity">去逛灵感库</button>
  </view>

  <view wx:else class="post-list">
    <view
      wx:for="{{posts}}"
      wx:key="id"
      class="post-card yu-card yu-card-pressable type-{{item.favoriteType}}"
      data-id="{{item.id}}"
      bindtap="openPost"
    >
      <view class="post-media tone-{{item.tone}}">
        <image
          wx:if="{{item.imageUrl}}"
          class="post-cover"
          src="{{item.imageUrl}}"
          mode="aspectFill"
          lazy-load="{{true}}"
          data-id="{{item.id}}"
          binderror="onImageError"
        />
        <view wx:else class="bracelet-preview">
          <image
            wx:for="{{item.visualBeads}}"
            wx:for-item="bead"
            wx:key="id"
            class="preview-bead"
            src="{{bead.src}}"
            mode="aspectFill"
            lazy-load="{{true}}"
            style="{{bead.style}}"
          />
        </view>
        <view class="media-shade"></view>
        <view class="type-pill">{{item.typeLabel}}</view>
        <button class="remove-fab" data-id="{{item.id}}" catchtap="removeFavorite">已收藏</button>
        <view class="post-copy">
          <view class="post-title">{{item.title}}</view>
          <view class="post-desc">{{item.desc}}</view>
        </view>
      </view>

      <view class="post-body">
        <view class="post-meta">
          <view class="author-dot"></view>
          <view class="meta-text">{{item.author}}</view>
          <view class="meta-divider"></view>
          <view class="meta-text">{{item.sceneText}}</view>
        </view>
        <view class="tag-row">
          <text wx:for="{{item.displayTags}}" wx:key="*this" class="yu-tag">{{item}}</text>
        </view>
        <view class="post-actions">
          <view class="detail-link">{{item.actionText}}</view>
          <button class="use-button" data-id="{{item.id}}" catchtap="useSame">带入 DIY</button>
        </view>
      </view>
    </view>
  </view>
</view>
