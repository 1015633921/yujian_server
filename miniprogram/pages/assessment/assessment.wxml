<view class="assessment-page yu-page">
  <view class="assessment-nav">
    <view class="nav-back yu-pressable" bindtap="goBack">‹</view>
    <view class="nav-title">{{currentStepKey === 'review' ? '确认测算信息' : modeCopy.navTitle}}</view>
    <view class="nav-more yu-pressable" bindtap="openGuide">?</view>
  </view>

  <scroll-view class="assessment-stepper" scroll-x show-scrollbar="{{false}}">
    <view class="stepper-track">
      <view
        wx:for="{{steps}}"
        wx:key="key"
        class="step-item {{item.activeClass}}"
        data-index="{{index}}"
        bindtap="jumpToStep"
      >
        <view class="step-dot">{{item.index}}</view>
        <view class="step-label">{{item.label}}</view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{currentStepKey !== 'review'}}" class="assessment-hero">
    <view class="hero-kicker">{{modeCopy.kicker}}</view>
    <view class="hero-title">{{modeCopy.title}}</view>
    <view class="hero-desc">{{modeCopy.desc}}</view>
    <view class="hero-guide-link" bindtap="openGuide">30 秒了解测算依据</view>
  </view>

  <view wx:if="{{currentStepKey !== 'review'}}" class="flow-intro">
    <view class="flow-count">{{progressText}}</view>
    <view>
      <view class="flow-title">{{currentStep.title}}</view>
      <view class="flow-desc">{{currentStep.desc}}</view>
    </view>
    <view class="flow-badge">{{currentStep.badge}}</view>
  </view>

  <view wx:if="{{currentStepKey === 'review'}}" class="review-hero">
    <view class="review-progress">
      <text>{{progressText}}</text>
      <view class="review-progress-track">
        <view class="review-progress-inner"></view>
      </view>
    </view>
    <view class="review-hero-title">确认测算信息</view>
    <view class="review-hero-desc">确认无误后，将生成你的五行能量报告和专属手串推荐。</view>
  </view>

  <view wx:if="{{currentStepKey === 'basic'}}" class="form-panel yu-card yu-card-lg">
    <view class="panel-head">
      <view>
        <view class="panel-title">请填写你的出生信息</view>
        <view class="panel-desc">用于计算你的五行能量分布</view>
      </view>
      <view class="panel-badge">基础信息</view>
    </view>

    <view class="form-row">
      <view class="row-label">昵称</view>
      <input
        class="row-input"
        placeholder="例如：小羽"
        value="{{form.name}}"
        data-field="name"
        bindinput="onInput"
      />
      <view class="row-required">*</view>
    </view>

    <view class="form-row gender-row">
      <view class="row-label">性别标识</view>
      <view class="gender-options">
        <view
          wx:for="{{genderOptions}}"
          wx:key="value"
          class="gender-seg {{item.activeClass}}"
          data-value="{{item.value}}"
          bindtap="selectGender"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <picker mode="date" value="{{form.birthDate}}" bindchange="onDateChange">
      <view class="form-row picker-row">
        <view class="row-label">出生日期</view>
        <view class="row-value">{{form.birthDate}}</view>
        <view class="row-arrow">›</view>
      </view>
    </picker>

    <picker mode="time" value="{{form.birthTime}}" bindchange="onTimeChange">
      <view class="form-row picker-row">
        <view class="row-label">出生时刻</view>
        <view class="row-value">{{birthTimeLabel}}</view>
        <view class="row-arrow">›</view>
      </view>
    </picker>

    <view class="unknown-row">
      <view class="seg small {{birthTimeUnknownClass}}" bindtap="setBirthTimeUnknown">时刻未知</view>
      <text>不确定时，将按中午 12:00 估算。</text>
    </view>

    <picker mode="region" level="city" value="{{form.birthRegion}}" bindchange="onRegionChange">
      <view class="form-row picker-row last-row">
        <view class="row-label">出生地点</view>
        <view class="row-value">{{form.birthRegion[0]}} {{form.birthRegion[1]}}</view>
        <view class="row-arrow">›</view>
      </view>
    </picker>
  </view>

  <view wx:if="{{currentStepKey === 'mbti'}}" class="option-section">
    <view class="option-head">
      <view>
        <view class="option-title">MBTI 类型</view>
        <view class="option-desc">可选，用于辅助理解偏好与表达方式。</view>
      </view>
      <view class="option-action" bindtap="clearMbti">{{form.mbti ? '清除' : '可选'}}</view>
    </view>
    <view class="chip-grid">
      <view
        wx:for="{{mbtiOptions}}"
        wx:key="value"
        class="chip {{item.activeClass}}"
        data-value="{{item.value}}"
        bindtap="selectMbti"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view wx:if="{{currentStepKey === 'wish'}}" class="option-section">
    <view class="option-head">
      <view>
        <view class="option-title">当前核心愿望</view>
        <view class="option-desc">最多选择 3 项，帮助推荐更贴近你的手作方案。</view>
      </view>
      <view class="option-action">最多 3 项</view>
    </view>
    <view class="wish-grid">
      <view
        wx:for="{{wishOptions}}"
        wx:key="value"
        class="wish {{item.activeClass}}"
        data-value="{{item.value}}"
        bindtap="toggleWish"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view wx:if="{{currentStepKey === 'state'}}" class="option-section">
    <view class="option-head">
      <view>
        <view class="option-title">当下状态</view>
        <view class="option-desc">选出最近最有共鸣的感受，用于七脉轮动态调节。</view>
      </view>
      <view class="option-action">最多 5 项</view>
    </view>
    <view class="state-grid">
      <view
        wx:for="{{chakraOptions}}"
        wx:key="value"
        class="state-card {{item.activeClass}}"
        data-value="{{item.value}}"
        bindtap="toggleChakraAnswer"
      >
        <view class="state-title">{{item.label}}</view>
        <view class="state-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{currentStepKey === 'palette'}}" class="option-section">
    <view class="option-head">
      <view>
        <view class="option-title">直觉色彩</view>
        <view class="option-desc">凭第一眼选择最吸引你的一组色彩。</view>
      </view>
      <view class="option-action">{{form.moodPaletteId ? '已选择' : '可选'}}</view>
    </view>
    <view class="palette-grid">
      <view
        wx:for="{{moodPalettes}}"
        wx:key="value"
        class="palette-card {{item.activeClass}}"
        data-value="{{item.value}}"
        bindtap="selectMoodPalette"
      >
        <view class="palette-swatches">
          <view
            wx:for="{{item.colors}}"
            wx:for-item="color"
            wx:key="*this"
            class="palette-swatch"
            style="background: {{color}};"
          ></view>
        </view>
        <view class="palette-title">{{item.label}}</view>
        <view class="palette-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{currentStepKey === 'review'}}" class="review-panel yu-card yu-card-lg">
    <view class="panel-head">
      <view>
        <view class="panel-title">测算档案</view>
        <view class="panel-desc">点击任一项可以返回对应步骤修改。</view>
      </view>
      <view class="panel-badge">已完成</view>
    </view>
    <view
      wx:for="{{reviewRows}}"
      wx:key="label"
      class="review-row"
      data-index="{{item.stepIndex}}"
      bindtap="jumpToStep"
    >
      <view>
        <view class="review-label">{{item.label}}</view>
        <view class="review-value">{{item.value}}</view>
      </view>
      <view class="review-edit">修改</view>
    </view>
  </view>

  <view wx:if="{{currentStepKey === 'review'}}" class="review-notice">
    出生时辰未知时，系统会按中午 12:00 估算；结果用于文化体验与个性化推荐参考。
  </view>

  <view class="privacy-note">
    <view class="note-dot"></view>
    <view>信息仅用于本次能量测算与方案推荐，不会展示给其他用户。</view>
  </view>

  <view class="assessment-bottom">
    <button
      wx:if="{{showPrevious}}"
      class="assessment-nav-button"
      bindtap="previousStep"
    >
      上一步
    </button>
    <button
      wx:if="{{showSkip}}"
      class="assessment-nav-button ghost"
      bindtap="skipStep"
    >
      跳过
    </button>
    <button
      class="yu-button yu-button-primary assessment-submit"
      loading="{{submitting}}"
      disabled="{{submitting || !canProceed}}"
      bindtap="handlePrimaryAction"
    >
      {{primaryButtonText}}
    </button>
  </view>
</view>
