.assessment-page {
  --assessment-primary: #2f5d50;
  --assessment-primary-dark: #1f3d35;
  --assessment-gold: #c6a15b;
  --assessment-gold-soft: #f4ead4;
  --assessment-line: #e5ddd0;
  --assessment-surface: rgba(255, 255, 255, .88);
  position: relative;
  overflow-x: hidden;
  padding-bottom: calc(176rpx + env(safe-area-inset-bottom));
  font-family: var(--yu-font-romance);
}

.assessment-nav {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 70rpx 1fr 70rpx;
  align-items: center;
  min-height: 72rpx;
}

.nav-back,
.nav-more {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border: var(--yu-line-hair);
  border-radius: 50%;
  color: var(--yu-color-text-regular);
  background: rgba(255, 255, 255, .82);
  box-shadow: var(--yu-shadow-press);
}

.nav-back {
  font-size: 44rpx;
  line-height: 1;
}

.nav-more {
  justify-self: end;
  color: var(--assessment-primary);
  font-size: 26rpx;
  font-weight: 850;
  letter-spacing: 0;
}

.nav-title {
  color: var(--yu-color-anchor-dark);
  text-align: center;
  font-size: 28rpx;
  font-weight: 650;
  letter-spacing: 1rpx;
}

.assessment-stepper {
  position: relative;
  z-index: 1;
  margin-top: 26rpx;
  padding: 0 10rpx;
  white-space: nowrap;
}

.stepper-track {
  display: inline-flex;
  min-width: 100%;
  gap: 12rpx;
  padding: 0 0 4rpx;
}

.step-item {
  position: relative;
  flex: 0 0 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: var(--yu-color-text-muted);
  font-size: 21rpx;
}

.step-item::before {
  position: absolute;
  top: 17rpx;
  left: -50%;
  width: 100%;
  height: 1rpx;
  background: var(--yu-color-line);
  content: "";
  z-index: -1;
}

.step-item:first-child::before {
  display: none;
}

.step-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border: 1rpx solid var(--yu-color-line);
  border-radius: 50%;
  color: #9b9a94;
  background: rgba(255, 255, 255, .92);
  font-size: 19rpx;
  font-weight: 700;
}

.step-label {
  white-space: nowrap;
}

.step-item.active {
  color: var(--assessment-primary);
  font-weight: 700;
}

.step-item.active .step-dot {
  color: #fff;
  border-color: var(--assessment-primary);
  background: var(--assessment-primary);
  box-shadow: 0 8rpx 18rpx rgba(47, 93, 80, .18);
}

.step-item.done {
  color: var(--assessment-gold);
}

.step-item.done .step-dot {
  color: #fff;
  border-color: var(--assessment-gold);
  background: var(--assessment-gold);
}

.assessment-hero {
  position: relative;
  z-index: 1;
  margin-top: 44rpx;
  text-align: center;
}

.hero-kicker {
  color: var(--yu-color-text-secondary);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.hero-title {
  margin-top: 14rpx;
  color: var(--yu-color-anchor-dark);
  font-family: var(--yu-font-title);
  font-size: 42rpx;
  font-weight: 650;
  letter-spacing: 2rpx;
}

.hero-desc {
  max-width: 590rpx;
  margin: 16rpx auto 0;
  color: var(--yu-color-text-secondary);
  font-size: 24rpx;
  line-height: 1.62;
}

.hero-guide-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  margin-top: 22rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(47, 93, 80, .18);
  border-radius: var(--yu-radius-pill);
  color: var(--assessment-primary);
  background: rgba(255, 255, 255, .72);
  box-shadow: 0 8rpx 22rpx rgba(47, 93, 80, .06);
  font-size: 22rpx;
  font-weight: 760;
}

.flow-intro {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 18rpx;
  margin-top: 34rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(222, 216, 205, .82);
  border-radius: 26rpx;
  background: rgba(255,255,255,.74);
  box-shadow: 0 14rpx 34rpx rgba(79, 72, 62, .045);
}

.flow-count {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  color: #fff;
  background: var(--assessment-primary-dark);
  font-size: 22rpx;
  font-weight: 800;
}

.flow-title {
  color: var(--yu-color-anchor-dark);
  font-size: 29rpx;
  font-weight: 800;
}

.flow-desc {
  margin-top: 6rpx;
  color: var(--yu-color-text-secondary);
  font-size: 22rpx;
  line-height: 1.42;
}

.flow-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 78rpx;
  height: 42rpx;
  padding: 0 14rpx;
  border-radius: var(--yu-radius-pill);
  color: var(--assessment-primary);
  background: rgba(47, 93, 80, .1);
  font-size: 20rpx;
  font-weight: 760;
}

.form-panel {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
  padding: 30rpx 28rpx 10rpx;
  border-color: rgba(222, 216, 205, .86);
  background:
    radial-gradient(circle at 92% 10%, rgba(255, 223, 196, .22), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(255, 252, 246, .78));
  box-shadow:
    0 18rpx 46rpx rgba(97, 82, 62, .07),
    inset 0 1rpx 0 rgba(255,255,255,.88);
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 2rpx 4rpx 24rpx;
}

.panel-title {
  color: var(--yu-color-anchor-dark);
  font-size: 30rpx;
  font-weight: 750;
}

.panel-desc {
  margin-top: 8rpx;
  color: var(--yu-color-text-secondary);
  font-size: 22rpx;
}

.panel-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: var(--yu-radius-pill);
  color: var(--assessment-primary);
  background: rgba(47, 93, 80, .1);
  font-size: 20rpx;
  font-weight: 700;
  white-space: nowrap;
}

.form-row {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  border-top: 1rpx solid rgba(229, 226, 220, .82);
}

.form-row-block {
  align-items: flex-start;
  flex-direction: column;
  gap: 18rpx;
  padding: 24rpx 0;
}

.gender-row {
  min-height: 88rpx;
}

.gender-options {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
  min-width: 0;
}

.gender-seg {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 74rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(222, 216, 205, .94);
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-text-secondary);
  background: rgba(255, 255, 255, .82);
  font-size: 22rpx;
  font-weight: 650;
  line-height: 1;
  white-space: nowrap;
  transition: opacity var(--yu-transition-fast), transform var(--yu-transition-fast);
}

.gender-seg:active {
  opacity: .82;
  transform: scale(.98);
}

.gender-seg.active {
  color: #fff;
  border-color: rgba(47, 93, 80, .24);
  background: linear-gradient(135deg, var(--assessment-primary), var(--assessment-primary-dark));
  box-shadow: 0 8rpx 18rpx rgba(47, 93, 80, .18);
}

.picker-row {
  transition: opacity var(--yu-transition-fast);
}

.picker-row:active {
  opacity: .72;
}

.last-row {
  border-bottom: 0;
}

.row-label {
  flex: 0 0 164rpx;
  color: var(--yu-color-text-regular);
  font-size: 27rpx;
  font-weight: 650;
}

.row-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  padding: 0;
  color: var(--yu-color-anchor-dark);
  text-align: right;
  font-size: 27rpx;
}

.row-required {
  width: 24rpx;
  color: var(--yu-color-red);
  text-align: right;
  font-size: 24rpx;
}

.row-value {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: var(--yu-color-anchor-dark);
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 27rpx;
  font-weight: 600;
}

.row-arrow {
  width: 36rpx;
  color: var(--yu-color-text-muted);
  text-align: right;
  font-size: 36rpx;
  line-height: 1;
}

.row-options,
.chip-grid,
.wish-grid,
.state-grid,
.palette-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.seg,
.chip,
.wish {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(222, 216, 205, .9);
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-text-secondary);
  background:
    linear-gradient(180deg, rgba(255,255,255,.92), rgba(250,247,240,.78));
  box-shadow: 0 8rpx 18rpx rgba(74, 64, 52, .035);
  font-size: 24rpx;
  font-weight: 650;
  transition: opacity var(--yu-transition-fast), transform var(--yu-transition-fast);
}

.seg:active,
.chip:active,
.wish:active {
  opacity: .82;
  transform: scale(.98);
}

.seg.small {
  min-height: 50rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
}

.seg.active,
.chip.active,
.wish.active {
  color: #253026;
  border-color: rgba(198, 161, 91, .42);
  background:
    radial-gradient(circle at 85% 15%, rgba(255,255,255,.72), transparent 28%),
    linear-gradient(135deg, #fff1c8, #dde9d1);
  box-shadow: 0 10rpx 22rpx rgba(172, 139, 74, .13);
}

.unknown-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 78rpx;
  padding: 0 0 16rpx 164rpx;
  color: var(--yu-color-text-muted);
  font-size: 21rpx;
  line-height: 1.45;
}

.option-section {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(222, 216, 205, .82);
  border-radius: var(--yu-radius-card-lg);
  background:
    radial-gradient(circle at 8% 0%, rgba(255, 246, 222, .46), transparent 24%),
    rgba(255, 255, 255, .78);
  box-shadow: 0 16rpx 42rpx rgba(79, 72, 62, .055);
}

.option-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 22rpx;
}

.option-title {
  color: var(--yu-color-anchor-dark);
  font-size: 29rpx;
  font-weight: 750;
}

.option-desc {
  margin-top: 8rpx;
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
  line-height: 1.45;
}

.option-action {
  flex: 0 0 auto;
  color: var(--assessment-primary);
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.chip {
  width: 144rpx;
}

.wish {
  min-width: 188rpx;
}

.state-card {
  box-sizing: border-box;
  width: calc((100% - 14rpx) / 2);
  min-height: 118rpx;
  padding: 22rpx 20rpx;
  border: 1rpx solid rgba(222, 216, 205, .88);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .78);
  box-shadow: 0 8rpx 18rpx rgba(74, 64, 52, .035);
}

.state-card.active {
  border-color: rgba(47, 93, 80, .32);
  background:
    radial-gradient(circle at 92% 8%, rgba(255,255,255,.78), transparent 30%),
    linear-gradient(135deg, rgba(221, 233, 209, .9), rgba(255, 241, 200, .72));
  box-shadow: 0 12rpx 26rpx rgba(47, 93, 80, .1);
}

.state-title {
  color: var(--yu-color-anchor-dark);
  font-size: 25rpx;
  font-weight: 760;
}

.state-desc {
  margin-top: 12rpx;
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
}

.palette-card {
  box-sizing: border-box;
  width: calc((100% - 14rpx) / 2);
  min-height: 156rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(222, 216, 205, .88);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .8);
  box-shadow: 0 8rpx 18rpx rgba(74, 64, 52, .035);
}

.palette-card.active {
  border-color: rgba(47, 93, 80, .48);
  background: rgba(255,255,255,.96);
  box-shadow: 0 14rpx 30rpx rgba(47, 93, 80, .11);
}

.palette-swatches {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
}

.palette-swatch {
  height: 46rpx;
  border-radius: 14rpx;
  box-shadow: inset 0 0 0 1rpx rgba(255,255,255,.65);
}

.palette-title {
  margin-top: 16rpx;
  color: var(--yu-color-anchor-dark);
  font-size: 25rpx;
  font-weight: 780;
}

.palette-desc {
  margin-top: 8rpx;
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
}

.privacy-note {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin: 26rpx 8rpx 0;
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
  line-height: 1.55;
}

.review-hero {
  position: relative;
  z-index: 1;
  margin-top: 38rpx;
  padding: 34rpx 30rpx 32rpx;
  border: 1rpx solid rgba(229, 221, 208, .9);
  border-radius: 30rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, .94), rgba(250, 247, 240, .82));
  box-shadow: 0 16rpx 40rpx rgba(74, 64, 52, .06);
}

.review-progress {
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: var(--assessment-primary);
  font-size: 22rpx;
  font-weight: 760;
}

.review-progress-track {
  flex: 1;
  height: 8rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(47, 93, 80, .1);
}

.review-progress-inner {
  width: 100%;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--assessment-primary), var(--assessment-gold));
}

.review-hero-title {
  margin-top: 28rpx;
  color: var(--yu-color-anchor-dark);
  font-family: var(--yu-font-title);
  font-size: 44rpx;
  font-weight: 760;
}

.review-hero-desc {
  margin-top: 14rpx;
  color: var(--yu-color-text-secondary);
  font-size: 24rpx;
  line-height: 1.58;
}

.review-panel {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  padding: 30rpx 28rpx 12rpx;
  border-color: rgba(222, 216, 205, .86);
  background: var(--assessment-surface);
}

.review-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 96rpx;
  border-top: 1rpx solid rgba(229, 226, 220, .82);
}

.review-label {
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
  font-weight: 700;
}

.review-value {
  margin-top: 7rpx;
  color: var(--yu-color-anchor-dark);
  font-size: 25rpx;
  font-weight: 730;
  line-height: 1.42;
}

.review-edit {
  flex: 0 0 auto;
  color: var(--assessment-primary);
  font-size: 22rpx;
  font-weight: 760;
}

.review-notice {
  position: relative;
  z-index: 1;
  margin: 20rpx 8rpx 0;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(198, 161, 91, .28);
  border-radius: 22rpx;
  color: #76684b;
  background: rgba(244, 234, 212, .52);
  font-size: 21rpx;
  line-height: 1.55;
}

.note-dot {
  flex: 0 0 auto;
  width: 10rpx;
  height: 10rpx;
  margin-top: 11rpx;
  border-radius: 50%;
  background: var(--assessment-primary);
}

.assessment-bottom {
  position: fixed;
  right: 0;
  left: 0;
  z-index: 30;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(247, 246, 242, 0), rgba(247, 246, 242, .9) 30%, rgba(247, 246, 242, .98));
}

.assessment-bottom > button {
  margin: 0;
  max-width: none;
}

.assessment-submit {
  flex: 1 1 0;
  width: 0;
  min-width: 210rpx;
  min-height: 92rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
}

.assessment-nav-button {
  display: flex;
  flex: 0 0 164rpx;
  align-items: center;
  justify-content: center;
  width: 164rpx;
  min-width: 0;
  height: 86rpx;
  padding: 0 14rpx;
  border: 1rpx solid rgba(222, 216, 205, .96);
  border-radius: 999rpx;
  color: var(--assessment-primary);
  background: rgba(255,255,255,.86);
  font-size: 25rpx;
  font-weight: 760;
  line-height: 1;
}

.assessment-nav-button.ghost {
  color: var(--yu-color-text-secondary);
  background: rgba(255,255,255,.58);
}

@media (max-width: 340px) {
  .assessment-page {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .row-label {
    flex-basis: 144rpx;
  }

  .unknown-row {
    padding-left: 144rpx;
  }

  .chip {
    width: 130rpx;
  }

  .wish {
    min-width: 174rpx;
  }

  .state-card,
  .palette-card {
    width: 100%;
  }
}

/* WeUI-like assessment bottom action. */
.assessment-bottom {
  box-sizing: border-box;
  border-top: 1rpx solid rgba(229, 221, 208, .72);
  background: rgba(250, 248, 243, .9);
  box-shadow: 0 -16rpx 40rpx rgba(74, 64, 52, .08);
  backdrop-filter: blur(18rpx);
}

.assessment-submit {
  box-sizing: border-box;
  flex: 1 1 0;
  width: 0;
  min-width: 210rpx;
  min-height: 86rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--assessment-primary) 0%, var(--assessment-primary-dark) 100%);
  box-shadow: 0 14rpx 32rpx rgba(47, 93, 80, .18);
}

.assessment-submit[disabled] {
  opacity: 1 !important;
  color: #5f6f66 !important;
  background: linear-gradient(135deg, #eef1ed 0%, #dce3dc 100%) !important;
  border: 1rpx solid rgba(95, 111, 102, .18);
  box-shadow: none;
}

@media (max-width: 340px) {
  .assessment-bottom {
    gap: 8rpx;
    padding-left: 18rpx;
    padding-right: 18rpx;
  }

  .assessment-nav-button {
    flex-basis: 146rpx;
    width: 146rpx;
    padding: 0 10rpx;
    font-size: 23rpx;
  }

  .assessment-submit {
    min-width: 178rpx;
    padding: 0 16rpx;
    font-size: 25rpx;
  }

}
