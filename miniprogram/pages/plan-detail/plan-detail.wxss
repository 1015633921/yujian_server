.recommend-page {
  position: relative;
  overflow-x: hidden;
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
}

.recommend-page::before {
  position: fixed;
  top: -160rpx;
  right: -170rpx;
  width: 480rpx;
  height: 480rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(189, 197, 183, .2), rgba(189, 197, 183, 0) 68%);
  content: "";
  pointer-events: none;
}

.recommend-nav {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 70rpx 1fr 70rpx;
  align-items: center;
  min-height: 72rpx;
}

.nav-back,
.nav-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
}

.nav-back {
  border: var(--yu-line-hair);
  border-radius: 50%;
  color: var(--yu-color-text-regular);
  background: rgba(255, 255, 255, .82);
  box-shadow: var(--yu-shadow-press);
  font-size: 44rpx;
  line-height: 1;
}

.nav-title {
  color: var(--yu-color-anchor-dark);
  text-align: center;
  font-size: 28rpx;
  font-weight: 650;
  letter-spacing: 1rpx;
}

.recommend-tabs {
  position: sticky;
  top: 0;
  z-index: 20;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin: 24rpx -4rpx 22rpx;
  padding: 10rpx 4rpx;
  background: linear-gradient(180deg, rgba(251,250,247,.96), rgba(251,250,247,.84));
  backdrop-filter: blur(16rpx);
}

.tab-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 58rpx;
  color: var(--yu-color-text-secondary);
  font-size: 24rpx;
  font-weight: 700;
}

.tab-item::after {
  position: absolute;
  right: 34rpx;
  bottom: 0;
  left: 34rpx;
  height: 4rpx;
  border-radius: var(--yu-radius-pill);
  background: transparent;
  content: "";
}

.tab-item.active {
  color: var(--yu-color-anchor-dark);
}

.tab-item.active::after {
  background: var(--yu-color-blue);
}

.main-card {
  position: relative;
  z-index: 1;
  overflow: hidden;
  background: rgba(255, 255, 255, .84);
}

.main-image-wrap {
  position: relative;
  height: 382rpx;
  overflow: hidden;
  border-radius: var(--yu-radius-card-lg) var(--yu-radius-card-lg) 0 0;
  background:
    radial-gradient(circle at 50% 40%, rgba(255,255,255,.92), rgba(255,255,255,0) 48%),
    linear-gradient(135deg, #eeeae4, #d9d5ce);
}

.main-image {
  width: 100%;
  height: 100%;
}

.bracelet-preview {
  position: relative;
  width: 100%;
  height: 100%;
}

.bracelet-center {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 260rpx;
  height: 150rpx;
  border: 2rpx solid rgba(120, 122, 114, .18);
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.preview-bead {
  position: absolute;
  top: 50%;
  left: 50%;
  margin-top: -21rpx;
  margin-left: -21rpx;
  border-radius: 50%;
  box-shadow:
    inset -6rpx -8rpx 14rpx rgba(30, 30, 30, .12),
    0 8rpx 18rpx rgba(32, 32, 31, .12);
}

.main-badge {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  color: #9A6D00;
  background: rgba(242, 181, 29, .18);
  font-size: 21rpx;
  font-weight: 800;
}

.main-content {
  padding: 28rpx 28rpx 30rpx;
}

.main-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.main-title {
  color: var(--yu-color-anchor-dark);
  font-size: 34rpx;
  font-weight: 820;
  line-height: 1.25;
}

.main-subtitle {
  margin-top: 8rpx;
  color: var(--yu-color-text-regular);
  font-size: 24rpx;
  line-height: 1.45;
}

.like-btn {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border: var(--yu-line-hair);
  border-radius: 50%;
  color: var(--yu-color-text-regular);
  background: rgba(255, 255, 255, .72);
  font-size: 31rpx;
  font-weight: 900;
}

.like-btn.saved {
  color: var(--yu-color-red);
  background: rgba(200, 59, 61, .08);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.plan-tag {
  display: flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-blue);
  background: rgba(54, 92, 156, .08);
  font-size: 20rpx;
  font-weight: 700;
}

.main-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
}

.price {
  color: var(--yu-color-anchor-dark);
  font-size: 34rpx;
  font-weight: 850;
}

.footer-hint {
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
}

.section-block {
  position: relative;
  z-index: 1;
  margin-top: 34rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
  padding: 0 4rpx;
}

.section-title {
  color: var(--yu-color-anchor-dark);
  font-size: 30rpx;
  font-weight: 820;
}

.section-action {
  color: var(--yu-color-blue);
  font-size: 22rpx;
  font-weight: 700;
}

.plan-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.small-plan {
  overflow: hidden;
  background: rgba(255, 255, 255, .78);
}

.small-preview-wrap {
  position: relative;
  height: 188rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 42%, rgba(255,255,255,.94), rgba(255,255,255,0) 50%),
    #eeeae4;
}

.small-image {
  width: 100%;
  height: 100%;
}

.small-bracelet {
  position: relative;
  width: 100%;
  height: 100%;
}

.small-bead {
  position: absolute;
  top: 50%;
  left: 50%;
  margin-top: -14rpx;
  margin-left: -14rpx;
  border-radius: 50%;
  box-shadow:
    inset -4rpx -5rpx 10rpx rgba(30, 30, 30, .12),
    0 5rpx 12rpx rgba(32, 32, 31, .1);
}

.small-title {
  margin: 20rpx 20rpx 0;
  color: var(--yu-color-anchor-dark);
  font-size: 26rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.small-subtitle {
  min-height: 64rpx;
  margin: 8rpx 20rpx 0;
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.small-price {
  margin: 12rpx 20rpx 22rpx;
  color: var(--yu-color-anchor-dark);
  font-size: 25rpx;
  font-weight: 820;
}

.story-card {
  padding: 28rpx;
  background: rgba(255, 255, 255, .76);
}

.story-title {
  color: var(--yu-color-anchor-dark);
  font-size: 27rpx;
  font-weight: 820;
}

.story-copy {
  margin-top: 12rpx;
  color: var(--yu-color-text-regular);
  font-size: 24rpx;
  line-height: 1.7;
}

.story-divider {
  height: 1rpx;
  margin: 24rpx 0;
  background: var(--yu-color-line);
}

.material-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.material-card {
  display: flex;
  gap: 18rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, .76);
}

.material-orb {
  flex: 0 0 auto;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 30% 25%, #fff 0 9%, #b9c6c7 11% 48%, #738982 100%);
  box-shadow: inset -8rpx -8rpx 14rpx rgba(30,30,30,.12);
}

.material-orb.tone-gold {
  background: radial-gradient(circle at 30% 25%, #fff8cc 0 9%, #dabb5f 11% 48%, #876421 100%);
}

.material-orb.tone-violet {
  background: radial-gradient(circle at 30% 25%, #f8f1ff 0 9%, #a589bb 11% 48%, #60456c 100%);
}

.material-info {
  flex: 1;
  min-width: 0;
}

.material-name {
  color: var(--yu-color-anchor-dark);
  font-size: 27rpx;
  font-weight: 820;
}

.material-role {
  margin-top: 4rpx;
  color: var(--yu-color-blue);
  font-size: 21rpx;
  font-weight: 700;
}

.material-reason {
  margin-top: 12rpx;
  color: var(--yu-color-text-secondary);
  font-size: 23rpx;
  line-height: 1.55;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(247, 246, 242, 0), rgba(247, 246, 242, .92) 22%, rgba(247, 246, 242, .98));
}

.save-button,
.diy-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  margin: 0;
  border-radius: var(--yu-radius-pill);
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1;
}

.save-button {
  flex: 0 0 180rpx;
  color: var(--yu-color-text-regular);
  border: var(--yu-line-hair);
  background: rgba(255, 255, 255, .86);
}

.save-button.saved {
  color: var(--yu-color-red);
  background: rgba(200, 59, 61, .08);
}

.diy-button {
  flex: 1;
  color: #fff;
  border: 0;
  background: var(--yu-color-anchor-dark);
  box-shadow: 0 16rpx 34rpx rgba(33, 34, 31, .16);
}

.empty-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-card {
  width: 100%;
  padding: 52rpx 34rpx;
  text-align: center;
}

.empty-title {
  color: var(--yu-color-anchor-dark);
  font-size: 32rpx;
  font-weight: 820;
}

.empty-desc {
  margin-top: 14rpx;
  color: var(--yu-color-text-secondary);
  font-size: 24rpx;
  line-height: 1.55;
}

@media (max-width: 340px) {
  .recommend-page {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .main-image-wrap {
    height: 340rpx;
  }

  .plan-grid {
    gap: 14rpx;
  }

  .small-preview-wrap {
    height: 164rpx;
  }

  .save-button {
    flex-basis: 154rpx;
  }
}

/* WeUI-like plan detail actions. */
.bottom-actions {
  box-sizing: border-box;
  width: 100%;
  gap: 14rpx;
  padding: 18rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(32, 32, 31, .08);
  background: rgba(251, 250, 247, .96);
  box-shadow: 0 -14rpx 34rpx rgba(45, 43, 37, .07);
  backdrop-filter: blur(18rpx);
}

.save-button,
.diy-button {
  box-sizing: border-box;
  min-width: 0;
  max-width: 100%;
  height: 84rpx;
  min-height: 84rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  line-height: 1;
  white-space: nowrap;
}

.save-button::after,
.diy-button::after {
  border: 0;
}

.save-button {
  flex-basis: 190rpx;
  border: 1rpx solid rgba(32, 32, 31, .1);
  background: rgba(255,255,255,.88);
}

.save-button.saved {
  color: #9d3e35;
  border-color: rgba(157, 62, 53, .14);
  background: rgba(157, 62, 53, .06);
}

.diy-button {
  width: 100%;
  background: linear-gradient(135deg, #2f322f 0%, #141614 100%);
  box-shadow: 0 14rpx 32rpx rgba(26, 28, 25, .16);
}

@media (max-width: 340px) {
  .bottom-actions {
    gap: 12rpx;
    padding-right: 22rpx;
    padding-left: 22rpx;
  }

  .save-button {
    flex-basis: 168rpx;
  }

  .save-button,
  .diy-button {
    height: 78rpx;
    min-height: 78rpx;
    padding: 0 16rpx;
    font-size: 24rpx;
  }
}

.save-button:active,
.diy-button:active {
  opacity: .86;
  transform: scale(.985);
}
