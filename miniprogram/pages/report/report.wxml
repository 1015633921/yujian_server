<view class="page" wx:if="{{report}}">
  <view class="nav-row">
    <view class="icon-btn" bindtap="goBack">‹</view>
    <view class="nav-title">能量报告</view>
    <view class="icon-btn" bindtap="shareReport">↗</view>
  </view>

  <view class="report-hero card">
    <view class="avatar">{{avatarChar}}</view>
    <view class="report-title">{{viewReport.title}}</view>
    <view class="report-tags">
      <text class="tag">{{viewReport.mbti}}</text>
      <text class="tag">{{viewReport.wish}}</text>
      <text class="tag">平衡指数 {{viewReport.balanceIndex}}</text>
    </view>
    <view class="summary">{{viewReport.summary}}</view>
    <view class="solar-time">真太阳时校准：{{viewReport.trueSolarTime}}</view>
  </view>

  <view class="section">
    <view class="section-title">五行能量分布</view>
    <view class="card chart-card">
      <view wx:for="{{viewReport.elements}}" wx:key="key" class="element-row">
        <view class="element-name">{{item.name}}</view>
        <view class="element-track"><view class="element-fill" style="width: {{item.width}}; background: {{item.color}};"></view></view>
        <view class="element-value">{{item.value}}</view>
      </view>
      <view class="chart-note">偏强：{{viewReport.strongest}} · 待补：{{viewReport.weakest}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">生成 DIY 推荐手串</view>
    <view class="card recommend-card">
      <view class="recommend-title">还差一步：输入手腕围度</view>
      <view class="recommend-copy">系统会结合你的五行能量、核心愿望和实际手围，计算珠子种类、尺寸与数量，再生成可继续编辑的 DIY 推荐方案。</view>
    </view>
  </view>

  <button class="primary-button" bindtap="openWristModal">输入手围并获取推荐</button>
</view>

<view class="page empty-page" wx:else>
  <view class="nav-title">还没有报告</view>
  <button class="primary-button" bindtap="goBack">返回测算</button>
</view>

<view wx:if="{{showWristModal}}" class="modal-mask" bindtap="closeWristModal">
  <view class="wrist-modal" catchtap="noop">
    <view class="modal-head">
      <view>
        <view class="modal-title">输入手腕围度</view>
        <view class="modal-sub">请贴合手腕测量，不需要自行预留松量</view>
      </view>
      <view class="modal-close" bindtap="closeWristModal">×</view>
    </view>

    <view class="wrist-input-wrap">
      <input class="wrist-input" type="digit" placeholder="例如 16" value="{{wristInput}}" bindinput="onWristInput" />
      <text>cm</text>
    </view>

    <view class="wrist-options">
      <view wx:for="{{wristOptions}}" wx:key="*this" class="wrist-option" data-value="{{item}}" bindtap="selectWristOption">{{item}}cm</view>
    </view>

    <view class="bead-size-label">偏好珠径</view>
    <view class="bead-size-options">
      <view wx:for="{{beadSizeOptions}}" wx:key="*this" class="bead-size-option {{beadSize === item ? 'active' : ''}}" data-value="{{item}}" bindtap="selectBeadSize">{{item}}mm</view>
    </view>

    <button class="primary-button modal-button" loading="{{generating}}" disabled="{{generating}}" bindtap="confirmWristAndRecommend">生成推荐 DIY 手串</button>
  </view>
</view>
