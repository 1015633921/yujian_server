<view class="result-page yu-page" wx:if="{{report}}">
  <view class="result-nav">
    <view class="nav-back yu-pressable" bindtap="goBack">‹</view>
    <view class="nav-title">五行测算</view>
    <view class="nav-share yu-pressable" bindtap="shareReport">↗</view>
  </view>

  <view class="result-stepper">
    <view
      wx:for="{{steps}}"
      wx:key="key"
      class="step-item {{item.activeClass}}"
    >
      <view class="step-dot">{{item.index}}</view>
      <view class="step-label">{{item.label}}</view>
    </view>
  </view>

  <view class="result-head">
    <view class="result-title">你的五行能量分布</view>
    <view class="result-subtitle">根据出生信息与当前愿望计算</view>
  </view>

  <view class="energy-stage">
    <view
      wx:for="{{viewReport.elements}}"
      wx:key="key"
      class="element-orbit element-{{item.key}}"
    >
      <view class="element-name">{{item.name}}</view>
      <view class="element-percent">{{item.percent}}%</view>
    </view>

    <view class="energy-ring-wrap">
      <view class="energy-ring" style="background: {{viewReport.ringGradient}};">
        <view class="energy-ring-inner">
          <view class="energy-label">整体能量</view>
          <view class="energy-score">{{viewReport.score}}</view>
          <view class="energy-status">{{viewReport.statusText}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="summary-card yu-card yu-card-lg">
    <view class="summary-head">
      <view>
        <view class="summary-title">能量解读</view>
        <view class="summary-meta">偏强 {{viewReport.strongest}} · 待补 {{viewReport.weakest}}</view>
      </view>
      <view class="balance-badge">平衡 {{viewReport.score}}</view>
    </view>
    <view class="summary-copy">{{viewReport.summary}}</view>
  </view>

  <view class="bazi-card yu-card">
    <view class="card-title">命盘底色</view>
    <view class="bazi-pillars">{{viewReport.bazi.pillarsText || '已按真太阳时排盘'}}</view>
    <view class="bazi-grid">
      <view>
        <text>日主</text>
        <view>{{viewReport.bazi.dayMaster || '已生成'}}</view>
      </view>
      <view>
        <text>强弱</text>
        <view>{{viewReport.bazi.strength || '中和'}}</view>
      </view>
      <view>
        <text>喜用</text>
        <view>{{viewReport.bazi.usefulText || '调和'}}</view>
      </view>
    </view>
    <view class="bazi-strategy">{{viewReport.bazi.strategy || viewReport.recommendationStrategy}}</view>
  </view>

  <view class="live-card yu-card">
    <view class="card-title">当下能量</view>
    <view class="live-block">
      <view class="live-label">七脉轮</view>
      <view class="live-title">{{viewReport.chakra.name}}</view>
      <view class="live-copy">{{viewReport.chakra.summary}}</view>
      <view class="live-colors" wx:if="{{viewReport.chakra.colors.length}}">
        <view wx:for="{{viewReport.chakra.colors}}" wx:key="*this" class="live-color" style="background: {{item}};"></view>
      </view>
    </view>
    <view class="live-block">
      <view class="live-label">直觉色彩</view>
      <view class="live-title">{{viewReport.mood.name}}</view>
      <view class="live-copy">{{viewReport.mood.summary}}</view>
      <view class="live-colors" wx:if="{{viewReport.mood.colors.length}}">
        <view wx:for="{{viewReport.mood.colors}}" wx:key="*this" class="live-color" style="background: {{item}};"></view>
      </view>
    </view>
  </view>

  <view class="keyword-card yu-card">
    <view class="card-title">能量关键词</view>
    <view class="keyword-desc">提炼属于你的禅意 / 国风气质标签</view>
    <view class="keyword-list">
      <view wx:for="{{viewReport.keywords}}" wx:key="label" class="keyword-tag">
        <text>{{item.label}}</text>
        <view>{{item.source}}</view>
      </view>
    </view>
  </view>

  <view class="season-card yu-card">
    <view class="season-head">
      <view>
        <view class="card-title">近期能量运势提示</view>
        <view class="season-meta">{{viewReport.seasonal.period}} · {{viewReport.seasonal.seasonal_element}}气当令</view>
      </view>
      <view class="season-mark">{{viewReport.seasonal.seasonal_element}}</view>
    </view>
    <view class="season-copy">{{viewReport.seasonal.seasonal_copy}}</view>
    <view class="season-line">
      <text>流失点</text>
      <view>{{viewReport.seasonal.drain_point}}</view>
    </view>
    <view class="season-line">
      <text>调和建议</text>
      <view>{{viewReport.seasonal.suggestion}}</view>
    </view>
  </view>

  <view class="element-card yu-card">
    <view class="card-title">五行占比</view>
    <view wx:for="{{viewReport.elements}}" wx:key="key" class="element-row">
      <view class="element-pill" style="background: {{item.softColor}}; color: {{item.color}};">{{item.name}}</view>
      <view class="element-track">
        <view class="element-fill" style="width: {{item.width}}; background: {{item.color}};"></view>
      </view>
      <view class="element-value">{{item.percent}}%</view>
    </view>
  </view>

  <view class="why-recommend-card yu-card">
    <view class="card-title">为什么推荐这些水晶</view>
    <view class="why-recommend-desc">系统会把命盘底色、愿望场景和当下状态一起折算到材料库，而不是只看单一标签。</view>
    <view class="why-recommend-list">
      <view wx:for="{{viewReport.recommendationReasons}}" wx:key="index" class="why-recommend-row">
        <view class="why-recommend-index">{{item.index}}</view>
        <view class="why-recommend-copy">
          <view class="why-recommend-title">{{item.title}}</view>
          <view class="why-recommend-text">{{item.desc}}</view>
          <view class="why-recommend-meta">{{item.meta}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="poster-entry yu-card yu-pressable" bindtap="shareReport">
    <view>
      <view class="poster-kicker">REPORT POSTER</view>
      <view class="poster-title">生成专属报告海报</view>
      <view class="poster-copy">把你的五行比例、关键词和调和建议做成宇涧专属海报，方便保存和分享。</view>
    </view>
    <view class="poster-icon">{{posterGenerating ? '…' : '海报'}}</view>
  </view>

  <view class="recommend-entry yu-card yu-pressable" bindtap="openWristModal">
    <view>
      <view class="recommend-title">下一步生成手串方案</view>
      <view class="recommend-copy">输入手腕围度后，系统会结合五行比例、核心愿望和珠径偏好生成可继续编辑的 DIY 方案。</view>
    </view>
    <view class="recommend-icon">→</view>
  </view>

  <view class="result-bottom">
    <view class="result-actions">
      <button class="result-secondary" bindtap="restartAssessment">重新测算</button>
      <button class="yu-button yu-button-primary result-submit" bindtap="openWristModal">查看推荐方案</button>
    </view>
  </view>
</view>

<view class="empty-page yu-page" wx:else>
  <view class="empty-card yu-card">
    <view class="empty-title">还没有测算报告</view>
    <view class="empty-desc">先完成基础信息填写，再查看五行能量分布。</view>
    <button class="yu-button yu-button-primary empty-button" bindtap="goBack">返回测算</button>
  </view>
</view>

<canvas
  id="reportPosterCanvas"
  class="report-poster-canvas"
  type="2d"
  canvas-id="reportPosterCanvas"
></canvas>

<view wx:if="{{showPosterModal}}" class="poster-mask" catchtap="closePosterModal">
  <view class="poster-modal" catchtap="noop">
    <view class="poster-modal-head">
      <view>
        <view class="poster-modal-title">专属报告海报</view>
        <view class="poster-modal-sub">长按图片也可以转发或保存</view>
      </view>
      <view class="poster-close" bindtap="closePosterModal">×</view>
    </view>
    <image class="poster-preview" src="{{posterPath}}" mode="aspectFit" show-menu-by-longpress="{{true}}" bindtap="previewPoster"></image>
    <view class="poster-actions">
      <button class="poster-secondary" bindtap="closePosterModal">稍后</button>
      <button class="poster-primary" loading="{{posterSaving}}" disabled="{{posterSaving}}" bindtap="savePosterImage">保存海报</button>
    </view>
  </view>
</view>

<view wx:if="{{showWristModal}}" class="modal-mask" bindtap="closeWristModal">
  <view class="wrist-modal" catchtap="noop">
    <view class="modal-head">
      <view>
        <view class="modal-title">选择手腕大小</view>
        <view class="modal-sub">左右滑动软尺，松手后自动吸附到 0.1cm</view>
      </view>
      <view class="modal-close" bindtap="closeWristModal">×</view>
    </view>

    <view class="wrist-ruler-value">
      <text class="wrist-ruler-number">{{wristRulerValue}}</text>
      <text class="wrist-ruler-unit">cm</text>
    </view>
    <view class="wrist-ruler-wrap">
      <view class="wrist-ruler-pointer"></view>
      <view class="wrist-ruler-fade left"></view>
      <view class="wrist-ruler-fade right"></view>
      <scroll-view
        class="wrist-ruler-scroll"
        scroll-x
        enhanced
        show-scrollbar="{{false}}"
        bounces="{{true}}"
        scroll-left="{{wristRulerScrollLeft}}"
        bindscroll="onWristRulerScroll"
        bindtouchstart="onWristRulerTouchStart"
        bindtouchend="onWristRulerTouchEnd"
        bindtouchcancel="onWristRulerTouchEnd"
      >
        <view class="wrist-ruler-track" style="padding-left:{{wristRulerSidePadding}}px;padding-right:{{wristRulerSidePadding}}px;">
          <view
            wx:for="{{wristRulerTicks}}"
            wx:key="index"
            class="wrist-ruler-tick {{item.className}}"
            style="width:{{wristRulerTickWidth}}px;"
          >
            <view class="tick-line"></view>
            <view class="tick-label">{{item.label}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
    <view class="wrist-ruler-range">{{wristRulerRangeText}}</view>

    <view class="bead-size-label">偏好珠径</view>
    <view class="bead-size-options">
      <view wx:for="{{beadSizeOptions}}" wx:key="*this" class="bead-size-option {{beadSize === item ? 'active' : ''}}" data-value="{{item}}" bindtap="selectBeadSize">{{item}}mm</view>
    </view>

    <button class="yu-button yu-button-primary modal-button" loading="{{generating}}" disabled="{{generating}}" bindtap="confirmWristAndRecommend">生成推荐 DIY 手串</button>
  </view>
</view>
