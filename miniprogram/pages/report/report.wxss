.result-page {
  position: relative;
  overflow-x: hidden;
  padding-bottom: calc(44rpx + env(safe-area-inset-bottom));
}

.result-page::before {
  position: fixed;
  top: -190rpx;
  left: 50%;
  width: 620rpx;
  height: 620rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, .96), rgba(255, 255, 255, 0) 66%);
  content: "";
  transform: translateX(-50%);
  pointer-events: none;
}

.result-nav {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 70rpx 1fr 70rpx;
  align-items: center;
  min-height: 72rpx;
}

.nav-back,
.nav-share {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border: var(--yu-line-hair);
  border-radius: 50%;
  color: var(--yu-color-text-regular);
  background: rgba(255, 255, 255, .82);
  box-shadow: var(--yu-shadow-press);
}

.nav-back {
  font-size: 44rpx;
  line-height: 1;
}

.nav-share {
  justify-self: end;
  font-size: 30rpx;
  font-weight: 700;
}

.nav-title {
  color: var(--yu-color-anchor-dark);
  text-align: center;
  font-size: 28rpx;
  font-weight: 650;
  letter-spacing: 1rpx;
}

.result-stepper {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-top: 26rpx;
  padding: 0 10rpx;
}

.step-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: var(--yu-color-text-muted);
  font-size: 21rpx;
}

.step-item::before {
  position: absolute;
  top: 17rpx;
  left: -50%;
  width: 100%;
  height: 1rpx;
  background: var(--yu-color-line);
  content: "";
  z-index: -1;
}

.step-item:first-child::before {
  display: none;
}

.step-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border: 1rpx solid var(--yu-color-line);
  border-radius: 50%;
  color: #9b9a94;
  background: rgba(255, 255, 255, .92);
  font-size: 19rpx;
  font-weight: 700;
}

.step-label {
  white-space: nowrap;
}

.step-item.done {
  color: var(--yu-color-green);
}

.step-item.done .step-dot {
  color: #fff;
  border-color: var(--yu-color-green);
  background: var(--yu-color-green);
}

.step-item.active {
  color: var(--yu-color-blue);
  font-weight: 700;
}

.step-item.active .step-dot {
  color: #fff;
  border-color: var(--yu-color-blue);
  background: var(--yu-color-blue);
  box-shadow: 0 8rpx 18rpx rgba(54, 92, 156, .18);
}

.result-head {
  position: relative;
  z-index: 1;
  margin-top: 48rpx;
  text-align: center;
}

.result-title {
  color: var(--yu-color-anchor-dark);
  font-family: "Songti SC", "STSong", "STKaiti", "KaiTi", serif;
  font-size: 40rpx;
  font-weight: 650;
  letter-spacing: 2rpx;
}

.result-subtitle {
  margin-top: 12rpx;
  color: var(--yu-color-text-secondary);
  font-size: 23rpx;
}

.energy-stage {
  position: relative;
  z-index: 1;
  width: 620rpx;
  height: 500rpx;
  margin: 30rpx auto 0;
}

.energy-ring-wrap {
  position: absolute;
  top: 82rpx;
  left: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 330rpx;
  height: 330rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, .38);
  box-shadow: inset 0 0 0 20rpx rgba(255, 255, 255, .5);
  transform: translateX(-50%);
}

.energy-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 286rpx;
  height: 286rpx;
  border-radius: 50%;
  box-shadow:
    0 18rpx 42rpx rgba(35, 38, 34, .06),
    inset 0 0 0 1rpx rgba(255, 255, 255, .8);
}

.energy-ring-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 210rpx;
  height: 210rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 20%, rgba(255,255,255,.98), rgba(255,255,255,.9)),
    var(--yu-color-bg-page-warm);
  box-shadow:
    inset 0 0 0 1rpx rgba(229, 226, 220, .86),
