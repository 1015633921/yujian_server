}

.poster-preview {
  display: block;
  width: 100%;
  min-height: 760rpx;
  background: #F7F6F2;
}

.poster-actions {
  display: grid;
  grid-template-columns: 188rpx minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.poster-secondary,
.poster-primary {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 84rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: var(--yu-radius-pill);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
}

.poster-secondary::after,
.poster-primary::after {
  border: 0;
}

.poster-secondary {
  border: 1rpx solid rgba(32,32,31,.1);
  color: var(--yu-color-text-regular);
  background: rgba(255,255,255,.86);
}

.poster-primary {
  color: #fff;
  background: var(--yu-color-anchor-dark);
  box-shadow: 0 12rpx 26rpx rgba(32,32,31,.16);
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 60;
  display: flex;
  align-items: flex-end;
  background: rgba(20, 20, 20, .42);
}

.wrist-modal {
  width: 100%;
  padding: 34rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 255, 255, .98), rgba(255,255,255,0) 42%),
    var(--yu-color-bg-page-warm);
  box-shadow: 0 -18rpx 56rpx rgba(0, 0, 0, .12);
}

.modal-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.modal-title {
  color: var(--yu-color-anchor-dark);
  font-size: 34rpx;
  font-weight: 820;
}

.modal-sub {
  margin-top: 8rpx;
  color: var(--yu-color-text-secondary);
  font-size: 23rpx;
}

.modal-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  color: var(--yu-color-text-secondary);
  font-size: 44rpx;
  line-height: 1;
}

.wrist-ruler-value {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 10rpx;
  margin-top: 28rpx;
  color: var(--yu-color-anchor-dark);
}

.wrist-ruler-number {
  font-family: "DIN Alternate", "SF Pro Display", "PingFang SC", sans-serif;
  font-size: 76rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -1rpx;
  font-variant-numeric: tabular-nums;
}

.wrist-ruler-unit {
  padding-bottom: 10rpx;
  color: var(--yu-color-text-secondary);
  font-size: 28rpx;
  font-weight: 700;
}

.wrist-ruler-wrap {
  position: relative;
  margin-top: 22rpx;
  height: 150rpx;
  overflow: hidden;
  border: var(--yu-line-hair);
  border-radius: 32rpx;
  background:
    linear-gradient(90deg, rgba(255,255,255,.94), rgba(250,248,242,.8), rgba(255,255,255,.94)),
    rgba(255, 255, 255, .88);
}

.wrist-ruler-scroll {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 150rpx;
  white-space: nowrap;
}

.wrist-ruler-track {
  display: inline-flex;
  align-items: flex-start;
  height: 150rpx;
  box-sizing: border-box;
}

.wrist-ruler-tick {
  position: relative;
  display: inline-flex;
  justify-content: center;
  height: 116rpx;
  padding-top: 28rpx;
  box-sizing: border-box;
}

.tick-line {
  width: 2rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: rgba(107, 112, 101, .34);
}

.wrist-ruler-tick.middle .tick-line {
  height: 34rpx;
  background: rgba(107, 112, 101, .46);
}

.wrist-ruler-tick.major .tick-line {
  height: 48rpx;
  background: rgba(48, 52, 46, .62);
}

.tick-label {
  position: absolute;
  top: 86rpx;
  left: 50%;
  transform: translateX(-50%);
  color: var(--yu-color-text-secondary);
  font-size: 22rpx;
  font-weight: 700;
}

.wrist-ruler-pointer {
  position: absolute;
  top: 14rpx;
  bottom: 18rpx;
  left: 50%;
  z-index: 3;
  width: 4rpx;
  border-radius: 999rpx;
  background: #1f211e;
  box-shadow: 0 10rpx 22rpx rgba(31, 33, 30, .16);
  transform: translateX(-50%);
  pointer-events: none;
}

.wrist-ruler-pointer::before {
  position: absolute;
  top: -2rpx;
  left: 50%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #1f211e;
  content: "";
  transform: translateX(-50%);
}

.wrist-ruler-fade {
  position: absolute;
  top: 0;
  bottom: 0;
  z-index: 2;
  width: 112rpx;
  pointer-events: none;
}

.wrist-ruler-fade.left {
  left: 0;
  background: linear-gradient(90deg, rgba(250,248,242,.98), rgba(250,248,242,0));
}

.wrist-ruler-fade.right {
  right: 0;
  background: linear-gradient(270deg, rgba(250,248,242,.98), rgba(250,248,242,0));
}

.wrist-ruler-range {
  margin-top: 12rpx;
  color: var(--yu-color-text-muted);
  text-align: center;
  font-size: 22rpx;
}

.bead-size-label {
  margin-top: 28rpx;
  color: var(--yu-color-text-regular);
  font-size: 25rpx;
  font-weight: 760;
}

.bead-size-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 14rpx;
}

.bead-size-option {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  border: var(--yu-line-hair);
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-text-secondary);
  background: rgba(255, 255, 255, .78);
  font-size: 23rpx;
  font-weight: 680;
}

.bead-size-option.active {
  color: #fff;
  border-color: var(--yu-color-blue);
  background: var(--yu-color-blue);
}

.modal-button {
  width: 100%;
  margin-top: 30rpx;
}

@media (max-width: 340px) {
  .result-page {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .energy-stage {
    width: 100%;
    height: 470rpx;
  }

  .energy-ring-wrap {
    width: 304rpx;
    height: 304rpx;
  }

  .energy-ring {
    width: 264rpx;
    height: 264rpx;
  }

  .energy-ring-inner {
    width: 194rpx;
    height: 194rpx;
  }

  .element-fire {
    right: 0;
  }

  .element-water {
    left: 0;
  }
}
