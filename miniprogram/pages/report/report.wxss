}

.element-fire {
  top: 128rpx;
  right: 10rpx;
}

.element-earth {
  right: 86rpx;
  bottom: 56rpx;
}

.element-metal {
  bottom: 56rpx;
  left: 86rpx;
}

.element-water {
  top: 128rpx;
  left: 10rpx;
}

.summary-card {
