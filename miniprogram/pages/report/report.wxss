}

.recommend-entry {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 26rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, .72);
}

.recommend-title {
  color: var(--yu-color-anchor-dark);
  font-size: 29rpx;
  font-weight: 800;
}

.recommend-copy {
  margin-top: 10rpx;
  color: var(--yu-color-text-secondary);
  font-size: 23rpx;
  line-height: 1.55;
}

.recommend-icon {
  flex: 0 0 auto;
