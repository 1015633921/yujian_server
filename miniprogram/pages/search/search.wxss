.search-page {
  padding-top: 20rpx;
}

.search-box {
  display: grid;
  grid-template-columns: 46rpx 1fr 54rpx;
  align-items: center;
  gap: 10rpx;
  min-height: 78rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(79, 59, 44, 0.08);
  border-radius: 8rpx;
  background: #fffdf9;
  box-shadow: 0 8rpx 22rpx rgba(73, 51, 33, 0.05);
}

.search-icon {
  color: #7a4e3a;
  text-align: center;
  font-size: 34rpx;
}

.search-input {
  min-height: 76rpx;
  font-size: 27rpx;
}

.clear-btn {
  width: 48rpx;
  height: 48rpx;
  min-height: 48rpx;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  color: #8a8790;
  background: #f6f3ee;
  font-size: 34rpx;
  line-height: 44rpx;
}

.keyword-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.keyword-chip {
  padding: 12rpx 20rpx;
  border: 1rpx solid rgba(122, 78, 58, 0.14);
  border-radius: 999rpx;
  color: #7a4e3a;
  background: #fffdf9;
  font-size: 24rpx;
  font-weight: 800;
}

.state-card {
  margin-top: 18rpx;
  padding: 28rpx;
  color: #756f68;
  font-size: 25rpx;
}

.result-list {
  display: grid;
  gap: 16rpx;
  margin-top: 18rpx;
}

.result-card {
  display: grid;
  grid-template-columns: 92rpx minmax(0, 1fr) 96rpx;
  align-items: center;
  gap: 14rpx;
  width: 100%;
  padding: 18rpx 16rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.result-image,
.result-sphere {
  width: 92rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: #edf0f2;
  box-shadow: inset -12rpx -14rpx 22rpx rgba(0, 0, 0, 0.14), 0 8rpx 16rpx rgba(0, 0, 0, 0.08);
}

.result-copy {
  min-width: 0;
  overflow: hidden;
}

.result-name {
  overflow: hidden;
  color: #2f2a26;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 27rpx;
  font-weight: 900;
}

.result-meta {
  margin-top: 6rpx;
  overflow: hidden;
  color: #756f68;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 22rpx;
  line-height: 1.35;
}

.result-price {
  margin-top: 8rpx;
  color: #7a4e3a;
  font-size: 24rpx;
  font-weight: 800;
}

.result-actions {
  display: grid;
  gap: 8rpx;
  width: 96rpx;
  justify-self: end;
  min-width: 0;
}

.result-actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  min-height: 46rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(122, 78, 58, 0.22);
  border-radius: 999rpx;
  color: #7a4e3a;
  background: #fffdf9;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 46rpx;
}

.result-actions button::after {
  border: 0;
}

.result-actions .primary {
  border: 0;
  color: #fff;
  background: #111;
}
