<view class="lab-home yu-page">
  <view class="home-topbar">
    <view class="home-brand">宇涧水晶</view>
  </view>

  <swiper
    class="hero-swiper"
    circular
    autoplay
    interval="4200"
    duration="520"
    indicator-dots
    indicator-color="rgba(255,255,255,.34)"
    indicator-active-color="#ffffff"
    bindchange="onBannerChange"
  >
    <swiper-item wx:for="{{homeBanners}}" wx:key="id">
      <view class="hero-lab yu-card yu-card-pressable hero-theme-{{item.theme}}" bindtap="openHomeBanner" data-index="{{index}}">
        <image wx:if="{{item.image_url}}" class="hero-banner-image" src="{{item.image_url}}" mode="aspectFill" lazy-load="{{true}}"></image>
        <view wx:else class="hero-photo">
          <view class="photo-table"></view>
          <view class="photo-tray"></view>
          <view class="photo-bracelet">
            <image wx:for="{{heroBeads}}" wx:key="index" class="photo-bead" src="{{item.src}}" mode="aspectFill" style="{{item.style}}"></image>
          </view>
          <image class="photo-loose loose-one" src="{{homeAssets.clearQuartz}}" mode="aspectFit"></image>
          <image class="photo-loose loose-two" src="{{homeAssets.amethyst}}" mode="aspectFit"></image>
          <image class="photo-loose loose-three" src="{{homeAssets.citrine}}" mode="aspectFit"></image>
        </view>
        <view class="hero-shade"></view>
        <view class="hero-copy">
          <view class="hero-eyebrow">{{item.eyebrow}}</view>
          <view class="hero-title">{{item.title}}</view>
          <view class="hero-subtitle">{{item.subtitle}}</view>
          <button class="hero-cta yu-pressable" catchtap="openHomeBanner" data-index="{{index}}">{{item.actionText}}</button>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view class="new-user-guide yu-card yu-card-pressable" bindtap="goToPage" data-url="/pages/assessment-guide/assessment-guide">
    <view class="guide-copy">
      <view class="guide-kicker">NEW HERE</view>
      <view class="guide-title">30 秒了解专属定制</view>
      <view class="guide-desc">看懂五行、MBTI、七脉轮和直觉色彩怎么参与推荐，再开始测算或 DIY。</view>
    </view>
    <view class="guide-action">
      <text>了解定制</text>
      <view>→</view>
    </view>
  </view>

  <view class="workshop-section yu-section">
    <view class="section-row">
      <view class="section-title">定制工坊</view>
      <view class="section-link" bindtap="goToPage" data-url="/pages/assessment-guide/assessment-guide">了解测算 →</view>
    </view>

    <scroll-view class="workshop-flow-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
    <view class="workshop-flow">
      <view class="flow-line"></view>
      <view class="flow-item blue" bindtap="goToPage" data-url="/pages/assessment/assessment">
        <view class="flow-dot">01</view>
        <view class="flow-step">INPUT</view>
        <view class="flow-title">填写测算</view>
        <view class="flow-desc">出生信息 / 愿望偏好</view>
      </view>
      <view class="flow-item green" bindtap="goToPage" data-url="/pages/assessment/assessment">
        <view class="flow-dot">02</view>
        <view class="flow-step">PROFILE</view>
        <view class="flow-title">生成画像</view>
        <view class="flow-desc">五行分布 / 能量方向</view>
      </view>
      <view class="flow-item yellow" bindtap="goToPage" data-url="/pages/workspace/workspace">
        <view class="flow-dot">03</view>
        <view class="flow-step">RECIPE</view>
        <view class="flow-title">推荐配方</view>
        <view class="flow-desc">主石 / 辅石 / 风格</view>
      </view>
      <view class="flow-item red" bindtap="goToPage" data-url="/pages/workspace/workspace">
        <view class="flow-dot">04</view>
        <view class="flow-step">DESIGN</view>
        <view class="flow-title">DIY 排布</view>
        <view class="flow-desc">腕围 / 顺序 / 预览</view>
      </view>
      <view class="flow-item violet" bindtap="goToPage" data-url="/pages/checkout/checkout">
        <view class="flow-dot">05</view>
        <view class="flow-step">ORDER</view>
        <view class="flow-title">确认下单</view>
        <view class="flow-desc">方案清单 / 收货备注</view>
      </view>
      <view class="flow-item dark" bindtap="goToPage" data-url="/pages/order-list/order-list">
        <view class="flow-dot">06</view>
        <view class="flow-step">CRAFT</view>
        <view class="flow-title">制作发货</view>
        <view class="flow-desc">手作履约 / 物流追踪</view>
      </view>
    </view>
    </scroll-view>
  </view>

  <view class="daily-lab-card yu-card yu-card-pressable" bindtap="onDailyTap">
    <view class="daily-card-glow"></view>
    <view class="daily-card-spark spark-a">✦</view>
    <view class="daily-card-spark spark-b">✧</view>
    <view class="daily-copy">
      <view class="daily-kicker">TODAY ENERGY</view>
      <view class="daily-title">今日能量建议</view>
      <view class="daily-subtitle">看看今天适合戴什么</view>
      <view class="daily-tags">
        <text wx:for="{{daily.keywords}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="daily-text">{{daily.summary}}</view>
      <view class="daily-recommend">今日推荐：{{daily.recommendedNames}}</view>
    </view>
    <view class="daily-score">
      <view class="daily-score-halo"></view>
      <text>{{daily.inspiration}}</text>
      <view>能量指数</view>
    </view>
  </view>

  <view class="recommend-section yu-section">
    <view class="section-row">
      <view class="section-title">热门灵感</view>
      <view class="section-link" bindtap="goToPage" data-url="/pages/community/community">进入灵感广场 →</view>
    </view>
    <scroll-view class="plan-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
      <view wx:for="{{inspirations}}" wx:key="id" class="plan-card yu-card-pressable" data-id="{{item.id}}" bindtap="openInspiration">
        <view class="plan-visual product-{{item.tone}}">
          <image wx:if="{{item.coverImage}}" class="plan-cover" src="{{item.coverImage}}" mode="aspectFill" lazy-load="{{true}}"></image>
          <view wx:else class="mini-bracelet">
            <image wx:for="{{item.visualBeads}}" wx:for-item="bead" wx:key="index" class="mini-bead" src="{{bead.src}}" mode="aspectFill" lazy-load="{{true}}" style="{{bead.style}}"></image>
          </view>
        </view>
        <view class="plan-name">{{item.shortName}}</view>
        <view class="plan-desc">{{item.shortDesc}}</view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{shoppingCart.length}}" class="inspiration-tray yu-card yu-card-pressable" bindtap="viewShoppingCart">
    <view>
      <view class="tray-title">购物车</view>
      <view class="tray-sub">{{shoppingCart.length}} 个定制方案待结算</view>
    </view>
    <view class="tray-action">查看</view>
  </view>

  <view class="lab-tabbar {{labTabbarClass}}">
    <view class="lab-tab active" bindtap="goToPage" data-url="/pages/home/home">
      <view class="tab-icon">▣</view>
      <text>首页</text>
    </view>
    <view class="lab-tab" bindtap="goToPage" data-url="/pages/assessment/assessment">
      <view class="tab-icon">✦</view>
      <text>测算</text>
    </view>
    <view class="lab-tab center" bindtap="goToPage" data-url="/pages/workspace/workspace">
      <view class="tab-icon">＋</view>
      <text>DIY</text>
    </view>
    <view class="lab-tab" bindtap="viewShoppingCart">
      <view class="tab-icon">车</view>
      <text>购物车</text>
    </view>
    <view class="lab-tab" bindtap="goToPage" data-url="/pages/profile/profile">
      <view class="tab-icon">♙</view>
      <text>我的</text>
    </view>
  </view>

  <view wx:if="{{showStoneSheet}}" class="stone-sheet-mask" catchtap="closeStoneSheet">
    <view class="stone-sheet" catchtap="noop">
      <view class="sheet-grabber"></view>
      <view class="stone-sheet-main">
        <view class="sheet-stone {{dailyStoneDetail.tone}}">
          <image src="{{dailyStoneDetail.image}}" mode="aspectFit"></image>
        </view>
        <view class="sheet-copy">
          <view class="sheet-title">{{dailyStoneDetail.name}}</view>
          <view class="sheet-desc">{{dailyStoneDetail.desc}}</view>
        </view>
      </view>
      <view wx:if="{{dailyStoneDetail.crystals && dailyStoneDetail.crystals.length}}" class="sheet-crystals">
        <view wx:for="{{dailyStoneDetail.crystals}}" wx:key="code" class="sheet-crystal">
          <view class="sheet-crystal-name">{{item.role}} · {{item.name}}</view>
          <view class="sheet-crystal-reason">{{item.reason}}</view>
        </view>
      </view>
      <view class="sheet-actions">
        <button class="sheet-secondary" bindtap="addDailyStoneToCart">收藏灵感</button>
        <button class="sheet-primary" bindtap="startDailyStoneDiy">用它开始 DIY</button>
      </view>
    </view>
  </view>
</view>
