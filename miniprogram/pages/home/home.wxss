  border-radius: 34rpx;
  background: #11151c;
  box-shadow: 0 16rpx 44rpx rgba(12, 14, 18, .28);
  opacity: 1;
  transform: translateY(0) scale(1);
  transform-origin: center bottom;
  transition: transform .28s cubic-bezier(.22, 1, .36, 1), opacity .22s ease, filter .28s ease;
  will-change: transform, opacity;
}

.lab-tabbar.is-hidden {
  opacity: 0;
  pointer-events: none;
  filter: blur(6rpx);
  transform: translateY(calc(130rpx + env(safe-area-inset-bottom))) scale(.94);
}

.lab-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 98rpx;
  border-radius: 28rpx;
  color: rgba(255,255,255,.78);
  font-size: 20rpx;
  font-weight: 800;
}

.lab-tab.active {
  color: #11151c;
  background: #fff;
}

.lab-tab.center {
  background: rgba(255,255,255,.06);
}

.lab-tab.active.center {
  background: #fff;
}

.tab-icon {
  margin-bottom: 8rpx;
  font-size: 32rpx;
  line-height: 1;
}

.stone-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  background: rgba(28,30,27,.34);
  backdrop-filter: blur(10rpx);
}

.stone-sheet {
  width: 100%;
  padding: 16rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #fbfaf7;
  box-shadow: 0 -22rpx 60rpx rgba(32,30,26,.12);
}

.sheet-grabber {
  width: 64rpx;
  height: 7rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #d9d5cd;
}

.stone-sheet-main {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.sheet-stone {
  display: flex;
  flex: 0 0 128rpx;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #eef1eb;
}

.sheet-stone image {
  width: 100rpx;
  height: 100rpx;
}

.sheet-copy {
  flex: 1;
  min-width: 0;
}

.sheet-title {
  font-size: 31rpx;
  font-weight: 800;
}

.sheet-desc {
  margin-top: 8rpx;
  color: #777973;
  font-size: 22rpx;
  line-height: 1.45;
}

.sheet-crystals {
  display: grid;
  gap: 12rpx;
  margin-top: 22rpx;
}

.sheet-crystal {
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,.7);
}

.sheet-crystal-name {
  color: #535b50;
  font-size: 22rpx;
  font-weight: 800;
}

.sheet-crystal-reason {
  margin-top: 5rpx;
  color: #83877f;
  font-size: 20rpx;
  line-height: 1.4;
}

.sheet-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.sheet-secondary,
.sheet-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  height: 76rpx;
  min-height: 76rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1;
  white-space: nowrap;
}

.sheet-secondary {
  border: var(--yu-line-hair);
  color: #60685c;
  background: #faf9f5;
}

.sheet-primary {
  border: 0;
  color: #fff;
  background: var(--yu-color-anchor-dark);
}

@media (max-width: 360px) {
  .hero-title {
    font-size: 48rpx;
  }

  .hero-subtitle {
    font-size: 22rpx;
  }

  .workshop-section,
  .recommend-section,
  .daily-lab-card,
  .inspiration-tray {
    margin-left: 28rpx;
    margin-right: 28rpx;
  }

  .workshop-flow {
    display: flex;
    gap: 12rpx;
    padding-top: 4rpx;
  }

  .flow-line {
    display: none;
  }

  .flow-item {
    flex-basis: 220rpx;
    min-height: 140rpx;
  }

  .flow-title {
    font-size: 27rpx;
  }

  .flow-desc {
    font-size: 18rpx;
  }

  .lab-tabbar {
    left: 22rpx;
    right: 22rpx;
  }
}

/* WeUI-like home controls. */
.hero-cta,
.tray-action,
.sheet-secondary,
.sheet-primary {
  box-sizing: border-box;
}

.hero-cta::after,
.sheet-secondary::after,
.sheet-primary::after {
  border: 0;
}

.hero-cta {
  border-radius: 999rpx;
  box-shadow: 0 14rpx 32rpx rgba(26, 28, 25, .16);
}

.tray-action {
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f322f 0%, #141614 100%);
  font-weight: 780;
  line-height: 56rpx;
}

.sheet-actions {
  gap: 14rpx;
}

.sheet-secondary,
.sheet-primary {
  height: 82rpx;
  min-height: 82rpx;
  border-radius: 999rpx;
  font-weight: 820;
  line-height: 1;
}

.sheet-secondary {
  border: 1rpx solid rgba(32, 32, 31, .1);
  color: var(--yu-color-text-regular);
  background: rgba(255,255,255,.88);
}

.sheet-primary {
  background: linear-gradient(135deg, #2f322f 0%, #141614 100%);
  box-shadow: 0 14rpx 32rpx rgba(26, 28, 25, .16);
}

.hero-cta:active,
.tray-action:active,
.sheet-secondary:active,
.sheet-primary:active {
  opacity: .86;
  transform: scale(.985);
}
