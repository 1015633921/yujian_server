.hero-section {
  position: relative;
}

.home-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand {
  font-size: 48rpx;
  font-weight: 900;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  color: #7a4e3a;
  font-size: 32rpx;
}

.subtitle {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
  color: #756f68;
  font-size: 25rpx;
  line-height: 1.45;
}

.subtitle text {
  padding: 5rpx 12rpx;
  border: 1rpx solid rgba(122, 78, 58, 0.14);
  border-radius: 999rpx;
  color: #7a4e3a;
  background: #fffdf9;
  font-size: 22rpx;
  font-weight: 800;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 76rpx;
  margin-top: 20rpx;
  padding: 0 22rpx;
  border-radius: 8rpx;
  color: #7a4e3a;
  background: #fffdf9;
  border: 1rpx solid rgba(79, 59, 44, 0.08);
  box-shadow: 0 8rpx 22rpx rgba(73, 51, 33, 0.05);
}

.search-icon {
  font-size: 34rpx;
}

.search-placeholder {
  color: #8a8790;
  font-size: 25rpx;
}

.entry-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 30rpx;
}

.entry {
  position: relative;
  min-height: 260rpx;
  padding: 26rpx;
  overflow: hidden;
  border-radius: 8rpx;
  color: #fff;
  box-shadow: 0 16rpx 32rpx rgba(54, 43, 35, 0.14);
}

.entry.diy {
  background: linear-gradient(135deg, #7a4e3a, #bf7358);
}

.entry.assess {
  background: linear-gradient(135deg, #315f66, #76a39d);
}

.entry-orbit {
  position: absolute;
  right: -42rpx;
  top: 22rpx;
  width: 150rpx;
  height: 150rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
}

.entry-orbit::before,
.entry-orbit::after {
  content: "";
  position: absolute;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
}

.entry-orbit::before {
  left: 30rpx;
  top: -18rpx;
  width: 86rpx;
  height: 186rpx;
  transform: rotate(34deg);
}

.entry-orbit::after {
  left: 42rpx;
  top: 42rpx;
  width: 18rpx;
  height: 18rpx;
  background: rgba(255, 255, 255, 0.6);
}

.entry-kicker {
  position: relative;
  font-size: 22rpx;
  opacity: 0.82;
}

.entry-title {
  position: relative;
  margin-top: 34rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.entry-desc {
  position: relative;
  min-height: 68rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.45;
  opacity: 0.9;
}

.entry-action {
  position: relative;
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  margin-top: 22rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.18);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.22);
  font-size: 25rpx;
  font-weight: 800;
}

.daily {
  padding: 28rpx;
}

.daily-head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.daily-title {
  font-size: 32rpx;
  font-weight: 800;
}

.daily-date {
  margin-top: 8rpx;
  color: #756f68;
  font-size: 24rpx;
}

.daily-score {
  font-size: 48rpx;
  font-weight: 900;
  color: #315f66;
}

.energy-bars {
  margin-top: 28rpx;
}

.bar-row {
  display: grid;
  grid-template-columns: 90rpx 1fr 74rpx;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #6e655d;
  font-size: 24rpx;
}

.bar {
  height: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(238, 232, 223, 0.82);
  box-shadow: inset 0 2rpx 6rpx rgba(73, 51, 33, 0.08);
}

.fill {
  height: 100%;
  border-radius: 999rpx;
}

.fill.vitality {
  background: linear-gradient(90deg, #d89a72, #b46f52);
}

.fill.inspiration {
  background: linear-gradient(90deg, #5fb8c7, #7665b1);
}

.daily-guide {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 28rpx;
}

.guide-chip {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f6f3ee;
  font-size: 24rpx;
}

.color-chip {
  background: #eaf4f5;
}

.number-chip {
  background: #fff4df;
}

.stone-chip {
  background: #eaf4f5;
  color: #315f66;
  font-weight: 800;
}

.product-scroll {
  white-space: nowrap;
}

.product {
  display: inline-block;
  width: 238rpx;
  margin-right: 18rpx;
  padding: 18rpx;
  vertical-align: top;
}

.stone-visual,
.inspo-image {
  height: 148rpx;
  border-radius: 8rpx;
  background: radial-gradient(circle at 35% 30%, #fff 0 10%, #b9d8df 11% 32%, #315f66 33% 100%);
}

.stone-visual.gold,
.inspo-image.gold {
  background: radial-gradient(circle at 35% 30%, #fff6c7 0 10%, #d7b65d 11% 36%, #8e6c21 37% 100%);
}

.stone-visual.violet,
.inspo-image.violet {
  background: radial-gradient(circle at 35% 30%, #f4efff 0 10%, #9f83b8 11% 36%, #64456d 37% 100%);
}

.inspo-image.clear {
  background: radial-gradient(circle at 35% 30%, #fff 0 12%, #d8e0e4 13% 36%, #8b9ca2 37% 100%);
}

.inspo-image.pink {
  background: radial-gradient(circle at 35% 30%, #fff 0 10%, #e6a7a4 11% 36%, #a65e62 37% 100%);
}

.inspo-image.black {
  background: radial-gradient(circle at 35% 30%, #bfc5c6 0 8%, #3d3c3f 9% 36%, #171719 37% 100%);
}

.product-name,
.inspo-name {
  margin-top: 16rpx;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.28;
  white-space: normal;
}

.product-desc,
.inspo-meta {
  margin-top: 8rpx;
  color: #756f68;
  font-size: 22rpx;
  line-height: 1.4;
  white-space: normal;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 14rpx;
}

.product-price {
  color: #7a4e3a;
  font-size: 28rpx;
  font-weight: 800;
}

.quick-add {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  min-height: 54rpx;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  color: #fff;
  background: #7a4e3a;
  font-size: 30rpx;
  line-height: 54rpx;
  box-shadow: 0 8rpx 18rpx rgba(122, 78, 58, 0.2);
}

.inspiration-tray {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(122, 78, 58, 0.1);
  border-radius: 8rpx;
  background: #fff8eb;
}

.tray-title {
  color: #7a4e3a;
  font-size: 25rpx;
  font-weight: 900;
}

.tray-sub {
  margin-top: 4rpx;
  color: #756f68;
  font-size: 22rpx;
}

.tray-action {
  flex: 0 0 96rpx;
  height: 52rpx;
  border-radius: 999rpx;
  color: #fff;
  background: #7a4e3a;
  text-align: center;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 52rpx;
}

.stone-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: flex-end;
  background: rgba(28, 24, 20, 0.28);
}

.stone-sheet {
  width: 100%;
  padding: 16rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #fffdf9;
  box-sizing: border-box;
}

.sheet-grabber {
  width: 64rpx;
  height: 7rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #e8ded2;
}

.stone-sheet-main {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.sheet-stone {
  flex: 0 0 128rpx;
  width: 128rpx;
  height: 128rpx;
}

.sheet-copy {
  flex: 1;
  min-width: 0;
}

.sheet-title {
  color: #2f2a26;
  font-size: 32rpx;
  font-weight: 900;
}

.sheet-desc {
  margin-top: 8rpx;
  color: #756f68;
  font-size: 24rpx;
  line-height: 1.45;
}

.sheet-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.sheet-secondary,
.sheet-primary {
  min-height: 76rpx;
  padding: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 76rpx;
}

.sheet-secondary {
  border: 1rpx solid rgba(122, 78, 58, 0.24);
  color: #7a4e3a;
  background: #fffdf9;
}

.sheet-primary {
  border: 0;
  color: #fff;
  background: #111;
}

.inspo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.inspo {
  padding: 16rpx;
}
