<view class="checkout-page yu-page">
  <view class="checkout-nav">
    <view class="nav-back yu-pressable" bindtap="goBack">‹</view>
    <view class="nav-title">确认方案</view>
    <view class="nav-placeholder"></view>
  </view>

  <view wx:if="{{design}}" class="checkout-content">
    <view class="plan-card yu-card yu-card-lg">
      <view class="plan-preview">
        <image
          wx:if="{{designPreviewImage}}"
          class="plan-preview-image"
          src="{{designPreviewImage}}"
          mode="aspectFill"
          lazy-load="{{true}}"
          binderror="onPreviewImageError"
        ></image>
        <view wx:else class="bracelet-mini">
          <view class="bracelet-mini-ring"></view>
          <view
            wx:for="{{previewBeads}}"
            wx:key="index"
            class="preview-bead"
            style="{{item.style}}"
          >
            <image wx:if="{{item.image_url}}" class="preview-bead-image" src="{{item.image_url}}" mode="aspectFill"></image>
            <view wx:else class="preview-bead-dot"></view>
          </view>
        </view>
      </view>
      <view class="plan-info">
        <view class="plan-title">温柔守护 · 和谐平衡款</view>
        <view class="plan-meta">手围：{{design.wristSize || '--'}}cm　配珠：{{design.summary.count}}颗</view>
        <view class="plan-tags">
          <text>平衡五行</text>
          <text>手作定制</text>
          <text>{{design.summary.length}}cm</text>
        </view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-title">方案清单</view>
      <view class="material-list yu-card">
        <view wx:for="{{bom}}" wx:key="sku" class="material-row">
          <view class="material-dot">
            <image wx:if="{{item.image_url}}" src="{{item.image_url}}" mode="aspectFill"></image>
          </view>
          <view class="material-main">
            <view class="material-name">{{item.name}}</view>
            <view class="material-sub">{{item.subText || item.sizeText || '定制珠材'}}</view>
          </view>
          <view class="material-right">
            <view class="material-price">¥{{item.totalText || item.priceText}}</view>
            <view class="material-qty">x {{item.qty}}</view>
          </view>
        </view>
        <view class="material-total">共 {{design.summary.count}} 颗材料</view>
      </view>
    </view>

    <view class="coupon-row yu-card">
      <view>
        <view class="coupon-title">优惠券</view>
        <view class="coupon-desc">当前暂无可用优惠</view>
      </view>
      <view class="coupon-amount">{{couponDiscountText}}</view>
    </view>

    <view class="section-block" id="addressForm">
      <view class="section-head">
        <view class="section-title">收货信息</view>
        <button class="link-button" bindtap="chooseWechatAddress">微信地址</button>
      </view>

      <view class="address-card yu-card" bindtap="focusAddressForm">
        <view wx:if="{{hasAddress}}" class="address-content">
          <view class="receiver-line">
            <text>{{receiver.name}}</text>
            <text>{{receiver.phone}}</text>
          </view>
          <view class="address-text">{{fullAddress}}</view>
        </view>
        <view wx:else class="address-empty">
          <view class="address-empty-title">请选择收货地址</view>
          <view class="address-empty-desc">支持微信地址导入，也可以下方手动填写。</view>
        </view>
        <view class="address-arrow">›</view>
      </view>

      <view class="form-card yu-card">
        <view class="field-row">
          <view class="field-label">收货人</view>
          <input class="input" placeholder="请填写收货人姓名" data-field="name" value="{{receiver.name}}" bindinput="onInput" />
        </view>
        <view class="field-row">
          <view class="field-label">手机号</view>
          <input class="input" placeholder="请填写 11 位手机号" maxlength="11" type="number" data-field="phone" value="{{receiver.phone}}" bindinput="onInput" />
        </view>
        <view class="field-row">
          <view class="field-label">所在地区</view>
          <picker mode="region" value="{{receiver.region}}" bindchange="onRegionChange">
            <view class="picker-value {{receiver.regionText ? '' : 'placeholder'}}">
              {{receiver.regionText || '请选择省 / 市 / 区'}}
            </view>
          </picker>
        </view>
        <view class="field-row detail-row">
          <view class="field-label">详细地址</view>
          <textarea class="textarea" placeholder="街道、门牌号、小区楼栋等" maxlength="120" data-field="detailAddress" value="{{receiver.detailAddress}}" bindinput="onInput"></textarea>
        </view>
        <view wx:if="{{addressError}}" class="form-error">{{addressError}}</view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <view class="section-title">订单备注</view>
        <view class="section-link">选填</view>
      </view>
      <view class="remark-card yu-card">
        <textarea class="remark-textarea" placeholder="例如：手围偏松一点、送礼请不要放价格、想要更亮一点的主珠..." maxlength="500" value="{{remark}}" bindinput="onRemarkInput"></textarea>
        <view class="remark-count">{{remark.length || 0}}/500</view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <view class="section-title">串珠顺序</view>
        <view class="section-link">制作核对</view>
      </view>
      <view class="sequence-card yu-card">
        <view wx:for="{{sequence}}" wx:key="index" class="sequence-row">
          <text class="sequence-index">{{item.index}}</text>
          <view class="sequence-dot">
            <image wx:if="{{item.image_url}}" src="{{item.image_url}}" mode="aspectFill"></image>
          </view>
          <view class="sequence-main">
            <view class="sequence-name">{{item.name}}</view>
            <view class="sequence-sub">{{item.subText || item.sizeText || '定制珠材'}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty">
    <view>还没有可结算的设计</view>
    <button class="primary-button" bindtap="goBack">返回工作台</button>
  </view>

  <view wx:if="{{design}}" class="submit-bar">
    <view class="pay-total">
      <text>合计：</text>
      <view>¥{{amountText}}</view>
    </view>
    <button class="submit-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitOrder">
      {{submitting ? '正在提交' : '提交订单'}}
    </button>
  </view>
</view>
