.checkout-page {
  min-height: 100vh;
  padding-bottom: calc(168rpx + env(safe-area-inset-bottom));
}

.checkout-nav {
  display: grid;
  grid-template-columns: 70rpx 1fr 70rpx;
  align-items: center;
  min-height: 72rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border: var(--yu-line-hair);
  border-radius: 50%;
  color: var(--yu-color-text-regular);
  background: rgba(255,255,255,.82);
  box-shadow: var(--yu-shadow-press);
  font-size: 44rpx;
  line-height: 1;
}

.nav-title {
  color: var(--yu-color-anchor-dark);
  text-align: center;
  font-size: 29rpx;
  font-weight: 750;
}

.checkout-content {
  margin-top: 18rpx;
}

.plan-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255,255,255,.86);
}

.plan-preview {
  position: relative;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 520rpx;
  overflow: visible;
  border-radius: 28rpx;
  background: #FFFFFF;
}

.plan-preview-stage {
  position: relative;
  display: flex;
  overflow: hidden;
  align-items: center;
  justify-content: center;
  width: 560rpx;
  height: 560rpx;
  max-width: 100%;
  border: 1rpx solid rgba(120, 118, 109, .1);
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow:
    inset 0 0 0 16rpx rgba(247, 245, 239, .78),
    inset 0 0 0 19rpx rgba(135, 132, 122, .08),
    0 18rpx 42rpx rgba(45, 42, 35, .06);
}

.plan-preview-stage::after {
  position: absolute;
  inset: 82rpx;
  border: 2rpx solid rgba(120, 118, 109, .12);
  border-radius: 50%;
  content: "";
  pointer-events: none;
}

.plan-preview-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #FFFFFF;
  transform: none;
  transform-origin: center;
}

.bracelet-mini {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.bracelet-mini-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 62%;
  height: 62%;
  border: 2rpx solid rgba(120, 118, 109, .18);
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.preview-bead {
  position: absolute;
  top: 50%;
  left: 50%;
  overflow: hidden;
  border-radius: 50%;
  box-shadow: inset -3rpx -5rpx 9rpx rgba(30,30,30,.13), 0 4rpx 10rpx rgba(32,32,31,.12);
}

.preview-bead-image,
.preview-bead-dot {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.preview-bead-dot {
  background: radial-gradient(circle at 32% 26%, #fff 0 12%, #d8cfc3 18% 58%, rgba(0,0,0,.18) 100%);
}

.plan-info {
  min-width: 0;
  padding: 4rpx 0;
}

.plan-title {
  color: var(--yu-color-anchor-dark);
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.35;
}

.plan-meta {
  margin-top: 10rpx;
  color: var(--yu-color-text-secondary);
  font-size: 22rpx;
}

.plan-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.plan-tags text {
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-blue);
  background: rgba(54, 92, 156, .08);
  font-size: 19rpx;
  line-height: 38rpx;
}

.section-block {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.section-title {
  color: var(--yu-color-anchor-dark);
  font-size: 29rpx;
  font-weight: 850;
}

.section-link {
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
}

.material-list,
.sequence-card,
.form-card,
.remark-card,
.address-card,
.coupon-row {
  background: rgba(255,255,255,.84);
}

.material-list {
  overflow: hidden;
  padding: 8rpx 24rpx 0;
}

.material-row {
  display: grid;
  grid-template-columns: 46rpx 1fr 120rpx;
  align-items: center;
  gap: 16rpx;
  min-height: 84rpx;
  border-bottom: 1rpx solid rgba(229,226,220,.78);
}

.material-row:last-of-type {
  border-bottom: 0;
}

.material-dot {
  overflow: hidden;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 32% 26%, #fff 0 12%, #d8cfc3 18% 58%, rgba(0,0,0,.16) 100%);
}

.material-dot image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.material-name {
  color: var(--yu-color-anchor-dark);
  font-size: 25rpx;
  font-weight: 780;
}

.material-sub {
  margin-top: 5rpx;
  color: var(--yu-color-text-secondary);
  font-size: 20rpx;
}

.material-right {
  text-align: right;
}

.material-price {
  color: var(--yu-color-anchor-dark);
  font-size: 23rpx;
  font-weight: 850;
}

.material-qty {
  margin-top: 4rpx;
  color: var(--yu-color-text-secondary);
  font-size: 20rpx;
}

.material-total {
  padding: 18rpx 0 22rpx;
  color: var(--yu-color-text-secondary);
  text-align: center;
  font-size: 22rpx;
}

.coupon-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 26rpx;
  padding: 26rpx;
}

.coupon-title {
  color: var(--yu-color-anchor-dark);
  font-size: 26rpx;
  font-weight: 800;
}

.coupon-desc {
  margin-top: 6rpx;
  color: var(--yu-color-text-secondary);
  font-size: 21rpx;
}

.coupon-amount {
  color: var(--yu-color-red);
  font-size: 24rpx;
  font-weight: 800;
}

.address-card {
  display: grid;
  grid-template-columns: 1fr 32rpx;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.receiver-line {
  display: flex;
  gap: 22rpx;
  color: var(--yu-color-anchor-dark);
  font-size: 27rpx;
  font-weight: 850;
}

.address-text,
.address-empty-desc {
  margin-top: 8rpx;
  color: var(--yu-color-text-secondary);
  font-size: 22rpx;
  line-height: 1.45;
}

.address-empty-title {
  color: var(--yu-color-anchor-dark);
  font-size: 27rpx;
  font-weight: 850;
}

.address-arrow {
  color: var(--yu-color-text-secondary);
  font-size: 36rpx;
}

.link-button {
  min-height: 50rpx;
  margin: 0;
  padding: 0 18rpx;
  border: var(--yu-line-hair);
  border-radius: var(--yu-radius-pill);
  color: var(--yu-color-green);
  background: rgba(255,255,255,.78);
  font-size: 22rpx;
  line-height: 50rpx;
}

.form-card {
  padding: 10rpx 24rpx;
}

.field-row {
  display: grid;
  grid-template-columns: 128rpx 1fr;
  align-items: center;
  gap: 18rpx;
  min-height: 88rpx;
  border-bottom: 1rpx solid rgba(229,226,220,.78);
}

.field-row:last-child {
  border-bottom: 0;
}

.detail-row {
  align-items: start;
  padding: 16rpx 0;
}

.field-label {
  color: var(--yu-color-anchor-dark);
  font-size: 24rpx;
  font-weight: 780;
}

.input,
.picker-value {
  min-height: 76rpx;
  color: var(--yu-color-anchor-dark);
  font-size: 25rpx;
  line-height: 76rpx;
}

.picker-value.placeholder {
  color: var(--yu-color-text-muted);
}

.textarea {
  width: 100%;
  min-height: 124rpx;
  padding: 18rpx 0;
  color: var(--yu-color-anchor-dark);
  font-size: 25rpx;
  line-height: 1.45;
}

.form-error {
  margin: 18rpx 0 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  color: #a8482d;
  background: #fff0e8;
  font-size: 22rpx;
}

.remark-card {
  position: relative;
  padding: 22rpx 24rpx 48rpx;
}

.remark-textarea {
  width: 100%;
  min-height: 126rpx;
  color: var(--yu-color-anchor-dark);
  font-size: 25rpx;
  line-height: 1.5;
}

.remark-count {
  position: absolute;
  right: 24rpx;
  bottom: 18rpx;
  color: var(--yu-color-text-muted);
  font-size: 21rpx;
}

.sequence-card {
  padding: 10rpx 24rpx;
}

.sequence-row {
  display: grid;
  grid-template-columns: 42rpx 46rpx 1fr;
  align-items: center;
  gap: 14rpx;
  min-height: 84rpx;
  border-bottom: 1rpx solid rgba(229,226,220,.78);
  font-size: 23rpx;
}

.sequence-row:last-child {
  border-bottom: 0;
}

.sequence-index {
  color: var(--yu-color-text-muted);
  font-family: var(--yu-font-serif);
  font-weight: 800;
}

.sequence-dot {
  overflow: hidden;
  width: 46rpx;
  height: 46rpx;
  border: 1rpx solid rgba(148, 143, 132, .16);
  border-radius: 50%;
  background: radial-gradient(circle at 30% 25%, #ffffff 0 10%, #ece7dc 55%, #d9d1c3 100%);
  box-shadow: 0 6rpx 12rpx rgba(65, 55, 38, .08);
}

.sequence-dot image {
  display: block;
  width: 100%;
  height: 100%;
}

.sequence-main {
  min-width: 0;
}

.sequence-name {
  overflow: hidden;
  color: var(--yu-color-anchor-dark);
  font-size: 24rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sequence-sub {
  margin-top: 4rpx;
  color: var(--yu-color-text-secondary);
  font-size: 20rpx;
}

.submit-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: grid;
  grid-template-columns: 1fr 260rpx;
  align-items: center;
  gap: 24rpx;
  padding: 18rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(140,145,133,.13);
  background: rgba(251,250,247,.96);
  box-shadow: 0 -12rpx 34rpx rgba(76,73,65,.07);
}

.pay-total {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  min-width: 0;
}

.pay-total text {
  color: var(--yu-color-text-regular);
  font-size: 25rpx;
}

.pay-total view {
  color: var(--yu-color-anchor-dark);
  font-size: 36rpx;
  font-weight: 900;
}

.submit-button {
  height: 82rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: var(--yu-radius-pill);
  color: #fff;
  background: var(--yu-color-blue);
  font-size: 27rpx;
  font-weight: 850;
  line-height: 82rpx;
  box-shadow: 0 14rpx 30rpx rgba(54, 92, 156, .18);
}

.empty {
  display: flex;
  min-height: 60vh;
  flex-direction: column;
  justify-content: center;
  color: var(--yu-color-text-secondary);
  text-align: center;
}

@media (max-width: 340px) {
  .plan-preview {
    min-height: 470rpx;
  }

  .plan-preview-stage {
    width: 500rpx;
    height: 500rpx;
  }

  .plan-preview-image {
    transform: none;
  }

  .submit-bar {
    grid-template-columns: 1fr 230rpx;
    padding-right: 22rpx;
    padding-left: 22rpx;
  }

  .pay-total view {
    font-size: 32rpx;
  }
}

/* WeUI-like checkout controls. */
.link-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid rgba(100, 124, 112, .16);
  border-radius: 999rpx;
  color: var(--yu-color-green);
  background: rgba(255, 255, 255, .7);
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1;
}

.link-button::after,
.submit-button::after {
  border: 0;
}

.submit-bar {
  box-sizing: border-box;
  width: 100%;
  overflow: visible;
  grid-template-columns: minmax(0, 1fr) minmax(260rpx, 320rpx);
  gap: 18rpx;
  padding: 18rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(32, 32, 31, .08);
  background: rgba(251, 250, 247, .96);
  box-shadow: 0 -14rpx 34rpx rgba(45, 43, 37, .07);
  backdrop-filter: blur(18rpx);
}

.submit-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 84rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #2f322f 0%, #141614 100%);
  box-shadow: 0 14rpx 32rpx rgba(26, 28, 25, .16);
  font-size: 27rpx;
  font-weight: 850;
  line-height: 1;
}

.submit-button:active,
.link-button:active {
  opacity: .86;
  transform: scale(.985);
}

@media (max-width: 340px) {
  .submit-bar {
    grid-template-columns: minmax(0, 1fr) 236rpx;
    gap: 12rpx;
  }

  .submit-button {
    height: 76rpx;
    font-size: 24rpx;
  }
}
