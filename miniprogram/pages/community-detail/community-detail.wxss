.inspo-detail-page,
.empty-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: calc(24rpx + env(safe-area-inset-top)) 28rpx calc(196rpx + env(safe-area-inset-bottom));
  color: var(--yu-color-text-primary);
  background: #F7F6F2;
}

.detail-nav {
  display: grid;
  grid-template-columns: 70rpx 1fr 130rpx;
  align-items: center;
  min-height: 72rpx;
  margin-bottom: 18rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  border: 1rpx solid rgba(32, 32, 31, .08);
  border-radius: 50%;
  color: var(--yu-color-anchor-dark);
  background: rgba(255,255,255,.9);
  box-shadow: 0 8rpx 22rpx rgba(20, 20, 20, .04);
  font-size: 44rpx;
  line-height: 1;
}

.nav-title {
  color: var(--yu-color-anchor-dark);
  font-size: 30rpx;
  font-weight: 850;
  text-align: center;
}

.nav-capsule {
  justify-self: end;
  display: grid;
  grid-template-columns: 1fr 1rpx 1fr;
  align-items: center;
  width: 120rpx;
  height: 58rpx;
  border: 1rpx solid rgba(32, 32, 31, .08);
  border-radius: 999rpx;
  background: rgba(255,255,255,.9);
  box-shadow: 0 8rpx 20rpx rgba(20,20,20,.03);
}

.nav-capsule::before {
  content: "";
  grid-column: 2;
  width: 1rpx;
  height: 30rpx;
  background: rgba(32,32,31,.08);
}

.nav-dot,
.nav-circle {
  grid-row: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-dot {
  grid-column: 1;
  font-size: 26rpx;
}

.nav-circle {
  grid-column: 3;
  justify-self: center;
  width: 28rpx;
  height: 28rpx;
  border: 7rpx solid #111;
  border-radius: 50%;
}

.title-panel {
  padding: 14rpx 4rpx 26rpx;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #8B8881;
  font-size: 22rpx;
  font-weight: 760;
}

.tone-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.meta-line {
  width: 34rpx;
  height: 1rpx;
  background: #D8D4CC;
}

.hero-title {
  margin-top: 18rpx;
  color: #191919;
  font-size: 46rpx;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.18;
}

.hero-desc {
  margin-top: 16rpx;
  max-width: 620rpx;
  color: #64615B;
  font-size: 25rpx;
  line-height: 1.66;
}

.hero-media,
.section-card,
.empty-card {
  border: 1rpx solid rgba(32,32,31,.07);
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 34rpx rgba(20, 20, 20, .045);
}

.hero-media {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 440rpx;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.bracelet-stage {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: #F7F6F2;
}

.preview-bead {
  position: absolute;
  left: 50%;
  top: 50%;
  margin-left: -21rpx;
  margin-top: -21rpx;
  border-radius: 50%;
  box-shadow: 0 5rpx 12rpx rgba(43,41,36,.14), inset 0 0 0 1rpx rgba(255,255,255,.6);
  transform-origin: center center;
}

.section-card {
  margin-top: 22rpx;
  padding: 30rpx;
}

.section-kicker {
  color: #A29D93;
  font-size: 20rpx;
  font-weight: 850;
  letter-spacing: 0;
}

.section-title {
  margin-top: 8rpx;
  color: #1F2220;
  font-size: 31rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.scene-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.scene-chips text {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border: 1rpx solid #E5E2DC;
  border-radius: 999rpx;
  color: #4F5F52;
  background: #FAF9F5;
  font-size: 22rpx;
  font-weight: 760;
}

.story-copy {
  margin-top: 18rpx;
  color: #54514C;
  font-size: 25rpx;
  line-height: 1.72;
}

.recipe-card {
  padding-bottom: 12rpx;
}

.material-item {
  display: grid;
  grid-template-columns: 42rpx 74rpx minmax(0, 1fr);
  align-items: center;
  gap: 18rpx;
  min-height: 104rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(229,226,220,.84);
}

.material-item:last-child {
  border-bottom: 0;
}

.material-index {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 850;
}

.material-image-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 74rpx;
  height: 74rpx;
  border: 1rpx solid #EEEAE3;
  border-radius: 50%;
  background: #FBFAF7;
}

.material-image {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
}

.material-dot {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
}

.material-copy {
  min-width: 0;
}

.material-name {
  color: #252824;
  font-size: 26rpx;
  font-weight: 850;
  line-height: 1.32;
}

.material-desc {
  margin-top: 8rpx;
  color: #85817A;
  font-size: 22rpx;
  line-height: 1.45;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  box-sizing: border-box;
  display: grid;
  width: 100%;
  grid-template-columns: minmax(190rpx, 228rpx) minmax(0, 1fr);
  gap: 18rpx;
  padding: 18rpx 28rpx calc(22rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(32,32,31,.08);
  background: rgba(251,250,247,.96);
  box-shadow: 0 -10rpx 28rpx rgba(20, 20, 20, .055);
  backdrop-filter: blur(18rpx);
}

.favorite-button,
.bottom-actions .primary-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  min-height: 88rpx;
  height: 88rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 850;
  line-height: 1;
  overflow: visible;
  white-space: nowrap;
}

.favorite-button::after,
.bottom-actions .primary-button::after {
  border: 0;
}

.favorite-button {
  border: 1rpx solid rgba(32,32,31,.1);
  color: #333631;
  background: #FFFFFF;
}

.bottom-actions .primary-button {
  border: 0;
  color: #FFFFFF;
  background: #20201F;
  box-shadow: 0 12rpx 28rpx rgba(32, 32, 31, .15);
}

.favorite-button:active,
.bottom-actions .primary-button:active {
  opacity: .86;
  transform: scale(.985);
}

.empty-card {
  margin-top: 180rpx;
  padding: 42rpx 30rpx;
  text-align: center;
}

.empty-title {
  color: #222420;
  font-size: 30rpx;
  font-weight: 850;
}

.empty-desc {
  margin-top: 12rpx;
  color: #8A8D86;
  font-size: 23rpx;
}

@media (max-width: 360px) {
  .inspo-detail-page,
  .empty-page {
    padding-left: 22rpx;
    padding-right: 22rpx;
  }

  .hero-title {
    font-size: 40rpx;
  }

  .hero-media {
    height: 390rpx;
  }

  .material-item {
    grid-template-columns: 38rpx 66rpx minmax(0, 1fr);
    gap: 14rpx;
  }

  .material-image-wrap {
    width: 66rpx;
    height: 66rpx;
  }

  .material-image {
    width: 60rpx;
    height: 60rpx;
  }

  .bottom-actions {
    grid-template-columns: minmax(176rpx, 206rpx) minmax(0, 1fr);
    gap: 12rpx;
    padding-right: 22rpx;
    padding-left: 22rpx;
  }

  .favorite-button,
  .bottom-actions .primary-button {
    height: 80rpx;
    min-height: 80rpx;
    padding: 0 16rpx;
    font-size: 24rpx;
  }
}
