.success-page {
  min-height: 100vh;
  padding-top: calc(56rpx + env(safe-area-inset-top));
}

.success-card {
  padding: 48rpx 34rpx 34rpx;
  text-align: center;
  background: rgba(255,255,255,.86);
}

.success-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 126rpx;
  height: 126rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: rgba(100, 124, 112, .12);
}

.check-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  color: #fff;
  background: var(--yu-color-green);
  box-shadow: 0 16rpx 32rpx rgba(100, 124, 112, .18);
  font-size: 48rpx;
  font-weight: 800;
}

.success-title {
  margin-top: 30rpx;
  color: var(--yu-color-anchor-dark);
  font-size: 38rpx;
  font-weight: 850;
}

.success-desc {
  max-width: 520rpx;
  margin: 14rpx auto 0;
  color: var(--yu-color-text-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.info-card {
  margin-top: 36rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(247, 246, 242, .86);
  text-align: left;
}

.info-row {
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 18rpx;
  align-items: start;
  min-height: 70rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(229,226,220,.8);
}

.info-row:last-child {
  border-bottom: 0;
}

.info-row text {
  color: var(--yu-color-text-secondary);
  font-size: 23rpx;
}

.info-row view {
  color: var(--yu-color-anchor-dark);
  text-align: right;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.45;
  word-break: break-all;
}

.amount-row view {
  font-size: 30rpx;
  font-weight: 900;
}

.primary-action {
  width: 100%;
  margin-top: 36rpx;
}

.secondary-action {
  width: 100%;
  margin-top: 16rpx;
}

.tips-card {
  margin-top: 28rpx;
  padding: 30rpx;
  background: rgba(255,255,255,.72);
}

.tips-title {
  color: var(--yu-color-anchor-dark);
  font-size: 28rpx;
  font-weight: 800;
}

.tips-list {
  margin-top: 18rpx;
  color: var(--yu-color-text-secondary);
  font-size: 24rpx;
  line-height: 1.8;
}

.tips-list view::before {
  margin-right: 10rpx;
  color: var(--yu-color-green);
  content: "•";
}

.orders-link {
  margin-top: 22rpx;
  color: var(--yu-color-blue);
  font-size: 24rpx;
  font-weight: 800;
}
