<view class="page">
  <view class="nav-row">
    <view>
      <view class="nav-title">灵感社区</view>
      <view class="sub">分享设计理念、佩戴感受与水晶知识</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">DIY 作品墙</view>
    <view wx:for="{{posts}}" wx:key="id" class="post card" data-id="{{item.id}}" bindtap="openPost">
      <view class="post-image {{item.tone}}"></view>
      <view class="post-body">
        <view class="post-title">{{item.title}}</view>
        <view class="post-author">{{item.author}} · {{item.likes}} 喜欢</view>
        <view class="post-desc">{{item.desc}}</view>
        <button class="secondary-button same-button" data-id="{{item.id}}" catchtap="useSame">一键同款并修改</button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">水晶百科 / 能量学堂</view>
    <view class="lesson-list card">
      <view wx:for="{{lessons}}" wx:key="title" class="lesson">
        <view class="lesson-title">{{item.title}}</view>
        <view class="lesson-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>
</view>
