<view class="page order-detail-page" wx:if="{{order}}">
  <view class="card status-card">
    <view class="status-text">{{order.status}}</view>
    <view class="order-id">{{order.id}}</view>
    <view class="order-time">{{order.createdAt}}</view>
  </view>

  <view class="card detail-card">
    <view class="card-title">收货信息</view>
    <view class="info-row"><text>收货人</text><view>{{order.receiver.name}}</view></view>
    <view class="info-row"><text>手机号</text><view>{{order.receiver.phone}}</view></view>
    <view class="info-row"><text>地址</text><view>{{order.receiver.address}}</view></view>
  </view>

  <view class="card detail-card">
    <view class="card-title">方案材料</view>
    <view wx:for="{{order.sequence}}" wx:key="index" class="material-row">
      <view>{{item.name || item.materialId || item.id}}</view>
      <text>¥{{item.price || 0}}</text>
    </view>
    <view class="total-row">
      <text>实付</text>
      <view>¥{{order.totalAmount}}</view>
    </view>
  </view>

  <view wx:if="{{logisticsDetail}}" class="card detail-card">
    <view class="card-title">物流信息</view>
    <view class="logistics-status">{{logisticsDetail.statusText}}</view>
    <view class="logistics-meta">{{logisticsDetail.carrier}} {{logisticsDetail.trackingNo}}</view>
    <view class="logistics-source">{{logisticsDetail.source}}</view>
    <view wx:for="{{logisticsDetail.traces}}" wx:key="index" class="trace-row">
      <view class="trace-dot"></view>
      <view>
        <view class="trace-desc">{{item.desc}}</view>
        <view wx:if="{{item.location}}" class="trace-sub">{{item.location}}</view>
        <view wx:if="{{item.time}}" class="trace-sub">{{item.time}}</view>
      </view>
    </view>
  </view>

  <view class="action-bar">
    <button wx:if="{{order.statusKey === 'pay'}}" data-action="pay" bindtap="handleAction">继续支付</button>
    <button wx:if="{{order.statusKey === 'ship' && isLocalApi}}" data-action="mockShip" bindtap="handleAction">模拟发货</button>
    <button wx:if="{{order.statusKey === 'receive' || order.statusKey === 'done'}}" data-action="logistics" bindtap="handleAction">查看物流</button>
    <button wx:if="{{order.statusKey === 'receive'}}" data-action="receive" bindtap="handleAction">确认收货</button>
    <button wx:if="{{order.statusKey === 'ship' || order.statusKey === 'receive'}}" data-action="refund" bindtap="handleAction">申请退款</button>
    <button wx:if="{{order.statusKey === 'receive' || order.statusKey === 'done'}}" data-action="afterSale" bindtap="handleAction">售后</button>
  </view>
</view>

<view class="page" wx:else>
  <view class="card empty-card">订单不存在或已刷新，请返回订单列表。</view>
</view>
