page {
  min-height: 100%;
  color: #25222a;
  background: #f6f3ee;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
button,
input,
picker,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 160rpx;
}

.section {
  margin-top: 32rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #25222a;
}

.section-link {
  font-size: 24rpx;
  color: #7a4e3a;
}

.card {
  background: #fffdf9;
  border: 1rpx solid rgba(79, 59, 44, 0.08);
  border-radius: 8rpx;
  box-shadow: 0 8rpx 22rpx rgba(73, 51, 33, 0.045);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  margin: 28rpx 0 0;
  border: 0;
  border-radius: 8rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  background: #7a4e3a;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  border: 1rpx solid rgba(122, 78, 58, 0.25);
  border-radius: 8rpx;
  color: #7a4e3a;
  font-size: 28rpx;
  background: #fffdf9;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #6e655d;
  background: #f1ece4;
}

.muted {
  color: #8a8790;
}

.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
  margin-bottom: 20rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 800;
}

.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  color: #7a4e3a;
  background: #fffdf9;
}
